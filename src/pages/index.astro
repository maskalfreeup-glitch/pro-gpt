<script>
  /* â”€â”€ AUDIT FLOW â”€â”€ */
  function startAudit() {
    const val = document.getElementById('siteInput').value.trim();
    if (!val) {
      document.getElementById('siteInput').focus();
      return;
    }

    const status = document.getElementById('status');
    const track = document.getElementById('progressTrack');
    const bar = document.getElementById('progressBar');

    track.style.display = 'block';

    const steps = [
      { pct: 15, msg: 'Querying AI citation databasesâ€¦' },
      { pct: 38, msg: 'Scanning entity signalsâ€¦' },
      { pct: 62, msg: 'Checking authority markersâ€¦' },
      { pct: 85, msg: 'Running E-E-A-T analysisâ€¦' },
      { pct: 100, msg: 'Scoring your visibilityâ€¦' },
    ];

    let i = 0;
    const run = () => {
      if (i >= steps.length) {
        setTimeout(showResult, 300);
        return;
      }
      const s = steps[i++];
      status.innerHTML = `<span class="status-line"><span class="dot"></span>${s.msg}</span>`;
      bar.style.width = s.pct + '%';
      setTimeout(run, 520);
    };

    run();
  }

  function showResult() {
    document.getElementById('status').innerHTML = '';
    document.getElementById('progressTrack').style.display = 'none';

    const r = document.getElementById('result');
    r.style.display = 'block';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => r.classList.add('visible'));
    });

    r.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* â”€â”€ LEAD FORM â”€â”€ */
  function submitLead() {
    const name = document.getElementById('nameInput').value.trim();
    const email = document.getElementById('emailInput').value.trim();
    if (!email) {
      document.getElementById('emailInput').focus();
      return;
    }

    // Save locally (replace with your actual endpoint / Mailchimp / ConvertKit)
    try {
      const leads = JSON.parse(localStorage.getItem('leads') || '[]');
      leads.push({ name, email, ts: new Date().toISOString() });
      localStorage.setItem('leads', JSON.stringify(leads));
    } catch(e) {}

    document.getElementById('leadForm').style.display = 'none';
    document.getElementById('fixCta').style.display = 'block';
  }

  /* â”€â”€ ENTER KEY â”€â”€ */
  document.getElementById('siteInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') startAudit();
  });

  /* â”€â”€ SCROLL REVEALS â”€â”€ */
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); observer.unobserve(e.target); } });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

