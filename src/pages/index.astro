---
import BaseHead from '../components/BaseHead.astro';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title="ProGPT — AI Visibility Audit" description="Check if AI recommends your business." />
  
  <style>
    :root {
      --bg:#050505;
      --card:#0d1117;
      --border:#1a1a1a;
      --accent:#ccff00;
      --text:#eaeaea;
      --muted:#8a8a8a;
      --danger:#ff4444;
    }

    body {
      margin:0;
      font-family:Inter, sans-serif;
      background:var(--bg);
      color:var(--text);
    }

    /* GRID */
    body::before{
      content:"";
      position:fixed;
      inset:0;
      background:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size:40px 40px;
      z-index:-1;
    }

    nav{
      display:flex;
      justify-content:space-between;
      padding:16px 20px;
      border-bottom:1px solid var(--border);
    }

    .buy{
      background:var(--accent);
      color:#000;
      padding:8px 14px;
      border-radius:6px;
      font-weight:700;
      text-decoration:none;
    }

    .container{
      max-width:800px;
      margin:auto;
      padding:60px 20px;
    }

    h1{
      font-size:clamp(42px,8vw,72px);
      line-height:0.9;
      margin:0;
    }

    h1 span{color:var(--accent);}

    .sub{
      color:var(--muted);
      margin-top:16px;
      font-size:18px;
    }

    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:16px;
      padding:24px;
      margin-top:20px;
    }

    input{
      width:100%;
      padding:16px;
      border-radius:12px;
      border:1px solid var(--border);
      background:#000;
      color:#fff;
    }

    .btn{
      width:100%;
      padding:16px;
      margin-top:12px;
      border:none;
      border-radius:12px;
      font-weight:800;
      background:var(--accent);
      color:#000;
      cursor:pointer;
    }

    .btn-alt{
      display:block;
      margin-top:10px;
      padding:12px;
      border:1px solid var(--border);
      border-radius:12px;
      text-align:center;
      color:var(--muted);
      text-decoration:none;
      font-size:13px;
    }

    #scan{display:none;}
    .log{font-family:monospace;color:var(--accent);font-size:12px;}

    .faq-item{
      border-top:1px solid var(--border);
      padding:12px 0;
      cursor:pointer;
    }

    .faq-a{
      display:none;
      color:#aaa;
      margin-top:6px;
      font-size:14px;
    }

    .faq-item.active .faq-a{
      display:block;
    }

    .badge{
      background:rgba(255,0,0,0.1);
      color:var(--danger);
      padding:6px 10px;
      border-radius:6px;
      font-size:12px;
    }

  </style>
</head>

<body>

<nav>
  <div>PROGPT</div>
  <a href="https://whop.com/progpt" class="buy">BUY</a>
</nav>

<div class="container">

<h1>AI is already <span>choosing</span> your competitors.</h1>
<p class="sub">If you're not in AI answers, you don't exist.</p>

<!-- SHIFT -->
<div class="card">
  <h3>The shift</h3>
  <p style="color:#aaa">
    Search ranked pages. AI selects businesses.
    Only a few get recommended.
  </p>
</div>

<!-- INPUT -->
<div class="card" id="inputBox">
  <input id="url" placeholder="yourwebsite.com">
  <button class="btn" onclick="run()">Run free audit →</button>
</div>

<!-- SCAN -->
<div id="scan" class="card">
  <div id="log" class="log">Scanning...</div>
  <div style="height:3px;background:#111;margin-top:10px">
    <div id="bar" style="height:100%;width:0%;background:var(--accent)"></div>
  </div>
</div>

<!-- RESULT -->
<div id="result" style="display:none">

  <div class="card">
    <h3>Score: <span id="score"></span>/10</h3>
    <div class="badge">Low visibility</div>

    <ul id="competitors" style="color:var(--accent);margin-top:10px"></ul>

    <p id="loss" style="color:var(--danger);font-weight:700"></p>
  </div>

  <!-- FAQ -->
  <div class="card">
    <h3>Why this happens</h3>
    <div id="faq"></div>
  </div>

  <!-- CTA -->
  <div class="card">
    <input placeholder="email">
    <button class="btn" onclick="location.href='https://whop.com/progpt'">
      Fix this → $297
    </button>
    <a class="btn-alt" href="https://discord.gg/YOUR">Join Discord</a>
  </div>

</div>

</div>

<script>
function detect(url){
  url=url.toLowerCase();
  if(url.includes("shop")) return "ecommerce";
  if(url.includes("agency")) return "agency";
  return "general";
}

function faq(type){
  const map={
    ecommerce:[
      ["Why no AI traffic?","Products lack structured signals"],
      ["Fix?","Schema + entity optimization"]
    ],
    agency:[
      ["Why invisible?","No authority signals"],
      ["Fix?","Topical authority"]
    ],
    general:[
      ["Why invisible?","AI cannot trust your site"],
      ["Fix?","Structured + authority signals"]
    ]
  };

  let el=document.getElementById("faq");
  el.innerHTML="";

  map[type].forEach(q=>{
    let d=document.createElement("div");
    d.className="faq-item";
    d.innerHTML=`<strong>${q[0]}</strong><div class="faq-a">${q[1]}</div>`;
    d.onclick=()=>d.classList.toggle("active");
    el.appendChild(d);
  });
}

function run(){
  let url=document.getElementById("url").value;
  if(!url) return;

  faq(detect(url));

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";

  let w=0;
  let interval=setInterval(()=>{
    w+=2;
    document.getElementById("bar").style.width=w+"%";
    if(w>=100){
      clearInterval(interval);
      show(url);
    }
  },40);
}

function show(url){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  document.getElementById("score").innerText=(2+Math.random()*2).toFixed(1);

  let clean=url.split('.')[0];
  let list=document.getElementById("competitors");
  list.innerHTML="";

  ["top-","get-","best-"].forEach(p=>{
    let li=document.createElement("li");
    li.innerText=p+clean+".com";
    list.appendChild(li);
  });

  let lost=Math.floor(Math.random()*20+10);
  document.getElementById("loss").innerText=
    "Losing "+lost+"–"+(lost+10)+" leads/month";
}
</script>

</body>
</html>