---
// Standard Astro frontmatter
const title = "ProGPT — AI Visibility Diagnostic";
const description = "Reclaim your signal. If you are not in the AI training set, you do not exist.";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

<style>
:root {
  --bg:#050505;
  --card:#0d1117;
  --border:#1a1a1a;
  --accent:#ccff00;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --danger:#ff4444;
}

body{
  background:var(--bg);
  color:var(--text);
  font-family: system-ui, -apple-system, sans-serif;
  margin:0;
  -webkit-font-smoothing: antialiased;
}

nav{
  display:flex;
  justify-content:space-between;
  align-items: center;
  padding:16px 20px;
  border-bottom:1px solid var(--border);
  background:var(--bg);
  position: sticky;
  top: 0;
  z-index: 100;
}
.logo{font-weight:800; letter-spacing: -1px; font-family: monospace;}
.nav-btn{
  background:var(--accent);
  padding:8px 14px;
  font-weight:800;
  border-radius:6px;
  color:#000;
  text-decoration: none;
  font-size: 12px;
}

.container{
  max-width:600px;
  margin:auto;
  padding:40px 20px;
}

h1{
  font-size: 42px;
  line-height: 0.95;
  font-weight:900;
  letter-spacing: -2px;
  margin: 0 0 12px 0;
}
h1 span{color:var(--accent)}

.sub{color:var(--muted); font-size: 18px; line-height: 1.4; margin-bottom: 20px;}

.live{
  font-size:12px;
  color:var(--muted);
  margin: 15px 0;
  font-family: monospace;
}

.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
  margin-top:20px;
}

input{
  width:100%;
  padding:16px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#000;
  color:white;
  margin-top:10px;
  font-size: 16px;
  box-sizing: border-box;
}

.btn{
  width:100%;
  padding:18px;
  background:var(--accent);
  color:#000;
  font-weight:800;
  border:none;
  border-radius:10px;
  margin-top:12px;
  cursor:pointer;
  font-size: 16px;
  text-transform: uppercase;
}

#scan{display:none;}
.log{ font-size:11px; color:var(--accent); font-family: monospace; text-transform: uppercase; }

.badge{
  display:inline-block;
  background:rgba(255, 68, 68, 0.1);
  color:var(--danger);
  padding:6px 12px;
  border-radius:6px;
  font-size:11px;
  font-weight: 700;
  margin-top:10px;
}

.loss { margin-top:16px; color:#aaa; font-size:14px; line-height: 1.5; }

.btn-alt{
  display:block;
  text-align:center;
  padding:14px;
  border: 1px solid var(--border);
  border-radius:10px;
  margin-top:10px;
  color:#888;
  text-decoration:none;
  font-size: 13px;
}
</style>
</head>

<body>

<nav>
  <div class="logo">PROGPT.STORE</div>
  <a href="https://whop.com/progpt" class="nav-btn">BUY NOW</a>
</nav>

<div class="container">

<h1>AI is already <span>choosing</span> your competitors.</h1>
<p class="sub">If you're not in the AI training set, you don't exist.</p>

<div class="live">
  <span style="color:var(--danger)">●</span> <span id="liveCount">24</span> operators scanning
</div>

<div id="input-container" class="card">
  <input id="url" type="text" placeholder="yourwebsite.com">
  <button class="btn" onclick="runAudit()">Run free audit →</button>
</div>

<div id="scan" class="card">
  <div id="log" class="log">Initializing neural scan...</div>
  <div style="height:2px; background:#111; margin-top:15px;">
    <div id="bar" style="height:100%; width:0%; background:var(--accent); transition: width 0.1s linear;"></div>
  </div>
</div>

<div id="result" style="display:none">
  <div class="card" style="border-color: rgba(255,68,68,0.2);">
    <h3 style="margin:0; font-size: 24px;">Score: <span id="score">--</span>/10</h3>
    <div class="badge">Visibility Critical</div>
    <p class="loss" id="lossText" style="color: var(--danger); font-weight: 600;"></p>
    <input type="email" placeholder="operator@email.com">
    <button class="btn" onclick="location.href='https://whop.com/progpt'">
      Reclaim your signal — $297
    </button>
    <a class="btn-alt" href="https://whop.com/progpt">Checkout via Whop</a>
  </div>
</div>

</div>

<script is:inline>
function runAudit(){
  const url = document.getElementById('url').value;
  if(!url) return;
  document.getElementById('input-container').style.display='none';
  document.getElementById('scan').style.display='block';
  let w = 0;
  const interval = setInterval(() => {
    w += 2;
    document.getElementById('bar').style.width = w + "%";
    if(w >= 100) {
      clearInterval(interval);
      document.getElementById('scan').style.display='none';
      document.getElementById('result').style.display='block';
      document.getElementById('score').innerText = (2.4 + Math.random()).toFixed(1);
      document.getElementById('lossText').innerText = "Estimated Leak: 14-28 leads / month";
    }
  }, 40);
}
</script>

</body>
</html>
