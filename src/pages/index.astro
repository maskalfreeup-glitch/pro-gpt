<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Visibility Engine</title>

<style>
:root{
  --bg:#050505;
  --panel:#0d1117;
  --border:#1a1a1a;
  --accent:#00ff9f;
  --text:#eaeaea;
  --muted:#777;
  --danger:#ff4444;
}

*{box-sizing:border-box;}

body{
  margin:0;
  font-family:Inter,system-ui;
  background:var(--bg);
  color:var(--text);
}

/* GRID */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size:40px 40px;
  z-index:-1;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:16px 20px;
  border-bottom:1px solid var(--border);
}

.logo{font-weight:800;}
.links a{
  color:var(--muted);
  margin-left:16px;
  text-decoration:none;
  font-size:14px;
}

/* LAYOUT */
.container{
  max-width:1000px;
  margin:auto;
  padding:40px 20px;
}

/* HERO */
h1{
  font-size:clamp(36px,6vw,64px);
  line-height:1;
  margin:0;
}
h1 span{color:var(--accent);}
.sub{
  color:var(--muted);
  margin-top:12px;
}

/* PANELS */
.panel{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:14px;
  padding:20px;
  margin-top:20px;
  box-shadow:0 0 30px rgba(0,255,159,0.04);
}

/* FLEX */
.row{
  display:grid;
  grid-template-columns:1fr;
  gap:20px;
}

@media(min-width:900px){
  .row{
    grid-template-columns:2fr 1fr;
  }
}

/* INPUT */
input{
  width:100%;
  padding:16px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#000;
  color:#fff;
}

/* BUTTON */
.btn{
  width:100%;
  padding:16px;
  margin-top:10px;
  border:none;
  border-radius:10px;
  background:var(--accent);
  color:#000;
  font-weight:700;
  cursor:pointer;
  transition:0.15s;
}
.btn:hover{filter:brightness(1.1);}

/* TEXT */
.muted{color:var(--muted);font-size:13px;}
.badge{color:var(--danger);font-size:12px;margin-top:6px;}

/* SCAN */
#scan,#result,#paywall{display:none;}

.bar-bg{height:4px;background:#111;margin-top:10px;}
.bar{height:100%;width:0%;background:var(--accent);}

/* LIST */
ul{padding-left:18px;}
li{margin:6px 0;}

/* FAQ */
.faq-item{
  border-top:1px solid var(--border);
  padding:10px 0;
  cursor:pointer;
}
.faq-a{display:none;color:#aaa;font-size:13px;}
.faq-item.active .faq-a{display:block;}
</style>
</head>

<body>

<nav>
  <div class="logo">AI VISIBILITY</div>
  <div class="links">
    <a href="/blog">Blog</a>
    <a href="#">Discord</a>
  </div>
</nav>

<div class="container">

<!-- SYSTEM BAR -->
<div class="panel" style="display:flex;justify-content:space-between;font-size:12px;">
  <div>System: <span style="color:var(--accent)">Online</span></div>
  <div>AI Index: Active</div>
  <div>Usage: <span id="usageCount">0</span>/3</div>
</div>

<h1>AI is already <span>choosing</span> your competitors.</h1>
<p class="sub">This engine checks if your business exists inside AI answers.</p>

<div class="row">

<!-- MAIN -->
<div>

<div class="panel" id="inputBox">
  <input id="url" placeholder="yourwebsite.com">
  <button class="btn" onclick="run()">Run audit</button>
  <div class="muted">Free tier: 3 scans</div>
</div>

<div id="scan" class="panel">
  <div id="log">Initializing scan...</div>
  <div class="bar-bg"><div class="bar" id="bar"></div></div>
</div>

<div id="result">

  <div class="panel">
    <h3>Score: <span id="score"></span>/10</h3>
    <div class="badge">LOW AI TRUST</div>

    <p class="muted">AI is recommending:</p>
    <ul id="competitors"></ul>

    <p id="loss" style="color:var(--danger);font-weight:700;"></p>
  </div>

  <div class="panel">
    <h3>Why this happens</h3>
    <div id="faq"></div>
  </div>

</div>

<div id="paywall" class="panel">
  <h3>Limit reached</h3>
  <p class="muted">Upgrade for full access</p>

  <ul>
    <li>Unlimited scans</li>
    <li>Competitor insights</li>
    <li>AI optimization signals</li>
  </ul>

  <button class="btn" onclick="goPro()">Upgrade via Whop</button>
</div>

</div>

<!-- SIDE PANEL -->
<div class="panel">
  <div class="muted">LIVE SIGNALS</div>
  <div class="muted">• Monitoring AI responses</div>
  <div class="muted">• Tracking competitors</div>
  <div class="muted">• Updating entity graph</div>
</div>

</div>

</div>

<script>

/* USER */
function getUser(){
  let id=localStorage.getItem("uid");
  if(!id){
    id="u_"+Math.random().toString(36).slice(2);
    localStorage.setItem("uid",id);
  }
  return id;
}

/* USAGE */
function getUsage(){
  return JSON.parse(localStorage.getItem("usage")||'{"scans":0}');
}
function incUsage(){
  let u=getUsage();
  u.scans++;
  localStorage.setItem("usage",JSON.stringify(u));
  updateUsageUI();
}

/* UI UPDATE */
function updateUsageUI(){
  document.getElementById("usageCount").innerText=getUsage().scans;
}
updateUsageUI();

/* LOCK */
function isLocked(){
  let pro=localStorage.getItem("pro");
  let u=getUsage();
  return !pro && u.scans>=3;
}

/* RUN */
function run(){
  let url=document.getElementById("url").value;
  if(!url.includes(".")) return alert("Enter valid domain");

  if(isLocked()){
    document.getElementById("paywall").style.display="block";
    return;
  }

  incUsage();

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";

  let logs=[
    "Scanning structure...",
    "Analyzing AI signals...",
    "Checking competitors...",
    "Finalizing..."
  ];

  let w=0,i=0;
  let int=setInterval(()=>{
    w+=2;
    document.getElementById("bar").style.width=w+"%";

    if(w%25===0 && i<logs.length){
      document.getElementById("log").innerText=logs[i++];
    }

    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },40);
}

/* RESULT */
function show(url){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  document.getElementById("score").innerText=(2+Math.random()*2).toFixed(1);

  let clean=url.replace(/^(https?:\/\/)?(www\.)?/,"").split('.')[0];
  let list=document.getElementById("competitors");
  list.innerHTML="";

  ["top-","best-","get-"].forEach(p=>{
    let li=document.createElement("li");
    li.innerText=p+clean+".com";
    list.appendChild(li);
  });

  let lost=Math.floor(Math.random()*20+10);
  document.getElementById("loss").innerText=
    "Estimated loss: "+lost+"–"+(lost+10)+" leads/month";

  renderFAQ();
}

/* FAQ */
function renderFAQ(){
  let data=[
    ["Why not in AI results?","No structured entity data."],
    ["What fixes it?","GEO + schema optimization."],
    ["Timeline?","2–4 weeks."]
  ];

  let el=document.getElementById("faq");
  el.innerHTML="";

  data.forEach(q=>{
    let d=document.createElement("div");
    d.className="faq-item";
    d.innerHTML="<strong>"+q[0]+"</strong><div class='faq-a'>"+q[1]+"</div>";
    d.onclick=()=>d.classList.toggle("active");
    el.appendChild(d);
  });
}

/* WHOP */
function goPro(){
  window.location.href="https://whop.com/progpt";
}

</script>

</body>
</html>