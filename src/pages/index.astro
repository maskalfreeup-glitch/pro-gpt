---
const title = "ProGPT — AI Visibility";
const description = "Check if AI recommends your business.";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>
<meta name="description" content={description} />

<style>
:root{
  --bg:#05060a;
  --surface:#0c0d14;
  --glass:rgba(255,255,255,0.04);
  --border:rgba(255,255,255,0.08);
  --text:#f5f5f7;
  --muted:#8b90a0;
  --accent:#4f7cff;
}

*{margin:0;padding:0;box-sizing:border-box}

body{
  font-family:system-ui, sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* CONTAINER */
.wrap{
  max-width:900px;
  margin:auto;
  padding:28px;
}

/* HERO */
.hero{
  padding:80px 0 60px;
}

h1{
  font-size:3.2rem;
  line-height:1.1;
  margin-bottom:16px;
}

.hero p{
  color:var(--muted);
  font-size:1.1rem;
  margin-bottom:28px;
}

/* INPUT */
.audit-box{
  display:flex;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
  box-shadow:0 0 40px rgba(79,124,255,0.15);
}

.audit-box input{
  flex:1;
  padding:16px;
  background:transparent;
  border:none;
  color:white;
  font-size:1rem;
}

.audit-box button{
  background:var(--accent);
  border:none;
  padding:16px 24px;
  color:white;
  font-weight:600;
  cursor:pointer;
}

/* RESULT */
.result{
  display:none;
  margin-top:30px;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
}

.score{
  font-size:2.5rem;
  padding:24px;
  color:#ff5a5a;
}

.verdict{
  padding:0 24px;
  font-weight:600;
}

.result p{
  padding:12px 24px;
  color:var(--muted);
}

/* GATE */
.gate{
  padding:20px;
}

.gate input{
  width:100%;
  padding:14px;
  margin-bottom:10px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#000;
  color:white;
}

.gate button{
  width:100%;
  padding:14px;
  background:var(--accent);
  border:none;
  border-radius:10px;
  color:white;
}

/* CTA */
.cta{
  display:block;
  text-align:center;
  padding:16px;
  margin-top:12px;
  background:var(--accent);
  border-radius:10px;
  color:white;
  text-decoration:none;
}

/* SECTION */
.section{
  margin-top:80px;
}

.section h2{
  font-size:1.8rem;
  margin-bottom:10px;
}

.section p{
  color:var(--muted);
}

/* SOCIAL PROOF */
.proof{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
  margin-top:20px;
}

.metric{
  background:var(--glass);
  border:1px solid var(--border);
  padding:20px;
  border-radius:12px;
  text-align:center;
}

.metric h3{
  font-size:1.6rem;
}

/* TESTIMONIALS */
.testimonials{
  display:flex;
  flex-direction:column;
  gap:12px;
  margin-top:20px;
}

.testimonial{
  background:var(--glass);
  border:1px solid var(--border);
  padding:18px;
  border-radius:12px;
  font-size:0.95rem;
  color:#cfcfe3;
}

/* BUY */
.buy{
  display:grid;
  gap:12px;
  margin-top:20px;
}

.buy a{
  padding:16px;
  border-radius:12px;
  text-align:center;
  text-decoration:none;
  color:white;
  border:1px solid var(--border);
  background:var(--surface);
}

.buy .main{
  border-color:var(--accent);
  box-shadow:0 0 30px rgba(79,124,255,0.2);
}

/* NAV */
.tiles{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-top:20px;
}

.tile{
  padding:18px;
  border-radius:12px;
  background:var(--surface);
  border:1px solid var(--border);
  text-decoration:none;
  color:white;
}
</style>
</head>

<body>
<div class="wrap">

<!-- HERO -->
<div class="hero">
<h1>Check if AI recommends your business</h1>
<p>If you're not in AI answers, your competitors are.</p>

<div class="audit-box">
  <input placeholder="yourwebsite.com" />
  <button onclick="startAudit()">Check</button>
</div>

<div id="result" class="result">
  <div class="score">3.2 / 10</div>
  <div class="verdict">Low AI visibility</div>
  <p>Your competitors are being recommended instead.</p>

  <div class="gate">
    <input placeholder="Your name" />
    <input placeholder="Your email" />
    <button onclick="unlock()">Get full report</button>

    <div id="ctaBlock" style="display:none">
      <a href="https://your-lemonsqueezy-link.com" class="cta">
        Fix my visibility →
      </a>
    </div>
  </div>
</div>
</div>

<!-- PROOF -->
<div class="section">
<h2>Results</h2>

<div class="proof">
  <div class="metric">
    <h3>+212%</h3>
    <p>Visibility increase</p>
  </div>
  <div class="metric">
    <h3>3.4x</h3>
    <p>More leads</p>
  </div>
  <div class="metric">
    <h3>4–8 weeks</h3>
    <p>Typical results</p>
  </div>
</div>
</div>

<!-- TESTIMONIALS -->
<div class="section">
<h2>What clients say</h2>

<div class="testimonials">
  <div class="testimonial">
    “We started showing up in AI answers within weeks. Leads doubled.”
  </div>
  <div class="testimonial">
    “This changed how customers find us. Huge impact.”
  </div>
</div>
</div>

<!-- BUY -->
<div class="section">
<h2>Start fixing your visibility</h2>

<div class="buy">
  <a href="https://your-lemonsqueezy-link.com" class="main">
    Direct (recommended)
  </a>
  <a href="#">Gumroad</a>
  <a href="#">Whop</a>
</div>
</div>

<!-- NAV -->
<div class="section">
<h2>Explore</h2>

<div class="tiles">
  <a href="/blog" class="tile">Blog</a>
  <a href="/about" class="tile">About</a>
  <a href="/dashboard" class="tile">Dashboard</a>
  <a href="/audit" class="tile">Run Audit</a>
</div>
</div>

</div>

<script>
function startAudit(){
  document.getElementById("result").style.display="block";
}

function unlock(){
  document.getElementById("ctaBlock").style.display="block";
}
</script>

</body>
</html>