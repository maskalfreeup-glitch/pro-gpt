---
const title = "AI Visibility Audit";
const description = "Check if ChatGPT recommends your business.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
        background: #000;
        color: #fff;
      }

      .container {
        max-width: 700px;
        margin: 0 auto;
        padding: 60px 20px;
        text-align: center;
      }

      h1 {
        font-size: 2rem;
        margin-bottom: 10px;
      }

      p {
        color: #aaa;
        margin-bottom: 30px;
      }

      .input-box {
        display: flex;
        background: #111;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 20px;
      }

      input {
        flex: 1;
        padding: 14px;
        border: none;
        outline: none;
        background: transparent;
        color: #fff;
        font-size: 1rem;
      }

      button {
        background: #7C3AED;
        border: none;
        padding: 14px 20px;
        color: white;
        cursor: pointer;
        font-weight: 600;
      }

      .result {
        background: #111;
        border-radius: 8px;
        padding: 20px;
        margin-top: 20px;
        display: none;
        text-align: left;
      }

      .score {
        font-size: 1.5rem;
        margin-bottom: 10px;
      }

      .cta {
        margin-top: 20px;
        display: block;
        background: #7C3AED;
        padding: 14px;
        text-decoration: none;
        color: white;
        border-radius: 6px;
        font-weight: bold;
        text-align: center;
      }

      footer {
        margin-top: 60px;
        font-size: 0.8rem;
        color: #666;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>Check if ChatGPT recommends your business</h1>
      <p>AI Visibility Audit for local businesses</p>

      <div class="input-box">
        <input id="siteInput" placeholder="Enter your website..." />
        <button onclick="runAudit()">Check</button>
      </div>

      <div id="result" class="result">
        <div class="score">AI Visibility Score: 3.2 / 10</div>
        <div>❌ Not recommended in AI answers</div>
        <div>⚠️ Weak positioning signals</div>

        <a
          class="cta"
          href="https://yourstore.lemonsqueezy.com/checkout/buy/XXXX"
          target="_blank"
        >
          Unlock full audit → $19
        </a>
      </div>

      <footer>
        progpt.store — AI Search Optimization
      </footer>
    </div>

    <script>
      function runAudit() {
        const input = document.getElementById("siteInput").value;
        if (!input) return;

        // TEMP FAKE RESULT (replace with Worker later)
        document.getElementById("result").style.display = "block";
      }
    </script>
  </body>
</html>