---
// Meta
const title = "AI Visibility Engine";
const description = "Check if AI is choosing your competitors.";
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#f7f6f3;
  --card:#ffffff;
  --border:#e8e8e3;
  --ink:#1a1a18;
  --muted:#6b6b63;
  --accent:#2f54eb;
  --danger:#de350b;
}

body{
  margin:0;
  font-family:'Geist',sans-serif;
  background:var(--bg);
  color:var(--ink);
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:12px 20px;
  border-bottom:1px solid var(--border);
}

.logo{font-weight:700}

.nav a{
  margin-left:16px;
  text-decoration:none;
  color:var(--muted);
  font-size:14px;
}

/* HERO */
.hero{
  max-width:720px;
  margin:80px auto 30px;
  text-align:center;
  padding:0 20px;
}

h1{
  font-family:'Instrument Serif',serif;
  font-size:clamp(36px,7vw,64px);
  line-height:1.05;
  margin:0;
}

.sub{
  color:var(--muted);
  margin-top:14px;
  font-size:18px;
}

/* MACHINE */
.machine{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:16px;
  margin-top:28px;
}

.input-wrap{
  display:flex;
  gap:8px;
}

input{
  flex:1;
  padding:14px;
  border-radius:10px;
  border:1px solid var(--border);
  font-size:16px;
}

button{
  background:var(--ink);
  color:white;
  border:none;
  padding:14px 18px;
  border-radius:10px;
  cursor:pointer;
}

.status{
  font-size:12px;
  color:var(--muted);
  margin-top:10px;
  font-family:monospace;
}

/* SCAN */
#scan,#result,#emailGate,#paywall{display:none;}

.bar-bg{
  height:3px;
  background:#eee;
  margin-top:10px;
  border-radius:10px;
}

.bar{
  height:100%;
  width:0%;
  background:var(--ink);
}

/* RESULT */
.output{
  margin-top:16px;
  padding:14px;
  background:#fafafa;
  border-radius:10px;
  border:1px solid var(--border);
}

.danger{
  color:var(--danger);
  font-weight:600;
}

/* LIST */
ul{
  padding-left:18px;
  color:var(--danger);
}

/* CTA */
.cta{
  text-align:center;
  margin-top:20px;
}

.cta a{
  display:inline-block;
  margin:6px;
  padding:10px 16px;
  border-radius:8px;
  text-decoration:none;
  font-size:14px;
}

.primary{background:var(--ink);color:white;}
.secondary{border:1px solid var(--border);color:var(--ink);}

footer{
  text-align:center;
  font-size:12px;
  color:var(--muted);
  padding:40px 0;
}
</style>
</head>

<body>

<nav>
  <div class="logo">AI Visibility</div>
  <div class="nav">
    <a href="/blog">Blog</a>
    <a href="https://discord.gg/progpt">Discord</a>
  </div>
</nav>

<div class="hero">
  <h1>AI is already choosing your competitors.</h1>
  <p class="sub">Check if your business exists in AI answers.</p>

  <div class="machine">

    <div id="inputBox" class="input-wrap">
      <input id="url" placeholder="yourwebsite.com">
      <button onclick="run()">Reveal →</button>
    </div>

    <div id="status" class="status">
      AI index active • competitors already ranking
    </div>

    <div style="font-size:11px;color:#999;margin-top:6px;">
      Most businesses score below 3/10
    </div>

    <div id="scan">
      <div class="bar-bg"><div id="bar" class="bar"></div></div>
    </div>

    <!-- RESULT -->
    <div id="result" class="output">
      <strong>Visibility Score:</strong>
      <div style="font-size:24px;margin:6px 0;">
        <span id="score"></span>/10
      </div>

      <div class="danger">Not recommended in AI answers</div>

      <div style="margin-top:12px;">
        AI is recommending:
        <ul id="competitors"></ul>
      </div>
    </div>

    <!-- EMAIL GATE -->
    <div id="emailGate" class="output">
      <strong>Get full report</strong>
      <p style="font-size:13px;color:var(--muted);">
        See exact fixes + ranking signals
      </p>
      <input id="email" placeholder="your@email.com">
      <button onclick="unlock()">Unlock →</button>
    </div>

    <!-- PAYWALL -->
    <div id="paywall" class="output">
      <strong>Free limit reached</strong>
      <p style="font-size:13px;color:var(--muted);">
        Upgrade to continue scanning + unlock full optimization system
      </p>

      <div class="cta">
        <a href="https://whop.com/progpt" class="primary">Upgrade Access</a>
        <a href="https://discord.gg/progpt" class="secondary">Join Research</a>
      </div>
    </div>

  </div>
</div>

<footer>
© {year} ProGPT
</footer>

<script is:inline>
let scans = localStorage.getItem("scans") || 0;

function run(){
  let url=document.getElementById("url").value;
  if(!url || !url.includes(".")) return;

  if(scans >= 3){
    document.getElementById("inputBox").style.display="none";
    document.getElementById("paywall").style.display="block";
    return;
  }

  scans++;
  localStorage.setItem("scans", scans);

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";
  document.getElementById("status").innerText="Analyzing AI signal graph...";

  let w=0;
  let int=setInterval(()=>{
    w+=4;
    document.getElementById("bar").style.width=w+"%";

    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },40);
}

function show(url){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(1.2 + Math.random()*2.2).toFixed(1);
  document.getElementById("score").innerText=score;

  let clean=url.split('.')[0];
  let list=document.getElementById("competitors");
  list.innerHTML="";

  ["top","best","get"].forEach(p=>{
    let li=document.createElement("li");
    li.innerText=p+"-"+clean+".com";
    list.appendChild(li);
  });

  setTimeout(()=>{
    document.getElementById("emailGate").style.display="block";
  },1200);
}

function unlock(){
  let email=document.getElementById("email").value;
  if(!email.includes("@")) return;

  // Later connect to backend
  window.location.href="https://whop.com/progpt";
}
</script>

</body>
</html>