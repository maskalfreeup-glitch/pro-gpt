<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>ProGPT — AI Visibility Audit</title>
<meta name="description" content="Check if AI recommends your business. Fix your visibility in ChatGPT, Gemini & AI search." />

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#05060c;
  --card:#0c0f17;
  --border:rgba(255,255,255,0.08);
  --text:#eef1f7;
  --muted:#6b7285;
  --accent:#4f8bff;
  --accent2:#00d4aa;
}

*{box-sizing:border-box;margin:0;padding:0}

body{
  background:var(--bg);
  color:var(--text);
  font-family:'DM Mono',monospace;
}

.wrap{max-width:920px;margin:auto;padding:0 20px}

h1,h2{font-family:'Syne',sans-serif;font-weight:800;letter-spacing:-0.03em}

h1{font-size:clamp(2.5rem,6vw,4rem);line-height:1.05}
h2{font-size:clamp(1.6rem,4vw,2.2rem)}

.sub{color:var(--muted);margin:20px 0 30px;line-height:1.7}

nav{
  position:fixed;top:0;width:100%;
  background:rgba(5,6,12,0.8);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
}

.nav-inner{
  max-width:920px;margin:auto;
  padding:14px 20px;
  display:flex;justify-content:space-between
}

.hero{padding-top:120px;padding-bottom:80px}

.input{
  display:flex;
  border:1px solid var(--border);
  border-radius:12px;
  overflow:hidden;
  background:var(--card)
}

.input input{
  flex:1;
  padding:16px;
  border:none;
  background:transparent;
  color:white;
}

.btn{
  background:var(--accent);
  color:white;
  border:none;
  padding:0 20px;
  cursor:pointer;
  font-weight:600;
}

.note{font-size:12px;color:var(--muted);margin-top:10px}

#result{
  display:none;
  margin-top:25px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:20px;
}

.score{
  font-size:2rem;
  font-weight:800;
  color:#ff4d5a;
}

.cta{
  display:block;
  margin-top:15px;
  background:linear-gradient(135deg,#4f8bff,#6a5acd);
  padding:14px;
  border-radius:10px;
  text-align:center;
  text-decoration:none;
  color:white;
  font-weight:700;
}

.section{padding:80px 0}

.cards{display:grid;gap:12px}

.card{
  padding:20px;
  border:1px solid var(--border);
  border-radius:12px;
  background:var(--card);
}

.metrics{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
}

.metric{
  padding:20px;
  border:1px solid var(--border);
  border-radius:12px;
  text-align:center;
}

.price-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
}

.price{
  padding:24px;
  border:1px solid var(--border);
  border-radius:14px;
  background:var(--card);
}

.featured{
  border-color:var(--accent);
}

footer{
  padding:40px 0;
  border-top:1px solid var(--border);
  text-align:center;
  color:var(--muted);
}

@media(max-width:700px){
  .metrics,.price-grid{grid-template-columns:1fr}
}
</style>
</head>

<body>

<nav>
  <div class="nav-inner">
    <div>ProGPT</div>
    <div style="font-size:12px;color:var(--muted)">AI Visibility</div>
  </div>
</nav>

<div class="wrap">

<!-- HERO -->
<section class="hero">

<h1>AI already chose your competitors.</h1>

<p class="sub">
When someone asks ChatGPT for your service, only a few businesses get named.
If you're not in the answer, you don't exist.
</p>

<div class="input">
  <input id="url" placeholder="yourwebsite.com">
  <button class="btn" onclick="run()">Check</button>
</div>

<div class="note">Free instant audit · No signup</div>

<div style="margin-top:15px;font-size:12px;color:var(--muted)">
🔴 12 businesses checked their visibility in the last hour
</div>

<!-- RESULT -->
<div id="result">
  <div class="score" id="score">3.2 / 10</div>
  <p style="margin-top:8px;color:var(--muted)">
  Your competitors are being recommended by AI. You are not.
  </p>

  <input placeholder="Email" id="email" style="margin-top:12px;padding:10px;width:100%">

  <button class="btn" style="margin-top:10px;width:100%" onclick="unlock()">
    Get full report →
  </button>

  <a href="#pricing" class="cta">Fix this now →</a>
</div>

</section>

<!-- SHIFT -->
<section class="section">
<h2>The shift</h2>
<p class="sub">
SEO ranked pages. AI selects businesses.
There is no page 2 anymore.
</p>
</section>

<!-- METRICS -->
<section class="section">
<h2>Results</h2>

<div class="metrics">
  <div class="metric"><strong>+212%</strong><br>Visibility</div>
  <div class="metric"><strong>3.4x</strong><br>Leads</div>
  <div class="metric"><strong>4–8 weeks</strong><br>Typical</div>
</div>

</section>

<!-- TESTIMONIALS -->
<section class="section">
<h2>What clients say</h2>

<div class="cards">
  <div class="card">“We started showing up in AI answers within weeks.”</div>
  <div class="card">“This changed how customers find us.”</div>
</div>
</section>

<!-- PRICING -->
<section class="section" id="pricing">
<h2>Fix your visibility</h2>

<div class="price-grid">

  <a href="https://your-lemonsqueezy-link.com" class="price featured">
    <strong>$297</strong>
    <p>Done-for-you AI optimization</p>
  </a>

  <a href="https://gumroad.com" class="price">
    <strong>$47</strong>
    <p>Blueprint</p>
  </a>

  <a href="https://whop.com" class="price">
    <strong>$97</strong>
    <p>Automation</p>
  </a>

</div>
</section>

<!-- FINAL CTA -->
<section class="section" style="text-align:center">
<h2>AI is already choosing who gets customers.</h2>
<p class="sub">Right now, it's not you.</p>
<a href="#pricing" class="cta">Fix that →</a>

<div style="margin-top:15px">
<a href="https://wa.me/91XXXXXXXXXX" style="color:var(--muted);font-size:12px">
Chat on WhatsApp →
</a>
</div>
</section>

<footer>
ProGPT.store — AI Search Optimization
</footer>

</div>

<script>
function run(){
  let s=(Math.random()*4+2).toFixed(1);
  document.getElementById('score').innerText=s+" / 10";
  document.getElementById('result').style.display='block';
}

function unlock(){
  let email=document.getElementById('email').value;
  let leads=JSON.parse(localStorage.getItem('leads')||"[]");
  leads.push({email});
  localStorage.setItem('leads',JSON.stringify(leads));
}
</script>

</body>
</html>