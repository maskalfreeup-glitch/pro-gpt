  <script>
    function handleCapture() {
      const email = document.getElementById("captureEmail").value.trim();
      if (!email || !email.includes("@")) {
        document.getElementById("captureEmail").focus();
        return;
      }

      // Save to localStorage
      try {
        const leads = JSON.parse(localStorage.getItem("progpt_leads") || "[]");
        leads.push({ email, ts: new Date().toISOString(), source: "homepage" });
        localStorage.setItem("progpt_leads", JSON.stringify(leads));
      } catch(e) {}

      // Show success
      document.getElementById("captureEmail").style.display = "none";
      document.querySelector(".capture-btn").style.display = "none";
      document.getElementById("captureSuccess").style.display = "block";

      // Redirect to audit after 1.5s
      setTimeout(() => {
        window.location.href = "/audit";
      }, 1500);
    }

    document.getElementById("captureEmail").addEventListener("keydown", e => {
      if (e.key === "Enter") handleCapture();
    });
  </script>

