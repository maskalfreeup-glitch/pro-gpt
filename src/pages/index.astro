<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ProGPT — AI Visibility Audit</title>

<style>
:root{
  --bg:#050505;
  --card:#0d1117;
  --border:#1a1a1a;
  --accent:#ccff00;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --danger:#ff4444;
}

body{
  margin:0;
  font-family:Inter, sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* GRID BACKGROUND */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size:40px 40px;
  z-index:-1;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:16px 20px;
  border-bottom:1px solid var(--border);
}

.logo{font-weight:800;}
.buy{
  background:var(--accent);
  color:#000;
  padding:8px 14px;
  border-radius:6px;
  font-weight:700;
  text-decoration:none;
}

/* LAYOUT */
.container{
  max-width:800px;
  margin:auto;
  padding:60px 20px;
}

/* HERO */
h1{
  font-size:clamp(42px,8vw,72px);
  line-height:0.9;
  margin:0;
  letter-spacing:-2px;
}

h1 span{color:var(--accent);}

.sub{
  color:var(--muted);
  margin-top:16px;
  font-size:18px;
}

/* CARD */
.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
  margin-top:20px;
  backdrop-filter:blur(10px);
}

/* INPUT */
input{
  width:100%;
  padding:16px;
  border-radius:12px;
  border:1px solid var(--border);
  background:#000;
  color:#fff;
  font-size:16px;
}

/* BUTTON */
.btn{
  width:100%;
  padding:16px;
  margin-top:12px;
  border:none;
  border-radius:12px;
  font-weight:800;
  background:var(--accent);
  color:#000;
  cursor:pointer;
}

/* ALT */
.btn-alt{
  display:block;
  margin-top:10px;
  padding:12px;
  border:1px solid var(--border);
  border-radius:12px;
  text-align:center;
  color:var(--muted);
  text-decoration:none;
  font-size:13px;
}

/* SCAN */
#scan{display:none;}
.log{font-family:monospace;color:var(--accent);font-size:12px}

/* FAQ */
.faq-item{
  border-top:1px solid var(--border);
  padding:14px 0;
  cursor:pointer;
}

.faq-a{
  display:none;
  margin-top:8px;
  color:#aaa;
  font-size:14px;
}

.faq-item.active .faq-a{
  display:block;
}

/* BADGE */
.badge{
  background:rgba(255,0,0,0.1);
  color:var(--danger);
  padding:6px 10px;
  border-radius:6px;
  font-size:12px;
}
</style>
</head>

<body>

<nav>
  <div class="logo">PROGPT</div>
  <a href="https://whop.com/progpt" class="buy">BUY</a>
</nav>

<div class="container">

<h1>AI is already <span id="dynamicWord">choosing</span> your competitors.</h1>
<p class="sub" id="dynamicSub">
If you're not in AI answers, you don't exist.
</p>

<div class="card" id="inputBox">
<input id="url" placeholder="yourwebsite.com">
<button class="btn" onclick="run()">Run free audit →</button>
</div>

<!-- SCAN -->
<div id="scan" class="card">
<div id="log" class="log">Initializing scan...</div>
<div style="height:3px;background:#111;margin-top:10px">
<div id="bar" style="height:100%;width:0%;background:var(--accent)"></div>
</div>
</div>

<!-- RESULT -->
<div id="result" style="display:none">

<div class="card">
<h3>Score: <span id="score"></span>/10</h3>
<div class="badge">Visibility Critical</div>

<ul id="competitors" style="color:var(--accent);font-family:monospace"></ul>

<p id="loss" style="color:var(--danger);font-weight:700"></p>

<input placeholder="Enter email">
<button class="btn" onclick="location.href='https://whop.com/progpt'">
Fix this → $297
</button>

<a class="btn-alt" href="https://discord.gg/YOUR">
Join free Discord
</a>

</div>

<!-- FAQ -->
<div class="card">
<h3>Why this is happening</h3>

<div class="faq" id="faq"></div>

</div>

</div>

</div>

<script>

/* ===== PERSONALIZATION ===== */
function detectNiche(url){
  url = url.toLowerCase();

  if(url.includes("shop") || url.includes("store")) return "ecommerce";
  if(url.includes("agency")) return "agency";
  if(url.includes("clinic") || url.includes("dent")) return "local";

  return "general";
}

/* ===== FAQ GENERATOR ===== */
function loadFAQ(type){
  const faq = document.getElementById("faq");

  const data = {
    ecommerce:[
      ["Why no AI traffic?","Product pages lack structured signals."],
      ["What fixes it?","Schema + product entity optimization."]
    ],
    agency:[
      ["Why invisible?","No authority graph or citations."],
      ["Fix?","Entity authority + topical dominance."]
    ],
    local:[
      ["Why not showing?","Weak local signals."],
      ["Fix?","Location authority + citations."]
    ],
    general:[
      ["Why invisible?","AI can't trust your content."],
      ["Fix?","Structured + authoritative signals."]
    ]
  };

  faq.innerHTML = "";

  data[type].forEach(q=>{
    let div=document.createElement("div");
    div.className="faq-item";
    div.innerHTML=`<strong>${q[0]}</strong><div class="faq-a">${q[1]}</div>`;
    div.onclick=()=>div.classList.toggle("active");
    faq.appendChild(div);
  });
}

/* ===== RUN AUDIT ===== */
function run(){
  let url=document.getElementById("url").value;
  if(!url) return;

  let niche=detectNiche(url);
  loadFAQ(niche);

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";

  let logs=[
    "Scanning structure...",
    "Analyzing AI signals...",
    "Checking competitors...",
    "Finalizing..."
  ];

  let i=0, w=0;

  let interval=setInterval(()=>{
    w+=2;
    document.getElementById("bar").style.width=w+"%";

    if(w%25===0){
      document.getElementById("log").innerText=logs[i++];
    }

    if(w>=100){
      clearInterval(interval);
      show(url);
    }
  },40);
}

/* ===== RESULT ===== */
function show(url){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(2+Math.random()*2).toFixed(1);
  document.getElementById("score").innerText=score;

  let clean=url.replace(/^(https?:\/\/)?(www\.)?/,"").split('.')[0];

  let prefixes=["get-","top-","try-","best-"];
  let list=document.getElementById("competitors");

  list.innerHTML="";
  for(let i=0;i<3;i++){
    let li=document.createElement("li");
    li.innerText=prefixes[Math.floor(Math.random()*prefixes.length)] + clean + ".com";
    list.appendChild(li);
  }

  let lost=Math.floor(Math.random()*20+10);
  document.getElementById("loss").innerText=
    "Estimated loss: "+lost+"–"+(lost+15)+" leads/month";
}

</script>

</body>
</html>