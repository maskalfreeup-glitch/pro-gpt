---
// Meta
const title = "AI Visibility Engine";
const description = "Check if AI recommends your business.";
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#f7f6f3;
  --card:#ffffff;
  --border:#e8e8e3;
  --ink:#1a1a18;
  --muted:#6b6b63;
  --accent:#2f54eb;
  --danger:#de350b;
}

body{
  margin:0;
  font-family:'Geist',sans-serif;
  background:var(--bg);
  color:var(--ink);
}

/* NAV */
nav{
  position:sticky;
  top:0;
  background:rgba(247,246,243,0.8);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
  padding:12px 20px;
}

.logo{font-weight:700}

/* HERO */
.hero{
  max-width:720px;
  margin:70px auto 30px;
  text-align:center;
  padding:0 20px;
}

h1{
  font-family:'Instrument Serif',serif;
  font-size:clamp(34px,7vw,60px);
  line-height:1.1;
  margin:0;
}

.sub{
  color:var(--muted);
  margin-top:14px;
  font-size:17px;
}

/* MACHINE CARD */
.machine{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:16px;
  margin-top:24px;
}

/* INPUT */
.input-wrap{
  display:flex;
  gap:8px;
}

input{
  flex:1;
  border:1px solid var(--border);
  padding:14px;
  border-radius:10px;
  font-size:16px;
  outline:none;
}

button{
  background:var(--ink);
  color:white;
  border:none;
  padding:14px 18px;
  border-radius:10px;
  font-weight:600;
  cursor:pointer;
}

/* STATUS */
.status{
  font-size:12px;
  color:var(--muted);
  margin-top:10px;
}

/* SCAN */
#scan,#result{display:none;}

.bar-bg{
  height:3px;
  background:#eee;
  margin-top:10px;
}
.bar{
  height:100%;
  width:0%;
  background:var(--ink);
}

/* OUTPUT */
.output{
  margin-top:16px;
  padding:12px;
  border-radius:10px;
  background:#fafafa;
  border:1px solid var(--border);
  font-size:14px;
}

.danger{color:var(--danger);}

/* FAQ (CLICK DROPS) */
.faq{
  max-width:720px;
  margin:50px auto;
  padding:0 20px;
}

.faq-item{
  border-top:1px solid var(--border);
  padding:14px 0;
  cursor:pointer;
}

.faq-a{
  display:none;
  color:var(--muted);
  margin-top:8px;
  font-size:14px;
}

.faq-item.open .faq-a{display:block}

/* BLOG */
.blog{
  max-width:720px;
  margin:40px auto;
  padding:0 20px;
}

.blog-card{
  border:1px solid var(--border);
  padding:16px;
  border-radius:10px;
  margin-top:10px;
  background:white;
}

/* CTA */
.cta{
  max-width:720px;
  margin:50px auto;
  text-align:center;
}

.cta a{
  display:inline-block;
  margin:10px;
  padding:12px 18px;
  border-radius:8px;
  text-decoration:none;
}

.primary{background:var(--ink);color:white;}
.secondary{border:1px solid var(--border);color:var(--muted);}

/* FOOTER */
footer{
  text-align:center;
  font-size:12px;
  color:var(--muted);
  padding:40px 0;
}
</style>
</head>

<body>

<nav>
  <div class="logo">AI Visibility</div>
  <div>
    <a href="/blog" style="margin-right:10px;text-decoration:none;color:var(--muted)">Blog</a>
    <a href="https://discord.gg/YOUR" style="text-decoration:none;color:var(--muted)">Discord</a>
  </div>
</nav>

<div class="hero">
  <h1>Does AI recommend you?</h1>
  <p class="sub">Run a check. See what AI sees.</p>

  <div class="machine">

    <div id="inputBox" class="input-wrap">
      <input id="url" placeholder="yourwebsite.com">
      <button onclick="run()">Run</button>
    </div>

    <div class="status">System ready • Awaiting input</div>

    <div id="scan">
      <div class="status">Scanning AI signals...</div>
      <div class="bar-bg"><div id="bar" class="bar"></div></div>
    </div>

    <div id="result" class="output">
      <div><strong>Score:</strong> <span id="score"></span>/10</div>
      <div class="danger">Not recommended in AI answers</div>
    </div>

  </div>
</div>

<!-- FAQ -->
<div class="faq">
  <div class="faq-item">
    <strong>Why am I not showing in AI?</strong>
    <div class="faq-a">Your business lacks structured signals AI can verify.</div>
  </div>

  <div class="faq-item">
    <strong>What improves visibility?</strong>
    <div class="faq-a">Schema + entity authority + citation consistency.</div>
  </div>

  <div class="faq-item">
    <strong>How fast does it change?</strong>
    <div class="faq-a">Usually within 2–4 weeks after fixes.</div>
  </div>
</div>

<!-- BLOG -->
<div class="blog">
  <h3>Research</h3>

  <div class="blog-card">
    <a href="/blog/how-ai-decides" style="text-decoration:none;color:var(--ink)">
      How AI decides which business to recommend →
    </a>
  </div>

  <div class="blog-card">
    <a href="/blog/geo-vs-seo" style="text-decoration:none;color:var(--ink)">
      GEO vs SEO — what changed →
    </a>
  </div>
</div>

<!-- CTA -->
<div class="cta">
  <a href="https://discord.gg/YOUR" class="secondary">Join Discord</a>
  <a href="https://whop.com/progpt" class="primary">Get Access</a>
</div>

<footer>
© {year}
</footer>

<script is:inline>
function run(){
  let url=document.getElementById("url").value;
  if(!url) return;

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";

  let w=0;
  let int=setInterval(()=>{
    w+=4;
    document.getElementById("bar").style.width=w+"%";

    if(w>=100){
      clearInterval(int);
      show();
    }
  },40);
}

function show(){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(2+Math.random()*2).toFixed(1);
  document.getElementById("score").innerText=score;
}

/* FAQ toggle */
document.querySelectorAll(".faq-item").forEach(el=>{
  el.onclick=()=>el.classList.toggle("open");
});
</script>

</body>
</html>