<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>ProGPT — AI Visibility</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet"/>

<style>
:root{
  --bg:#050505;
  --card:#0f0f0f;
  --border:#1a1a1a;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --accent:#00ff88;
}

body{
  font-family:Inter,sans-serif;
  background:var(--bg);
  color:var(--text);
  margin:0;
}

/* NAVBAR */
.nav{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:14px 20px;
  border-bottom:1px solid var(--border);
  background:#000;
}

.logo{
  font-weight:700;
}

.nav-links{
  display:flex;
  gap:16px;
  align-items:center;
}

.nav-links a{
  color:#ccc;
  text-decoration:none;
  font-size:14px;
}

/* DROPDOWN */
.dropdown{
  position:relative;
}

.dropdown-content{
  display:none;
  position:absolute;
  right:0;
  top:30px;
  background:#111;
  border:1px solid var(--border);
  border-radius:10px;
  min-width:180px;
  overflow:hidden;
}

.dropdown-content a{
  display:block;
  padding:12px;
  color:#ccc;
}

.dropdown-content a:hover{
  background:#1a1a1a;
}

.dropdown:hover .dropdown-content{
  display:block;
}

/* CONTAINER */
.container{
  max-width:720px;
  margin:auto;
  padding:24px;
}

/* HERO */
h1{
  font-size:38px;
  line-height:1.1;
}

p{
  color:var(--muted);
  margin-top:8px;
}

/* CARD */
.card{
  background:linear-gradient(180deg,#0d1117,#050505);
  border:1px solid rgba(0,255,136,0.15);
  padding:20px;
  border-radius:14px;
  margin-top:20px;
}

/* INPUT */
input{
  width:100%;
  padding:14px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#0b0b0b;
  color:white;
  margin-top:10px;
}

/* BUTTON */
button{
  margin-top:14px;
  width:100%;
  padding:14px;
  border-radius:10px;
  border:none;
  background:var(--accent);
  color:black;
  font-weight:600;
  cursor:pointer;
}

/* SCAN */
.scan{ display:none; margin-top:20px; }

.loader{
  height:6px;
  background:#111;
  border-radius:6px;
  overflow:hidden;
  margin-top:10px;
}

.loader span{
  display:block;
  height:100%;
  width:0%;
  background:var(--accent);
  animation:scan 2.5s linear forwards;
}

@keyframes scan{
  0%{width:0%}
  100%{width:100%}
}
</style>
</head>

<body>

<!-- NAVBAR -->
<div class="nav">
  <div class="logo">PROGPT</div>

  <div class="nav-links">
    <a href="/">Home</a>
    <a href="/blog">Blog</a>

    <div class="dropdown">
      <a href="#">Get Access ▾</a>
      <div class="dropdown-content">
        <a href="https://whop.com/progpt">Buy on Whop</a>
        <a href="https://discord.gg/YOUR">Join Discord</a>
        <a href="https://gumroad.com">Buy on Gumroad</a>
      </div>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="container">

<h1>AI is already ranking your competitors.</h1>
<p>If you're not in AI answers, you're invisible.</p>

<!-- INPUT -->
<div id="step1" class="card">
<input id="website" placeholder="yourwebsite.com">
<button onclick="startScan()">Run free audit →</button>
</div>

<!-- SCAN -->
<div id="scan" class="scan">
<p id="scanText">Scanning your site…</p>
<div class="loader"><span></span></div>
</div>

<!-- RESULT -->
<div id="result" style="display:none;margin-top:20px">

<div class="card">
<h2 id="scoreText">Score: 3.1 / 10</h2>

<p>AI is not recommending your business.</p>

<input id="email" placeholder="Enter email to unlock audit">
<button onclick="saveLead()">Unlock full audit →</button>

</div>

</div>

<!-- VALUE -->
<div class="card">
<h3>What happens next</h3>
<p>
• Full audit breakdown<br>
• GEO + SEO fixes<br>
• AI content strategy<br>
• Done-for-you execution
</p>
</div>

</div>

<script>
function startScan(){
  document.getElementById("step1").style.display="none";
  document.getElementById("scan").style.display="block";

  let texts=[
    "Scanning website…",
    "Analyzing AI signals…",
    "Checking competitors…",
    "Evaluating ranking gaps…"
  ];

  let i=0;
  let interval=setInterval(()=>{
    document.getElementById("scanText").innerText=texts[i];
    i++;
    if(i>=texts.length) clearInterval(interval);
  },600);

  setTimeout(showResult,2600);
}

function showResult(){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(Math.random()*3+2).toFixed(1);
  document.getElementById("scoreText").innerText="Score: "+score+" / 10";
}

function saveLead(){
  localStorage.setItem("email",document.getElementById("email").value);
}
</script>

</body>
</html>