---
const year = new Date().getFullYear();
---

<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Visibility Audit</title>

<style>
:root{
--bg:#f7f6f3;
--card:#fff;
--border:#e8e8e3;
--ink:#1a1a18;
--muted:#5a5a52;
--danger:#de350b;
}

body{
margin:0;
font-family:sans-serif;
background:var(--bg);
color:var(--ink);
}

/* HERO */
.hero{
max-width:700px;
margin:80px auto;
text-align:center;
padding:0 20px;
}

h1{
font-size:40px;
margin:0;
}

.sub{
color:var(--muted);
margin-top:10px;
}

/* MACHINE */
.machine{
background:var(--card);
border:1px solid var(--border);
border-radius:16px;
padding:20px;
margin-top:25px;
}

.input{
display:flex;
gap:8px;
}

input{
flex:1;
padding:14px;
border-radius:10px;
border:1px solid var(--border);
}

button{
padding:14px;
background:var(--ink);
color:white;
border:none;
border-radius:10px;
cursor:pointer;
}

/* STATUS */
.status{
font-size:12px;
color:var(--muted);
margin-top:8px;
font-family:monospace;
}

/* SCAN */
#scan,#report{display:none;}

.log{
font-size:12px;
margin-top:10px;
color:var(--muted);
font-family:monospace;
}

/* REPORT */
.report{
margin-top:20px;
padding:16px;
border:1px solid var(--border);
border-radius:12px;
background:#fafafa;
}

.score{
font-size:28px;
font-weight:700;
}

.bad{color:var(--danger)}

.row{
display:flex;
justify-content:space-between;
margin-top:6px;
font-size:14px;
}

.cta{
margin-top:20px;
text-align:center;
}

.cta a{
background:var(--ink);
color:white;
padding:12px 18px;
border-radius:8px;
text-decoration:none;
}
</style>
</head>

<body>

<div class="hero">

<h1>AI is already ranking your competitors.</h1>
<p class="sub">Check if your business exists in AI answers.</p>

<div class="machine">

<div id="inputBox" class="input">
<input id="url" placeholder="yourwebsite.com">
<button onclick="run()">Analyze</button>
</div>

<div class="status">AI index active • scanning queries</div>

<div id="scan">
<div class="log" id="log"></div>
</div>

<div id="report" class="report">

<div class="score" id="score"></div>
<div class="bad">Not recommended in AI answers</div>

<div class="row"><span>Entity Recognition</span><span>❌</span></div>
<div class="row"><span>Schema Graph</span><span>❌</span></div>
<div class="row"><span>AI Citations</span><span>❌</span></div>
<div class="row"><span>Authority</span><span>⚠️</span></div>

<div style="margin-top:10px;font-size:13px;">
AI is recommending:
<ul id="competitors"></ul>
</div>

<div class="cta">
<a href="https://whop.com/progpt">Unlock Fix Plan →</a>
</div>

</div>

</div>
</div>

<script>
function run(){
let url=document.getElementById("url").value;
if(!url) return;

document.getElementById("inputBox").style.display="none";
document.getElementById("scan").style.display="block";

let steps=[
"parsing domain...",
"mapping entity graph...",
"checking schema...",
"analyzing citations...",
"ranking competitors..."
];

let i=0;
let log=document.getElementById("log");

let int=setInterval(()=>{
log.innerHTML+=steps[i]+"<br>";
i++;

if(i>=steps.length){
clearInterval(int);
show(url);
}
},600);
}

function show(url){
document.getElementById("scan").style.display="none";
document.getElementById("report").style.display="block";

let score=(1+Math.random()*2).toFixed(1);
document.getElementById("score").innerText=score+"/10";

let base=url.split('.')[0];
let list=document.getElementById("competitors");

["best","top","pro"].forEach(p=>{
let li=document.createElement("li");
li.innerText=p+"-"+base+".com";
list.appendChild(li);
});
}
</script>

</body>
</html>