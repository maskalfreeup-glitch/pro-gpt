<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ProGPT — AI Visibility Engine</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#04060a;
  --surface:#080c12;
  --surface2:#0d1219;
  --border:#151c27;
  --border2:#1e2836;
  --accent:#00e5ff;
  --accent2:#7b61ff;
  --green:#00ff9f;
  --red:#ff3b3b;
  --amber:#ffaa00;
  --text:#dde4ee;
  --muted:#556070;
  --faint:#2a3444;
  --mono:'DM Mono',monospace;
  --sans:'DM Sans',sans-serif;
  --display:'Syne',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:var(--sans);
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
}
body::after{
  content:"";position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;z-index:9999;opacity:.35;
}
body::before{
  content:"";position:fixed;inset:0;
  background:
    linear-gradient(rgba(0,229,255,0.022) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,229,255,0.022) 1px,transparent 1px);
  background-size:60px 60px;z-index:0;pointer-events:none;
}

/* CURSOR */
#cursor{
  position:fixed;width:7px;height:7px;
  background:var(--accent);border-radius:50%;
  pointer-events:none;z-index:10000;
  transform:translate(-50%,-50%);
  transition:transform .12s,opacity .12s;
  mix-blend-mode:screen;
  box-shadow:0 0 10px var(--accent);
}

/* NAV */
nav{
  position:sticky;top:0;z-index:1000;
  display:flex;justify-content:space-between;align-items:center;
  padding:0 32px;height:56px;
  background:rgba(4,6,10,0.88);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.logo{
  font-family:var(--display);font-weight:800;font-size:17px;
  letter-spacing:-.5px;color:#fff;
  display:flex;align-items:center;gap:8px;
}
.logo-dot{
  width:7px;height:7px;border-radius:50%;
  background:var(--accent);box-shadow:0 0 8px var(--accent);
  animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}
.nav-links{display:flex;align-items:center;gap:24px;list-style:none}
.nav-links a{
  color:var(--muted);text-decoration:none;
  font-family:var(--mono);font-size:11.5px;letter-spacing:.5px;
  transition:color .2s;
}
.nav-links a:hover{color:var(--text)}
.nav-cta{
  background:var(--accent) !important;color:#000 !important;
  padding:7px 16px;border-radius:6px;
  font-weight:600 !important;font-family:var(--display) !important;
  font-size:12px !important;letter-spacing:.3px;
}

/* LAYOUT */
.wrap{max-width:960px;margin:auto;padding:0 24px;position:relative;z-index:1;}
.section-label{
  font-family:var(--mono);font-size:10.5px;color:var(--accent);
  letter-spacing:2.5px;text-transform:uppercase;margin-bottom:16px;
  display:flex;align-items:center;gap:8px;
}
.section-label::before{content:"";width:20px;height:1px;background:var(--accent);}

/* HERO */
#hero{padding:96px 0 80px;border-bottom:1px solid var(--border);}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(0,229,255,0.06);border:1px solid rgba(0,229,255,0.15);
  padding:6px 14px;border-radius:4px;
  font-family:var(--mono);font-size:10.5px;color:var(--accent);
  letter-spacing:2px;margin-bottom:32px;
}
.blink{animation:blink .8s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
h1{
  font-family:var(--display);font-size:clamp(48px,7.5vw,88px);
  font-weight:800;line-height:.9;letter-spacing:-4px;color:#fff;max-width:820px;
}
h1 em{font-style:normal;color:var(--accent);text-shadow:0 0 60px rgba(0,229,255,.25)}
h1 s{text-decoration:line-through;color:var(--muted);text-decoration-color:var(--red)}
.hero-sub{
  margin-top:24px;color:var(--muted);font-size:17px;
  max-width:460px;line-height:1.7;font-weight:300;
}
.hero-actions{margin-top:40px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}

/* BUTTONS */
.btn-primary{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--accent);color:#000;padding:13px 24px;border-radius:8px;
  font-family:var(--display);font-weight:700;font-size:14px;
  border:none;cursor:pointer;text-decoration:none;
  transition:all .2s;letter-spacing:-.2px;position:relative;overflow:hidden;
}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 8px 30px rgba(0,229,255,.3)}
.btn-ghost{
  display:inline-flex;align-items:center;gap:8px;
  background:transparent;color:var(--text);padding:13px 24px;border-radius:8px;
  font-family:var(--display);font-weight:600;font-size:14px;
  border:1px solid var(--border2);cursor:pointer;text-decoration:none;
  transition:all .2s;
}
.btn-ghost:hover{border-color:var(--muted);color:#fff}
.btn-discord{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(88,101,242,.13);color:#7b8dff;padding:13px 24px;border-radius:8px;
  font-family:var(--display);font-weight:600;font-size:14px;
  border:1px solid rgba(88,101,242,.22);cursor:pointer;text-decoration:none;
  transition:all .2s;
}
.btn-discord:hover{background:rgba(88,101,242,.22);border-color:rgba(88,101,242,.45)}
.hero-note{color:var(--muted);font-family:var(--mono);font-size:11px;display:flex;align-items:center;gap:6px}

/* STATS */
#stats{border-bottom:1px solid var(--border)}
.stats-inner{display:grid;grid-template-columns:repeat(4,1fr);max-width:960px;margin:auto}
.stat{padding:28px 24px;border-right:1px solid var(--border)}
.stat:last-child{border-right:none}
.stat-num{font-family:var(--display);font-size:34px;font-weight:800;color:#fff;letter-spacing:-2px}
.stat-num span{color:var(--accent)}
.stat-label{font-size:12px;color:var(--muted);margin-top:4px;font-family:var(--mono)}

/* ═══════════════════════════════════════════════════
   AI AUDIT SECTION — THE CENTREPIECE
════════════════════════════════════════════════════ */
#audit{padding:80px 0;border-bottom:1px solid var(--border)}
.audit-layout{display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start}
.audit-left h2{
  font-family:var(--display);font-size:clamp(28px,4vw,46px);
  font-weight:800;letter-spacing:-2px;color:#fff;line-height:.92;
}
.audit-left p{color:var(--muted);font-size:15px;line-height:1.7;margin-top:16px;max-width:360px}
.audit-perks{margin-top:24px;display:flex;flex-direction:column;gap:10px}
.perk{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--muted)}
.perk-icon{color:var(--green);font-family:var(--mono);flex-shrink:0;margin-top:1px}
.powered-by{
  margin-top:28px;display:flex;align-items:center;gap:10px;
  font-family:var(--mono);font-size:10.5px;color:var(--muted);letter-spacing:.5px;
}
.cf-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(249,130,53,.1);border:1px solid rgba(249,130,53,.2);
  padding:5px 10px;border-radius:5px;color:#f98235;font-size:10px;letter-spacing:1px;
}

/* THE AUDIT WIDGET */
.audit-widget{
  background:var(--surface);border:1px solid var(--border);
  border-radius:18px;position:relative;overflow:hidden;
}
.audit-widget::before{
  content:"";position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:.5;
}

/* STATE: INPUT */
#aw-input{padding:28px}
.aw-label{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:20px}
.url-field{
  display:flex;align-items:center;gap:0;
  background:#000;border:1px solid var(--border);border-radius:10px;overflow:hidden;
  transition:border-color .2s;
}
.url-field:focus-within{border-color:rgba(0,229,255,.4)}
.url-prefix{
  padding:0 14px;font-family:var(--mono);font-size:12px;
  color:var(--muted);white-space:nowrap;border-right:1px solid var(--border);height:48px;
  display:flex;align-items:center;
}
.url-field input{
  flex:1;background:transparent;border:none;
  padding:14px 14px;color:#fff;font-family:var(--mono);font-size:13px;outline:none;
}
.url-field input::placeholder{color:var(--muted)}
.scan-btn{
  width:100%;margin-top:14px;padding:15px;border:none;border-radius:10px;
  background:var(--accent);color:#000;font-family:var(--display);
  font-weight:700;font-size:14px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:all .2s;
}
.scan-btn:hover{opacity:.9;transform:translateY(-1px)}
.scan-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.scan-btn svg{transition:transform .3s}
.scan-btn:not(:disabled):hover svg{transform:translateX(3px)}
.widget-footer{
  margin-top:12px;font-family:var(--mono);font-size:10px;
  color:var(--muted);text-align:center;letter-spacing:.5px;
}

/* STATE: SCANNING */
#aw-scan{display:none;padding:28px}
.scan-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.scan-title{font-family:var(--display);font-weight:700;font-size:15px;color:#fff}
.scan-pill{
  font-family:var(--mono);font-size:10px;color:var(--accent);
  background:rgba(0,229,255,.08);border:1px solid rgba(0,229,255,.15);
  padding:4px 10px;border-radius:20px;
}
.terminal{
  background:#000;border:1px solid var(--border);border-radius:10px;
  padding:16px;min-height:140px;font-family:var(--mono);font-size:11.5px;
  overflow-y:auto;max-height:200px;
}
.t-line{padding:2.5px 0;display:flex;gap:8px;animation:tFade .25s ease}
@keyframes tFade{from{opacity:0;transform:translateY(3px)}to{opacity:1;transform:none}}
.t-ts{color:var(--muted);flex-shrink:0}
.t-msg{color:var(--accent)}
.t-msg.dim{color:var(--muted)}
.t-msg.ok{color:var(--green)}
.t-msg.warn{color:var(--amber)}
.t-msg.err{color:var(--red)}
.progress-bar{height:3px;background:var(--border);border-radius:10px;overflow:hidden;margin-top:16px}
#prog-fill{
  height:100%;width:0%;
  background:linear-gradient(90deg,var(--accent2),var(--accent));
  box-shadow:0 0 8px var(--accent);transition:width .15s linear;
}
.scan-meta{display:flex;justify-content:space-between;margin-top:8px}
.scan-meta span{font-family:var(--mono);font-size:10px;color:var(--muted)}

/* STATE: RESULT */
#aw-result{display:none}
.result-header{
  padding:24px 28px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;gap:16px;
}
.score-block{display:flex;align-items:baseline;gap:6px}
.score-num{
  font-family:var(--display);font-size:56px;font-weight:800;
  letter-spacing:-4px;line-height:1;
}
.score-denom{font-family:var(--mono);font-size:16px;color:var(--muted)}
.score-tag{
  font-family:var(--mono);font-size:10px;letter-spacing:1.5px;
  padding:4px 10px;border-radius:5px;align-self:center;
}
.score-tag.critical{background:rgba(255,59,59,.1);color:var(--red);border:1px solid rgba(255,59,59,.2)}
.score-tag.low{background:rgba(255,170,0,.1);color:var(--amber);border:1px solid rgba(255,170,0,.2)}
.score-tag.mid{background:rgba(0,229,255,.08);color:var(--accent);border:1px solid rgba(0,229,255,.15)}
.result-domain{
  font-family:var(--mono);font-size:11px;color:var(--muted);text-align:right;
}
.result-domain strong{display:block;color:#fff;font-size:14px;margin-bottom:3px}

/* AI REPORT STREAM */
.report-stream{
  padding:24px 28px;
  border-bottom:1px solid var(--border);
  font-family:var(--mono);font-size:12px;
  color:var(--muted);line-height:1.8;
  max-height:320px;overflow-y:auto;
}
.report-stream::-webkit-scrollbar{width:3px}
.report-stream::-webkit-scrollbar-track{background:transparent}
.report-stream::-webkit-scrollbar-thumb{background:var(--border2);border-radius:10px}

/* report markdown-ish */
.rpt-h{color:#fff;font-weight:500;margin:14px 0 6px;font-size:11.5px;letter-spacing:1px}
.rpt-h:first-child{margin-top:0}
.rpt-bullet{display:flex;gap:8px;padding:2px 0}
.rpt-bullet::before{content:"→";color:var(--accent);flex-shrink:0}
.rpt-line{padding:1.5px 0}
.rpt-warn{color:var(--amber)}
.rpt-ok{color:var(--green)}
.rpt-bad{color:var(--red)}
.rpt-neutral{color:var(--muted)}
.typing-cursor{
  display:inline-block;width:7px;height:12px;
  background:var(--accent);border-radius:1px;
  animation:blink .6s step-end infinite;vertical-align:middle;margin-left:3px;
}

/* METRIC GRID */
.metrics{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:var(--border);border-bottom:1px solid var(--border);
}
.metric{background:var(--surface);padding:16px 20px}
.metric-key{font-family:var(--mono);font-size:9.5px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px}
.metric-val{font-family:var(--display);font-size:20px;font-weight:700;letter-spacing:-.5px}
.metric-val.bad{color:var(--red)}
.metric-val.warn{color:var(--amber)}
.metric-val.ok{color:var(--green)}

/* RESULT CTA */
.result-cta-block{padding:24px 28px}
.result-cta-block p{font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.6}
.cta-row{display:flex;gap:10px}
.cta-primary{
  flex:1;background:var(--accent);color:#000;border:none;
  border-radius:8px;padding:13px;font-family:var(--display);
  font-weight:700;font-size:13px;cursor:pointer;
  text-decoration:none;text-align:center;display:block;transition:all .2s;
}
.cta-primary:hover{opacity:.9}
.cta-secondary{
  flex:1;background:transparent;color:var(--muted);border:1px solid var(--border2);
  border-radius:8px;padding:13px;font-family:var(--mono);
  font-size:11px;cursor:pointer;text-decoration:none;
  text-align:center;display:block;transition:all .2s;letter-spacing:.3px;
}
.cta-secondary:hover{border-color:var(--muted);color:var(--text)}
.rescan{
  width:100%;margin-top:10px;background:transparent;border:none;
  font-family:var(--mono);font-size:10px;color:var(--muted);
  cursor:pointer;letter-spacing:1px;transition:color .2s;
}
.rescan:hover{color:var(--text)}

/* HOW */
#how{padding:80px 0;border-bottom:1px solid var(--border)}
#how h2{
  font-family:var(--display);font-size:clamp(28px,4vw,46px);
  font-weight:800;letter-spacing:-2px;color:#fff;
  max-width:480px;line-height:.92;margin-bottom:48px;
}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden}
.step{background:var(--surface);padding:32px 28px}
.step-num{font-family:var(--mono);font-size:10px;color:var(--accent);letter-spacing:2px;margin-bottom:20px}
.step-icon{font-size:22px;margin-bottom:14px}
.step h3{font-family:var(--display);font-size:17px;font-weight:700;color:#fff;margin-bottom:8px;letter-spacing:-.5px}
.step p{font-size:13px;color:var(--muted);line-height:1.65}

/* PRICING */
#pricing{padding:80px 0;border-bottom:1px solid var(--border)}
#pricing h2{font-family:var(--display);font-size:clamp(28px,4vw,46px);font-weight:800;letter-spacing:-2px;color:#fff;margin-bottom:8px;line-height:.92}
.sub-head{color:var(--muted);font-size:14px;margin-bottom:40px}
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.price-card{
  background:var(--surface);border:1px solid var(--border);border-radius:16px;
  padding:28px;position:relative;transition:border-color .2s;
}
.price-card.featured{
  border-color:rgba(0,229,255,.28);
  background:linear-gradient(160deg,rgba(0,229,255,.045),var(--surface));
}
.price-card.featured::before{
  content:"";position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
}
.platform-badge{
  font-family:var(--mono);font-size:10px;color:var(--muted);
  letter-spacing:2px;text-transform:uppercase;margin-bottom:16px;
  display:flex;align-items:center;gap:6px;
}
.price-name{font-family:var(--display);font-size:20px;font-weight:700;color:#fff;letter-spacing:-.5px;margin-bottom:8px}
.price-amount{font-family:var(--display);font-size:40px;font-weight:800;color:#fff;letter-spacing:-2px;line-height:1;margin-bottom:4px}
.price-amount span{font-size:16px;color:var(--muted);font-weight:400;letter-spacing:0}
.price-desc{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6}
.price-features{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:24px}
.price-features li{display:flex;gap:8px;font-size:13px;color:var(--muted)}
.price-features li::before{content:"→";color:var(--accent);font-family:var(--mono);flex-shrink:0}
.price-btn{
  width:100%;padding:12px;border-radius:8px;
  font-family:var(--display);font-weight:700;font-size:13px;
  cursor:pointer;text-decoration:none;text-align:center;display:block;transition:all .2s;
}
.price-btn.primary{background:var(--accent);color:#000;border:none}
.price-btn.primary:hover{opacity:.9}
.price-btn.outline{background:transparent;color:var(--text);border:1px solid var(--border2)}
.price-btn.outline:hover{border-color:var(--muted)}
.popular-tag{
  position:absolute;top:14px;right:14px;
  background:var(--accent);color:#000;
  font-family:var(--mono);font-size:9px;letter-spacing:1.5px;
  text-transform:uppercase;padding:3px 8px;border-radius:4px;
}

/* DEEP AUDIT FORM */
#free-audit{padding:80px 0;border-bottom:1px solid var(--border)}
.audit-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start}
.form-side h2{font-family:var(--display);font-size:clamp(26px,3.5vw,42px);font-weight:800;letter-spacing:-2px;color:#fff;line-height:.92;margin-bottom:12px}
.form-side p{color:var(--muted);font-size:14px;line-height:1.7;margin-bottom:24px}
.form-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:28px;position:relative}
.form-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent2),transparent);opacity:.6;
}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-grid .full{grid-column:1/-1}
label{display:block;font-family:var(--mono);font-size:9.5px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px}
input[type=text],input[type=email],input[type=url],select,textarea{
  width:100%;background:#000;border:1px solid var(--border);border-radius:8px;
  padding:11px 14px;color:#fff;font-family:var(--mono);font-size:12px;outline:none;transition:border-color .2s;
}
select{appearance:none;cursor:pointer}
textarea{min-height:78px;resize:vertical}
input:focus,select:focus,textarea:focus{border-color:rgba(0,229,255,.4)}
.form-submit{
  width:100%;background:var(--accent2);color:#fff;border:none;
  border-radius:8px;padding:14px;font-family:var(--display);font-weight:700;
  font-size:14px;cursor:pointer;margin-top:4px;transition:all .2s;
}
.form-submit:hover{opacity:.9;transform:translateY(-1px)}
.form-submit:disabled{opacity:.5;cursor:not-allowed;transform:none}
.form-footer-note{font-family:var(--mono);font-size:10px;color:var(--muted);text-align:center;margin-top:12px;letter-spacing:.5px}
.info-cards{display:flex;flex-direction:column;gap:12px}
.info-card{display:flex;align-items:flex-start;gap:14px;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:16px}
.info-card-icon{font-size:20px;flex-shrink:0}
.info-card-title{font-family:var(--display);font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.info-card-desc{font-size:12px;color:var(--muted);line-height:1.6}

/* DISCORD */
#discord{padding:80px 0;border-bottom:1px solid var(--border)}
.discord-box{
  background:linear-gradient(135deg,rgba(88,101,242,.12),rgba(88,101,242,.04));
  border:1px solid rgba(88,101,242,.2);border-radius:20px;padding:48px;
  display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center;
  position:relative;overflow:hidden;
}
.discord-box::before{
  content:"";position:absolute;top:-80px;right:-80px;
  width:240px;height:240px;
  background:radial-gradient(circle,rgba(88,101,242,.12),transparent);
  pointer-events:none;
}
.discord-box h2{font-family:var(--display);font-size:clamp(24px,3vw,38px);font-weight:800;letter-spacing:-1.5px;color:#fff;line-height:.92;margin-bottom:12px}
.discord-box p{font-size:15px;color:var(--muted);line-height:1.65;max-width:440px}
.discord-meta{display:flex;gap:24px;margin-top:16px}
.discord-stat{font-family:var(--mono);font-size:11px;color:var(--muted)}
.discord-stat strong{display:block;font-size:20px;color:#fff;font-family:var(--display);font-weight:800;letter-spacing:-1px}
.dc-previews{display:flex;flex-direction:column;gap:10px;min-width:200px}
.dc-msg{
  background:rgba(88,101,242,.1);border:1px solid rgba(88,101,242,.15);
  border-radius:10px;padding:12px 14px;
  font-family:var(--mono);font-size:10.5px;color:#7b8dff;
}
.dc-channel{color:var(--muted);margin-bottom:5px;font-size:10px}

/* BLOG */
#blog{padding:80px 0;border-bottom:1px solid var(--border)}
#blog h2{font-family:var(--display);font-size:clamp(28px,4vw,46px);font-weight:800;letter-spacing:-2px;color:#fff;margin-bottom:32px;line-height:.92}
.blog-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:16px}
.blog-card{
  background:var(--surface);border:1px solid var(--border);border-radius:14px;
  padding:24px;text-decoration:none;
  display:flex;flex-direction:column;justify-content:space-between;
  transition:all .22s;position:relative;overflow:hidden;
}
.blog-card:hover{border-color:var(--border2);transform:translateY(-2px)}
.blog-card.featured{background:linear-gradient(160deg,rgba(0,229,255,.04),var(--surface))}
.blog-cat{font-family:var(--mono);font-size:9.5px;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px}
.blog-title{font-family:var(--display);font-size:18px;font-weight:700;color:#fff;letter-spacing:-.5px;line-height:1.2;margin-bottom:12px}
.blog-card:not(.featured) .blog-title{font-size:14px}
.blog-excerpt{font-size:13px;color:var(--muted);line-height:1.65;margin-bottom:20px}
.blog-meta{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:9.5px;color:var(--muted)}
.blog-dot{width:3px;height:3px;border-radius:50%;background:var(--muted)}

/* PROOF */
#proof{padding:80px 0;border-bottom:1px solid var(--border)}
#proof h2{font-family:var(--display);font-size:clamp(26px,3.5vw,42px);font-weight:800;letter-spacing:-2px;color:#fff;margin-bottom:32px;line-height:.92}
.testimonials{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.testi{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px}
.testi-quote{font-size:14px;color:var(--text);line-height:1.7;margin-bottom:20px}
.testi-author{display:flex;align-items:center;gap:10px}
.testi-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:var(--display);font-size:11px;font-weight:700;color:#000}
.testi-name{font-family:var(--display);font-size:13px;font-weight:700;color:#fff}
.testi-role{font-family:var(--mono);font-size:10px;color:var(--muted)}

/* FAQ */
#faq{padding:80px 0;border-bottom:1px solid var(--border)}
#faq h2{font-family:var(--display);font-size:clamp(26px,3.5vw,42px);font-weight:800;letter-spacing:-2px;color:#fff;margin-bottom:32px;line-height:.92}
.faq-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 40px}
.faq-item{border-top:1px solid var(--border);padding:16px 0;cursor:pointer}
.faq-q{display:flex;justify-content:space-between;align-items:center;font-family:var(--display);font-size:14px;font-weight:600;color:#fff;gap:16px}
.faq-arrow{color:var(--muted);font-family:var(--mono);font-size:16px;transition:transform .2s;flex-shrink:0}
.faq-item.open .faq-arrow{transform:rotate(45deg);color:var(--accent)}
.faq-a{display:none;margin-top:10px;font-size:13px;color:var(--muted);line-height:1.7}
.faq-item.open .faq-a{display:block}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:40px 0}
.footer-inner{display:flex;justify-content:space-between;align-items:center}
.footer-logo{font-family:var(--display);font-weight:800;font-size:16px;color:#fff;display:flex;align-items:center;gap:6px}
.footer-links{display:flex;gap:24px}
.footer-links a{font-family:var(--mono);font-size:11px;color:var(--muted);text-decoration:none;letter-spacing:.5px;transition:color .2s}
.footer-links a:hover{color:var(--text)}
.footer-copy{font-family:var(--mono);font-size:11px;color:var(--faint)}

/* TOAST */
#toast{
  position:fixed;bottom:24px;right:24px;
  background:var(--surface);border:1px solid rgba(0,255,159,.2);
  border-radius:10px;padding:14px 18px;
  font-family:var(--mono);font-size:12px;color:var(--green);
  z-index:9998;display:none;align-items:center;gap:8px;
  box-shadow:0 8px 32px rgba(0,0,0,.5);
}
#toast.show{display:flex;animation:slideIn .3s ease}
@keyframes slideIn{from{transform:translateY(16px);opacity:0}to{transform:none;opacity:1}}

/* MOBILE */
@media(max-width:768px){
  nav{padding:0 16px}
  .nav-links{display:none}
  .wrap{padding:0 16px}
  h1{letter-spacing:-2px}
  .audit-layout,.audit-form-grid,.faq-grid,
