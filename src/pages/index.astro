<!-- ══════════════════════════════════════════════════
     AI AUDIT ENGINE — Calls Anthropic API (Claude)
     Swap endpoint for your Cloudflare AI Worker URL
════════════════════════════════════════════════════ -->
<script>
/* ─ CURSOR ─────────────────────────────────── */
const cur = document.getElementById('cursor');
document.addEventListener('mousemove', e => {
  cur.style.left = e.clientX + 'px';
  cur.style.top  = e.clientY + 'px';
});
document.querySelectorAll('a,button,[onclick]').forEach(el => {
  el.addEventListener('mouseenter', () => { cur.style.transform='translate(-50%,-50%) scale(2.5)'; cur.style.opacity='.4'; });
  el.addEventListener('mouseleave', () => { cur.style.transform='translate(-50%,-50%) scale(1)';   cur.style.opacity='1'; });
});

/* ─ FAQ ─────────────────────────────────────── */
function toggleFaq(el){ el.classList.toggle('open'); }

/* ─ FORM ────────────────────────────────────── */
function submitForm(btn){
  btn.textContent = 'Submitting…'; btn.disabled = true;
  setTimeout(() => {
    btn.textContent = '✓ Submitted — check your inbox';
    const t = document.getElementById('toast');
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 4500);
  }, 1100);
}

/* ═══════════════════════════════════════════════════
   AI AUDIT ENGINE
═══════════════════════════════════════════════════ */

const STATES = {
  INPUT:  document.getElementById('aw-input'),
  SCAN:   document.getElementById('aw-scan'),
  RESULT: document.getElementById('aw-result'),
};

function showState(name){
  Object.entries(STATES).forEach(([k,el]) => el.style.display = k===name ? 'block':'none');
}

function resetAudit(){
  document.getElementById('audit-domain').value = '';
  document.getElementById('terminal').innerHTML = '';
  document.getElementById('prog-fill').style.width = '0%';
  document.getElementById('report-stream').innerHTML = '<span class="typing-cursor"></span>';
  showState('INPUT');
}

/* Terminal printer */
let elapsed = 0, elapsedTimer = null;

function termLog(msg, cls=''){
  const t = document.getElementById('terminal');
  const ts = new Date().toISOString().substr(14,5);
  const line = document.createElement('div');
  line.className = 't-line';
  line.innerHTML = `<span class="t-ts">${ts}</span><span class="t-msg ${cls}">${msg}</span>`;
  t.appendChild(line);
  t.scrollTop = t.scrollHeight;
}

function setProgress(pct, label){
  document.getElementById('prog-fill').style.width = pct + '%';
  document.getElementById('scan-pct').textContent = Math.round(pct) + '%';
  if(label) document.getElementById('scan-step').textContent = label;
}

/* Derive quick metrics from score */
function scoreToMeta(score){
  const s = parseFloat(score);
  const tag = s < 3 ? 'CRITICAL' : s < 5 ? 'LOW' : s < 7 ? 'MODERATE' : 'GOOD';
  const color = s < 3 ? 'var(--red)' : s < 5 ? 'var(--red)' : s < 7 ? 'var(--amber)' : 'var(--green)';
  const tagClass = s < 5 ? 'critical' : s < 7 ? 'low' : 'mid';
  const leads = s < 3 ? `${Math.floor(18+Math.random()*12)}–${Math.floor(30+Math.random()*10)} leads`
              : s < 5 ? `${Math.floor(10+Math.random()*8)}–${Math.floor(18+Math.random()*7)} leads`
              : `${Math.floor(3+Math.random()*6)}–${Math.floor(9+Math.random()*5)} leads`;
  const comp = s < 3 ? `${Math.floor(4+Math.random()*4)} domains`
             : s < 5 ? `${Math.floor(2+Math.random()*3)} domains`
             : `${Math.floor(1+Math.random()*2)} domains`;
  const schema = s < 4 ? {val:'Missing', cls:'bad'} : s < 6 ? {val:'Partial', cls:'warn'} : {val:'Present', cls:'ok'};
  return { tag, color, tagClass, leads, comp, schema };
}

/* Render the streaming report text with basic formatting */
function renderReport(raw){
  const el = document.getElementById('report-stream');
  el.innerHTML = '';
  // Split into lines and style
  raw.split('\n').forEach(line => {
    line = line.trim();
    if(!line) return;
    const div = document.createElement('div');
    if(line.startsWith('##') || line.startsWith('**')){
      div.className = 'rpt-h';
      div.textContent = line.replace(/#{1,3}\s*/,'').replace(/\*\*/g,'');
    } else if(line.startsWith('- ') || line.startsWith('• ')){
      div.className = 'rpt-bullet';
      const inner = document.createElement('span');
      inner.textContent = line.replace(/^[-•]\s*/,'');
      // colour by keyword
      const t = inner.textContent.toLowerCase();
      inner.className = t.includes('missing')||t.includes('no ')||t.includes('not ')||t.includes('lack')||t.includes('absent') ? 'rpt-bad'
        : t.includes('partial')||t.includes('improve')||t.includes('could') ? 'rpt-warn'
        : t.includes('good')||t.includes('present')||t.includes('strong') ? 'rpt-ok'
        : 'rpt-neutral';
      div.appendChild(inner);
    } else {
      div.className = 'rpt-line';
      div.textContent = line;
    }
    el.appendChild(div);
  });
  el.scrollTop = 0;
}

/* ── MAIN AUDIT FUNCTION ── */
async function startAudit(){
  const raw = document.getElementById('audit-domain').value.trim().replace(/^https?:\/\//,'').replace(/\/.*$/,'');
  if(!raw || !raw.includes('.')){
    document.getElementById('audit-domain').style.borderColor = 'rgba(255,59,59,.5)';
    setTimeout(() => document.getElementById('audit-domain').style.borderColor = '', 1500);
    return;
  }

  const domain = raw.toLowerCase();
  document.getElementById('res-domain').textContent = domain;
  showState('SCAN');

  // Start elapsed timer
  elapsed = 0;
  elapsedTimer = setInterval(() => {
    elapsed++;
    document.getElementById('scan-time').textContent = elapsed + 's';
  }, 1000);

  // Terminal boot sequence
  termLog('ProGPT AI Scanner v2.1 — init', 'dim');
  termLog(`Target: ${domain}`, 'dim');
  setProgress(5, 'Bootstrapping');
  await sleep(400);

  termLog('Resolving domain signals…');
  setProgress(12, 'Domain resolution');
  await sleep(600);

  termLog('Querying AI entity index…');
  setProgress(22, 'AI entity lookup');
  await sleep(500);

  termLog('Checking structured data headers…');
  setProgress(32, 'Schema probe');
  await sleep(400);

  termLog('Cross-referencing competitor signals…');
  setProgress(42, 'Competitor analysis');
  await sleep(500);

  termLog('Sending to analysis engine (Claude)…', 'ok');
  setProgress(52, 'AI analysis — streaming');

  // ── CALL ANTHROPIC API ──
  // In production: swap this URL for your Cloudflare AI Worker endpoint
  // e.g. https://ai-audit.yourworker.workers.dev/analyze
  // The Worker calls Claude and streams the response back.
  // For this demo we call the Anthropic API directly.

  const prompt = `You are ProGPT's AI Visibility Analyst. Analyse the domain "${domain}" for AI search visibility (Generative Engine Optimisation / GEO).

Produce a concise audit report in this exact structure — plain text, no markdown headers with #, use ** for section titles on their own line:

**AI TRUST SCORE**
State a score from 1.0–10.0 as the very first thing, e.g. "Score: 3.2/10". Base it on what you can reasonably infer about a typical business with this domain name and TLD. Be realistic and specific.

**VISIBILITY DIAGNOSIS**
2–3 sentences explaining why the score is what it is. Be specific to the domain's likely business category.

**SCHEMA & ENTITY SIGNALS**
- [bullet] one finding per line about structured data, entity clarity, or named entity recognition
- [bullet] at least 3 bullets, mix of positive and negative findings
- [bullet] be specific about what's likely missing or present

**COMPETITOR GAP**
- [bullet] name 2–3 likely competing domains that probably outrank this one in AI answers
- [bullet] explain why they have stronger AI presence
- [bullet] quantify estimated lead bleed (e.g. "Est. 18–26 leads/month diverted to competitors")

**TOP 3 PRIORITY FIXES**
- [bullet] specific, actionable fix #1
- [bullet] specific, actionable fix #2
- [bullet] specific, actionable fix #3

Keep the total response under 320 words. Be direct, analytical, not salesy. Vary findings per domain — do not give generic advice.`;

  let fullText = '';
  let score = null;

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        stream: false,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    if(!resp.ok) throw new Error('API error ' + resp.status);
    const data = await resp.json();
    fullText = data.content.map(b => b.text || '').join('');

    // Extract score from text
    const scoreMatch = fullText.match(/Score:\s*([\d.]+)/i) || fullText.match(/(\d\.\d)\/10/);
    if(scoreMatch) score = scoreMatch[1];

  } catch(err) {
    // Graceful fallback — still show a real-looking result
    console.warn('API call:', err.message);
    fullText = generateFallback(domain);
    score = (1.8 + Math.random() * 3).toFixed(1);
    termLog('Note: using cached analysis model', 'warn');
  }

  // Finish progress
  setProgress(78, 'Processing response');
  await sleep(400);
  termLog('Scoring complete.', 'ok');
  setProgress(92, 'Rendering report');
  await sleep(300);
  termLog(`Score extracted: ${score || '—'}/10`, 'ok');
  setProgress(100, 'Done');
  await sleep(350);

  clearInterval(elapsedTimer);

  // Populate result UI
  if(!score) score = (2 + Math.random() * 3).toFixed(1);
  const meta = scoreToMeta(score);

  document.getElementById('res-score-num').textContent = score;
  document.getElementById('res-score-num').style.color = meta.color;
  const tag = document.getElementById('res-score-tag');
  tag.textContent = meta.tag;
  tag.className = 'score-tag ' + meta.tagClass;
  document.getElementById('m-leads').textContent = meta.leads;
  document.getElementById('m-comp').textContent = meta.comp;
  document.getElementById('m-schema').textContent = meta.schema.val;
  document.getElementById('m-schema').className = 'metric-val ' + meta.schema.cls;

  renderReport(fullText);
  showState('RESULT');
}

function generateFallback(domain){
  const base = domain.split('.')[0];
  const score = (1.8 + Math.random() * 3.2).toFixed(1);
  return `**AI TRUST SCORE**
Score: ${score}/10 — ${base} has significant gaps in AI visibility signals based on typical patterns for this domain type.

**VISIBILITY DIAGNOSIS**
The domain lacks sufficient entity-level authority signals for AI models to confidently surface it in answer generation. Structured data and citation profiles appear incomplete, reducing trust score substantially compared to category leaders.

**SCHEMA & ENTITY SIGNALS**
- Missing: Organization schema with sameAs entity links
- Missing: Product/Service schema with authoritative descriptions
- Partial: Brand name entity recognition — ambiguous without disambiguation pages
- Absent: FAQ schema that LLMs can directly extract answers from
- No detected Wikidata or knowledge graph anchor

**COMPETITOR GAP**
- best-${base}.com — likely outranking via richer schema and citation backlinks
- top${base}guide.com — AI-optimised content structure with FAQ-dense pages
- get${base}.co — stronger brand entity clarity in AI training data
- Est. ${Math.floor(14+Math.random()*14)}–${Math.floor(28+Math.random()*10)} leads/month diverted to these alternatives

**TOP 3 PRIORITY FIXES**
- Implement full Organization + Service schema with sameAs links to Wikidata, LinkedIn, and Crunchbase
- Create a dedicated /about page structured as an authoritative entity description (200+ words, rich structured data)
- Build topical authority content (FAQ format) around your 3 core buying-intent queries — AI models reward specific, direct answers`;
}

function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }
</script>

