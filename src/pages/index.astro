---
const title = "ProGPT — AI Visibility";
const description = "AI chooses who gets recommended. Make sure it's you.";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>
<meta name="description" content={description} />

<style>
:root{
  --bg:#06070d;
  --surface:#0e1018;
  --border:rgba(255,255,255,0.08);
  --text:#f5f7ff;
  --muted:#8a90a2;
  --accent:#5b8cff;
}

*{margin:0;padding:0;box-sizing:border-box}

body{
  font-family: system-ui, -apple-system, sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.5;
}

/* GRID BACKGROUND */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size:40px 40px;
  pointer-events:none;
}

/* WRAP */
.wrap{
  max-width:900px;
  margin:auto;
  padding:28px;
}

/* HERO */
.hero{
  padding:120px 0 80px;
  position:relative;
}

.hero::before{
  content:"";
  position:absolute;
  width:500px;
  height:300px;
  background:radial-gradient(circle, rgba(91,140,255,0.25), transparent);
  top:0;
  left:50%;
  transform:translateX(-50%);
  filter:blur(80px);
}

.badge{
  font-size:0.7rem;
  letter-spacing:0.12em;
  color:var(--muted);
  margin-bottom:20px;
}

h1{
  font-size:3.2rem;
  line-height:1.05;
  letter-spacing:-0.04em;
  margin-bottom:18px;
}

.hero p{
  color:var(--muted);
  font-size:1.1rem;
  max-width:520px;
  margin-bottom:28px;
}

/* INPUT */
.audit-box{
  display:flex;
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
  background:rgba(255,255,255,0.03);
  backdrop-filter:blur(10px);
}

.audit-box input{
  flex:1;
  padding:16px;
  background:transparent;
  border:none;
  color:white;
  font-size:1rem;
}

.audit-box button{
  background:var(--accent);
  border:none;
  padding:16px 24px;
  color:white;
  font-weight:600;
  cursor:pointer;
}

/* RESULT */
.result{
  display:none;
  margin-top:30px;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
}

.score{
  font-size:2.6rem;
  padding:24px;
  color:#ff5a5a;
}

.verdict{
  padding:0 24px;
  font-weight:600;
}

.result p{
  padding:12px 24px;
  color:var(--muted);
}

/* GATE */
.gate{
  padding:20px;
}

.gate input{
  width:100%;
  padding:14px;
  margin-bottom:10px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#000;
  color:white;
}

.gate button{
  width:100%;
  padding:14px;
  background:var(--accent);
  border:none;
  border-radius:10px;
  color:white;
}

/* CTA */
.cta{
  display:block;
  text-align:center;
  padding:16px;
  margin-top:12px;
  background:var(--accent);
  border-radius:10px;
  color:white;
  text-decoration:none;
}

/* SECTION */
.section{
  margin-top:100px;
}

.section h2{
  font-size:1.9rem;
  margin-bottom:12px;
  letter-spacing:-0.03em;
}

.section p{
  color:var(--muted);
  max-width:520px;
}

/* CONTRAST */
.contrast{
  margin-top:30px;
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
}

.contrast div{
  padding:20px;
}

.contrast .top{
  background:rgba(255,255,255,0.02);
}

.contrast .bottom{
  background:rgba(91,140,255,0.05);
}

/* PROOF */
.proof{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:12px;
  margin-top:24px;
}

.metric{
  padding:20px;
  border-radius:12px;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.02);
}

.metric h3{
  font-size:1.4rem;
}

/* TESTIMONIALS */
.testimonials{
  margin-top:24px;
  display:flex;
  flex-direction:column;
  gap:12px;
}

.testimonial{
  padding:18px;
  border-radius:12px;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.02);
  color:#d0d4e0;
}

/* BUY */
.buy{
  display:grid;
  gap:12px;
  margin-top:24px;
}

.buy a{
  padding:18px;
  border-radius:12px;
  text-align:center;
  text-decoration:none;
  color:white;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.02);
}

.buy .main{
  border-color:var(--accent);
  box-shadow:0 0 30px rgba(91,140,255,0.25);
}

/* NAV */
.tiles{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-top:24px;
}

.tile{
  padding:20px;
  border-radius:12px;
  border:1px solid var(--border);
  text-decoration:none;
  color:white;
  background:rgba(255,255,255,0.02);
}
</style>
</head>

<body>
<div class="wrap">

<!-- HERO -->
<div class="hero">

<div class="badge">AI SEARCH SHIFT</div>

<h1>AI already chose your competitors.</h1>

<p>
When someone asks ChatGPT for your service,
only a few businesses get recommended.
Most are never seen.
</p>

<div class="audit-box">
  <input placeholder="yourwebsite.com" />
  <button onclick="startAudit()">Run audit</button>
</div>

<div id="result" class="result">
  <div class="score">3.2 / 10</div>
  <div class="verdict">Low AI visibility</div>
  <p>Your competitors are being recommended instead.</p>

  <div class="gate">
    <input placeholder="Your name" />
    <input placeholder="Your email" />
    <button onclick="unlock()">Get full report</button>

    <div id="ctaBlock" style="display:none">
      <a href="https://your-lemonsqueezy-link.com" class="cta">
        Fix my AI visibility →
      </a>
    </div>
  </div>
</div>

</div>

<!-- CONTRAST -->
<div class="section">
<h2>The shift</h2>

<div class="contrast">
  <div class="top">
    Search = pages, rankings, clicks
  </div>
  <div class="bottom">
    AI = picks a few businesses. Ignores the rest.
  </div>
</div>
</div>

<!-- PROOF -->
<div class="section">
<h2>What changes</h2>

<div class="proof">
  <div class="metric">
    <h3>Appear in AI answers</h3>
  </div>
  <div class="metric">
    <h3>Higher intent leads</h3>
  </div>
  <div class="metric">
    <h3>Compounding visibility</h3>
  </div>
</div>
</div>

<!-- TESTIMONIALS -->
<div class="section">
<h2>What clients say</h2>

<div class="testimonials">
  <div class="testimonial">
    “We were invisible before. Now we show up when people ask AI.”
  </div>
  <div class="testimonial">
    “This changed how customers find us.”
  </div>
</div>
</div>

<!-- BUY -->
<div class="section">
<h2>Start fixing your visibility</h2>

<div class="buy">
  <a href="https://your-lemonsqueezy-link.com" class="main">
    Fix my AI visibility →
  </a>
  <a href="#">Buy on Gumroad</a>
  <a href="#">Buy on Whop</a>
</div>
</div>

<!-- NAV -->
<div class="section">
<h2>Explore</h2>

<div class="tiles">
  <a href="/blog" class="tile">Blog</a>
  <a href="/about" class="tile">About</a>
  <a href="/dashboard" class="tile">Dashboard</a>
  <a href="/audit" class="tile">Run Audit</a>
</div>
</div>

</div>

<script>
function startAudit(){
  document.getElementById("result").style.display="block";
}

function unlock(){
  document.getElementById("ctaBlock").style.display="block";
}
</script>

</body>
</html>