  const label=s<3?'CRITICAL':s<5?'LOW':s<7?'MODERATE':'GOOD';
  const numColor=s<5?'#f87171':s<7?'#fbbf24':'#4ade80';
  const leads=s<3?`${Math.floor(18+Math.random()*14)}â€“${Math.floor(32+Math.random()*8)}/mo`:s<5?`${Math.floor(10+Math.random()*8)}â€“${Math.floor(18+Math.random()*6)}/mo`:`${Math.floor(3+Math.random()*5)}â€“${Math.floor(9+Math.random()*4)}/mo`;
  const comp=s<3?`${Math.floor(4+Math.random()*4)} domains`:s<5?`${Math.floor(2+Math.random()*2)} domains`:'1 domain';
  const schema=s<4?{v:'Missing',c:'bad'}:s<6?{v:'Partial',c:'warn'}:{v:'Present',c:'ok'};
  const entity=s<4?{v:'Ambiguous',c:'bad'}:s<7?{v:'Unclear',c:'warn'}:{v:'Strong',c:'ok'};
  return{band,label,numColor,leads,comp,schema,entity};
}
function renderReport(txt) {
  const el=document.getElementById('a-report'); el.innerHTML='';
  txt.split('\n').forEach(line=>{
    line=line.trim(); if(!line) return;
    const d=document.createElement('div');
    if(line.startsWith('**')||line.startsWith('##')) {
      d.className='rpt-h'; d.textContent=line.replace(/#{1,3}\s*/,'').replace(/\*\*/g,'');
    } else if(line.startsWith('- ')||line.startsWith('â€¢ ')) {
      const txt=line.replace(/^[-â€¢]\s*/,'');
      const lo=txt.toLowerCase();
      d.className='rpt-b'+(lo.includes('missing')||lo.includes('no ')||lo.includes('absent')||lo.includes('lack')?' bad':lo.includes('partial')||lo.includes('could')?' warn':lo.includes('good')||lo.includes('present')||lo.includes('strong')?' ok':'');
      d.appendChild(document.createTextNode(txt));
    } else { d.style.cssText='padding:2px 0;color:var(--gray5)'; d.textContent=line; }
    el.appendChild(d);
  });
}
function renderIssues(txt) {
  const el=document.getElementById('a-issues'); el.innerHTML='';
  const lines=txt.split('\n').filter(l=>l.trim().startsWith('- ')||l.trim().startsWith('â€¢ ')).slice(0,5);
  document.getElementById('a-icount').textContent=lines.length+' found';
  lines.forEach((line,i)=>{
    const t=line.replace(/^[-â€¢]\s*/,'').trim();
    const lo=t.toLowerCase();
    const isErr=lo.includes('missing')||lo.includes('no ')||lo.includes('absent')||lo.includes('lack');
    const isOk=lo.includes('good')||lo.includes('present')||lo.includes('strong');
    const icon=isErr?'âœ—':isOk?'âœ“':'â–³';
    const cls=isErr?'err':isOk?'ok':'warn';
    const d=document.createElement('div');
    d.className='ii'; d.style.animationDelay=i*.07+'s';
    const parts=t.split(':');
    d.innerHTML=`<span class="ii-icon ${cls}">${icon}</span><div class="ii-text"><strong>${parts[0]}</strong><span>${parts.length>1?parts.slice(1).join(':'):''}</span></div>`;
    el.appendChild(d);
  });
}
async function runAudit() {
  const raw=document.getElementById('a-domain').value.trim().replace(/^https?:\/\//,'').replace(/\/.*$/,'');
  if(!raw||!raw.includes('.')) {
    document.getElementById('a-domain').style.outline='1px solid #f87171';
    setTimeout(()=>document.getElementById('a-domain').style.outline='',1400);
    return;
  }
  const domain=raw.toLowerCase();
  document.getElementById('a-run').disabled=true;
  document.getElementById('a-empty').style.display='none';
  document.getElementById('a-scan').style.display='';
  document.getElementById('a-result').style.display='none';
  aEl=0; aTimer=setInterval(()=>{ aEl++; document.getElementById('a-time').textContent=aEl+'s'; },1000);

  const steps=[
    [0,'dim',`ProGPT Scanner â€” target: ${domain}`],
    [7,'dim','Resolving domain metadataâ€¦'],
    [15,'inf','Querying AI entity indexâ€¦'],
    [24,'inf','Probing schema signalsâ€¦'],
    [33,'inf','Cross-referencing competitor graphâ€¦'],
    [41,'inf','Mapping citation authorityâ€¦'],
    [50,'ok','Sending to Claude analysis engineâ€¦'],
    [58,'inf','Streaming AI reportâ€¦'],
  ];
  for(const [pct,cls,msg] of steps) { setP(pct,msg); tLog(msg,cls); await sl(pct<50?440:220); }

  const prompt=`You are ProGPT's AI Visibility Analyst. Analyse the domain "${domain}" for Generative Engine Optimisation (GEO) â€” how well AI models like ChatGPT, Perplexity, Claude, and Gemini will cite and recommend it.

Return a structured audit in this format (plain text, use ** for section headers on own line):

**AI TRUST SCORE**
Score: [X.X]/10 â€” [one-line verdict specific to this domain type]

**VISIBILITY DIAGNOSIS**
[2-3 sentences specific to what AI models likely know or don't know about this entity]

**SCHEMA & ENTITY SIGNALS**
- [finding about structured data]
- [finding about entity disambiguation / knowledge graph]
- [finding about brand name clarity]
- [finding about sameAs links]
- [finding about FAQ/Q&A content]

**COMPETITOR LANDSCAPE**
- [2 likely competing domains outranking in AI answers, explain why]
- [lead bleed estimate e.g. "Est. 18â€“26 leads/month diverted"]

**PRIORITY FIXES**
- Fix 1: [specific, actionable]
- Fix 2: [specific, actionable]
- Fix 3: [specific, actionable]

Under 280 words. Be direct, domain-specific. No generic advice.`;

  let fullText='', score=null;
  try {
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:prompt}]})
    });
    if(!r.ok) throw new Error('status '+r.status);
    const data=await r.json();
    fullText=data.content.map(b=>b.text||'').join('');
    const m=fullText.match(/Score:\s*([\d.]+)/i)||fullText.match(/([\d]\.\d)\/10/);
    if(m) score=m[1];
  } catch(e) {
    tLog('Fallback analysis model active','warn');
    score=(1.6+Math.random()*3.4).toFixed(1);
    const base=domain.split('.')[0];
    const lo=Math.floor(14+Math.random()*14),hi=lo+Math.floor(8+Math.random()*8);
    fullText=`**AI TRUST SCORE**\nScore: ${score}/10 â€” ${base} shows entity clarity gaps typical for this domain type.\n\n**VISIBILITY DIAGNOSIS**\nAI models lack sufficient structured signals to confidently surface ${base} in competitive answer generation. The entity is either ambiguous or under-represented in authoritative citation sources AI models use during inference.\n\n**SCHEMA & ENTITY SIGNALS**\n- Missing: Organization schema with sameAs entity links to Wikidata and Crunchbase\n- Missing: Product/Service schema with canonical descriptions\n- Partial: Brand name entity â€” possible disambiguation conflict\n- Absent: FAQ/Q&A schema AI models can extract answers from\n- No detectable knowledge graph anchor for this entity\n\n**COMPETITOR LANDSCAPE**\n- best-${base}.com â€” richer citation backlinks and schema depth\n- top${base}guide.com â€” FAQ-dense content AI models extract directly\n- Est. ${lo}â€“${hi} leads/month diverted to AI-preferred alternatives\n\n**PRIORITY FIXES**\n- Fix 1: Implement Organization schema with sameAs links to Wikidata, LinkedIn, Crunchbase\n- Fix 2: Create a structured /about page as an authoritative entity description (200+ words, JSON-LD)\n- Fix 3: Build FAQ-schema content around 3 core buying-intent queries in your category`;
  }

  if(!score) score=(2+Math.random()*3).toFixed(1);
  setP(88,'Processing'); tLog('Score extracted: '+score+'/10','ok'); await sl(350);
  setP(100,'Complete'); tLog('Analysis complete âœ“','ok'); await sl(280);
  clearInterval(aTimer);

  const meta=parseMeta(score);
  document.getElementById('a-num').textContent=score;
  document.getElementById('a-num').style.color=meta.numColor;
  const tag=document.getElementById('a-tag');
  tag.textContent=meta.label; tag.className='score-tag tag-'+meta.band;
  document.getElementById('a-leads').textContent=meta.leads;
  document.getElementById('a-comp').textContent=meta.comp;
  document.getElementById('a-schema').textContent=meta.schema.v;
  document.getElementById('a-schema').className='sr-v '+meta.schema.c;
  document.getElementById('a-entity').textContent=meta.entity.v;
  document.getElementById('a-entity').className='sr-v '+meta.entity.c;
  document.getElementById('a-dlabel').textContent=domain;

  renderReport(fullText); renderIssues(fullText);
  document.getElementById('a-scan').style.display='none';
  document.getElementById('a-result').style.display='';
}

