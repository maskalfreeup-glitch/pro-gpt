<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>ProGPT — AI Visibility</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#050505;
  --card:#0f0f0f;
  --border:#1a1a1a;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --accent:#4f7cff;
}

/* BASE */
*{box-sizing:border-box;margin:0;padding:0}

body{
  font-family:Inter, sans-serif;
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
}

/* BACKGROUND GRID */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(#111 1px, transparent 1px),
    linear-gradient(90deg,#111 1px, transparent 1px);
  background-size:40px 40px;
  opacity:0.2;
  z-index:-1;
}

/* GLOW ORB */
body::after{
  content:"";
  position:fixed;
  width:500px;
  height:500px;
  background:radial-gradient(circle, rgba(79,124,255,0.25), transparent 70%);
  top:20%;
  left:50%;
  transform:translateX(-50%);
  filter:blur(80px);
  z-index:-1;
}

.container{
  max-width:720px;
  margin:auto;
  padding:24px;
}

h1{
  font-size:40px;
  line-height:1.1;
}

h2{
  font-size:22px;
}

p{
  color:var(--muted);
  margin-top:8px;
}

.section{
  margin-top:60px;
}

.card{
  background:var(--card);
  border:1px solid var(--border);
  padding:18px;
  border-radius:14px;
  margin-top:12px;
  transition:0.3s;
}

.card:hover{
  border-color:#2a2a2a;
}

input,select{
  width:100%;
  padding:14px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#0b0b0b;
  color:white;
  margin-top:10px;
}

button{
  margin-top:14px;
  width:100%;
  padding:14px;
  border-radius:10px;
  border:none;
  background:var(--accent);
  color:white;
  font-weight:600;
  cursor:pointer;
  transition:0.2s;
}

button:hover{
  transform:translateY(-1px);
}

.cta-main{
  display:block;
  text-align:center;
  margin-top:18px;
  padding:16px;
  border-radius:12px;
  background:var(--accent);
  color:white;
  font-weight:600;
  text-decoration:none;
  box-shadow:0 0 20px rgba(79,124,255,0.4);
}

.cta-alt a{
  display:block;
  text-align:center;
  margin-top:10px;
  padding:14px;
  border-radius:10px;
  border:1px solid var(--border);
  color:var(--text);
  text-decoration:none;
}

/* SCANNING */
.scan{
  display:none;
  margin-top:20px;
  text-align:center;
}

.loader{
  width:100%;
  height:6px;
  background:#111;
  border-radius:6px;
  overflow:hidden;
  margin-top:12px;
}

.loader span{
  display:block;
  height:100%;
  width:0%;
  background:var(--accent);
  animation:scan 2.5s linear forwards;
}

@keyframes scan{
  0%{width:0%}
  100%{width:100%}
}

/* LIVE ACTIVITY */
.live{
  font-size:13px;
  color:var(--muted);
  margin-top:10px;
}

.dot{
  display:inline-block;
  width:8px;
  height:8px;
  background:red;
  border-radius:50%;
  margin-right:6px;
  animation:pulse 1.2s infinite;
}

@keyframes pulse{
  0%{opacity:1}
  50%{opacity:0.3}
  100%{opacity:1}
}

</style>
</head>

<body>

<div class="container">

<!-- HERO -->
<section class="section">
<h1>AI already chose your competitors.</h1>
<p>If you're not in AI answers, you don't exist.</p>

<div class="live">
  <span class="dot"></span>
  <span id="liveCount">12</span> businesses checked in the last hour
</div>

</section>

<!-- AUDIT -->
<section class="section">

<h2>Check your AI visibility</h2>

<div id="step1" class="card">
  <input id="website" placeholder="yourwebsite.com">
  <button onclick="startScan()">Check →</button>
</div>

<!-- SCANNING -->
<div id="scan" class="scan">
  <p id="scanText">Scanning your site…</p>
  <div class="loader"><span></span></div>
</div>

<!-- RESULT -->
<div id="result" style="display:none;margin-top:20px">

  <div class="card">
    <h2 id="scoreText">Score: 3.2 / 10</h2>

    <p>AI is not recommending your business.</p>

    <ul style="margin-top:10px;color:#aaa;font-size:14px">
      <li>Weak authority signals</li>
      <li>No structured data</li>
      <li>No AI content</li>
    </ul>

    <p style="margin-top:10px">
      Competitors are taking your traffic.
    </p>

    <input id="email" placeholder="Enter email for full report">
    <button onclick="saveLead()">Get full report →</button>

  </div>

</div>

</section>

<!-- VALUE -->
<section class="section">

<h2>What you get</h2>

<div class="card">
  Done-for-you AI optimization
</div>

<div class="card">
  Schema + AI content signals
</div>

<div class="card">
  Authority + local ranking fixes
</div>

</section>

<!-- CTA -->
<section class="section">

<h2>Fix your visibility</h2>

<p>One-time setup · Results in 4–8 weeks</p>

<a href="https://your-lemonsqueezy-link.com" class="cta-main">
Start now → $297
</a>

<div class="cta-alt">
  <a href="https://whop.com">Buy on Whop</a>
  <a href="https://gumroad.com">Buy on Gumroad</a>
  <a href="https://discord.gg/YOUR">Join Discord</a>
</div>

</section>

</div>

<script>
function startScan(){
  document.getElementById("step1").style.display="none";
  document.getElementById("scan").style.display="block";

  let texts=[
    "Scanning your website…",
    "Analyzing AI signals…",
    "Checking competitors…",
    "Evaluating authority…"
  ];

  let i=0;
  let interval=setInterval(()=>{
    document.getElementById("scanText").innerText=texts[i];
    i++;
    if(i>=texts.length) clearInterval(interval);
  },600);

  setTimeout(showResult,2600);
}

function showResult(){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(Math.random()*3+2).toFixed(1);
  document.getElementById("scoreText").innerText="Score: "+score+" / 10";
}

function saveLead(){
  let email=document.getElementById("email").value;

  let leads=JSON.parse(localStorage.getItem("leads")||"[]");
  leads.push({
    email,
    website:document.getElementById("website").value
  });

  localStorage.setItem("leads",JSON.stringify(leads));
}

/* LIVE COUNTER */
setInterval(()=>{
  let el=document.getElementById("liveCount");
  let num=parseInt(el.innerText);
  el.innerText=num+Math.floor(Math.random()*3);
},5000);
</script>

</body>
</html>