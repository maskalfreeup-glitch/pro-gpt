---
const title = "AI Visibility Audit";
const description = "Check if ChatGPT recommends your business.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
        background: #000;
        color: #fff;
      }

      .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 60px 20px;
        text-align: center;
      }

      h1 {
        font-size: 2.2rem;
        line-height: 1.3;
        margin-bottom: 12px;
      }

      .sub {
        color: #aaa;
        margin-bottom: 30px;
      }

      .input-box {
        display: flex;
        background: #111;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 0 0 1px #222;
      }

      input {
        flex: 1;
        padding: 16px;
        border: none;
        outline: none;
        background: transparent;
        color: #fff;
        font-size: 1rem;
      }

      button {
        background: linear-gradient(135deg, #7C3AED, #9333EA);
        border: none;
        padding: 16px 22px;
        color: white;
        cursor: pointer;
        font-weight: 600;
        transition: 0.2s;
      }

      button:hover {
        opacity: 0.9;
      }

      .trust {
        font-size: 0.85rem;
        color: #666;
        margin-top: 12px;
      }

      .result {
        background: #111;
        border-radius: 12px;
        padding: 24px;
        margin-top: 30px;
        display: none;
        text-align: left;
        box-shadow: 0 0 0 1px #222;
      }

      .score {
        font-size: 1.6rem;
        margin-bottom: 10px;
      }

      .bad {
        color: #ff4d4d;
        margin-bottom: 10px;
      }

      .warn {
        color: #ffaa00;
        margin-bottom: 10px;
      }

      .cta {
        margin-top: 20px;
        display: block;
        background: #7C3AED;
        padding: 14px;
        text-decoration: none;
        color: white;
        border-radius: 8px;
        font-weight: bold;
        text-align: center;
      }

      .features {
        margin-top: 50px;
        text-align: left;
      }

      .features div {
        margin-bottom: 10px;
        color: #ccc;
      }

      footer {
        margin-top: 60px;
        font-size: 0.8rem;
        color: #666;
      }

      @media (max-width: 600px) {
        h1 {
          font-size: 1.8rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>Check if ChatGPT recommends your business</h1>

      <p class="sub">
        AI Visibility Audit for local businesses
      </p>

      <div class="input-box">
        <input id="siteInput" placeholder="Enter your website..." />
        <button onclick="runAudit()">Check</button>
      </div>

      <div class="trust">
        Works for ChatGPT, Gemini & AI search
      </div>

      <!-- RESULT -->
      <div id="result" class="result">
        <div class="score">AI Visibility Score: <b>3.2 / 10</b></div>

        <div class="bad">❌ Not recommended in AI answers</div>
        <div class="warn">⚠️ Weak authority & unclear positioning</div>

        <div>
          AI cannot clearly understand your business or trust your content.
        </div>

        <a
          class="cta"
          href="https://yourstore.lemonsqueezy.com/checkout/buy/XXXX"
          target="_blank"
        >
          Unlock full audit → $19
        </a>
      </div>

      <!-- FEATURES -->
      <div class="features">
        <div>✔ Check if AI recommends your business</div>
        <div>✔ Identify why you're invisible</div>
        <div>✔ Get clear steps to improve</div>
      </div>

      <footer>
        progpt.store — AI Search Optimization
      </footer>
    </div>

    <script>
      function runAudit() {
        const input = document.getElementById("siteInput").value;
        if (!input) return;

        // TEMP RESULT (replace with real API later)
        document.getElementById("result").style.display = "block";
      }
    </script>
  </body>
</html>