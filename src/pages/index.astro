---
const title = "ProGPT — AI Visibility System";
const description = "Check if ChatGPT recommends your business.";
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>

<style>
body {
  margin: 0;
  background: #000;
  color: #fff;
  font-family: -apple-system, sans-serif;
}

/* subtle grid */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(124,58,237,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(124,58,237,0.05) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

.container {
  max-width: 720px;
  margin: 0 auto;
  padding: 80px 20px;
  text-align: center;
}

/* HERO */
h1 {
  font-size: 2.6rem;
  line-height: 1.25;
  font-weight: 800;
}

.sub {
  color: #888;
  margin-top: 12px;
  margin-bottom: 30px;
}

/* INPUT */
.audit-box {
  display: flex;
  background: #0b0b0b;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #1a1a1a;
  box-shadow: 0 0 30px rgba(124,58,237,0.08);
}

.audit-box input {
  flex: 1;
  padding: 16px;
  background: transparent;
  border: none;
  color: #fff;
  outline: none;
  font-size: 1rem;
}

.audit-box button {
  background: linear-gradient(135deg, #7C3AED, #9333EA);
  border: none;
  padding: 16px 22px;
  color: white;
  font-weight: 600;
  cursor: pointer;
}

/* TRUST */
.trust {
  font-size: 0.8rem;
  color: #555;
  margin-top: 10px;
}

/* RESULT */
.result {
  display: none;
  margin-top: 26px;
  padding: 20px;
  background: #0b0b0b;
  border-radius: 12px;
  border: 1px solid #1a1a1a;
  text-align: left;
}

.score {
  font-size: 1.4rem;
  font-weight: 700;
}

.bad { color: #ff4d4d; margin-top: 8px; }
.warn { color: #ffaa00; margin-top: 6px; }

/* CTA */
.cta {
  display: block;
  margin-top: 16px;
  background: linear-gradient(135deg, #7C3AED, #9333EA);
  padding: 14px;
  text-align: center;
  border-radius: 10px;
  color: white;
  text-decoration: none;
  font-weight: 700;
  letter-spacing: 0.3px;
}

/* SECTIONS */
.section {
  margin-top: 70px;
  text-align: left;
}

.section h2 {
  font-size: 1.5rem;
  margin-bottom: 12px;
}

.section p {
  color: #888;
  margin-bottom: 16px;
  line-height: 1.6;
}

.list div {
  margin-bottom: 8px;
  color: #ccc;
}

/* FOOTER */
footer {
  margin-top: 70px;
  font-size: 0.75rem;
  color: #444;
  text-align: center;
}

</style>
</head>

<body>

<div class="container">

<h1>
Check if AI recommends your business
</h1>

<p class="sub">
If you’re not in AI answers, you don’t exist.
</p>

<div class="audit-box">
  <input id="siteInput" placeholder="Enter your website..." />
  <button onclick="runAudit()">Check</button>
</div>

<div class="trust">
ChatGPT • Gemini • AI Search
</div>

<!-- RESULT -->
<div id="result" class="result">

<div class="score">AI Visibility Score: 3.2 / 10</div>

<div class="bad">❌ Not recommended</div>
<div class="warn">⚠ Weak authority signals</div>

<p style="color:#777; margin-top:10px;">
AI cannot confidently select your business.
Your competitors are more likely to appear.
</p>

<a href="https://whop.com/progpt" class="cta">
Fix this →
</a>

</div>

<!-- WHY -->
<div class="section">
<h2>Why this matters</h2>

<p>
Search is shifting from links to answers.
AI picks a few businesses — not pages.
</p>

<div class="list">
<div>✔ Only top entities get recommended</div>
<div>✔ Most businesses are invisible</div>
<div>✔ Visibility = revenue</div>
</div>
</div>

<!-- WHAT -->
<div class="section">
<h2>What we fix</h2>

<p>
We restructure your business for AI systems to understand and trust.
</p>

<div class="list">
<div>✔ Structured data & schema</div>
<div>✔ Positioning clarity</div>
<div>✔ Local authority signals</div>
<div>✔ AI-answer-ready content</div>
</div>
</div>

<!-- CTA -->
<div class="section">
<h2>Get your audit</h2>

<p>
See exactly why AI ignores you — and how we fix it.
</p>

<a href="https://whop.com/progpt" class="cta">
Get full audit →
</a>

</div>

<footer>
progpt.store — AI Search Optimization
</footer>

</div>

<script>
function runAudit() {
  const input = document.getElementById("siteInput").value;
  if (!input) return;
  document.getElementById("result").style.display = "block";
}
</script>

</body>
</html>