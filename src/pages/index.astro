---
const title = "ProGPT â€” Rank Inside ChatGPT & AI Search";
const description = "We help local businesses appear inside AI-generated answers. Free AI visibility audit â€” see your score in 30 seconds.";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href="https://progpt.store" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ProGPT",
    "url": "https://progpt.store",
    "description": "AI search optimization and GEO services for local businesses",
    "serviceType": "Generative Engine Optimization",
    "areaServed": "United States"
  }
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #ffffff;
      --bg2: #f9f9f8;
      --bg3: #f3f3f0;
      --border: #e8e8e3;
      --border2: #d5d5ce;
      --ink: #1a1a18;
      --ink2: #3d3d38;
      --ink3: #6b6b63;
      --ink4: #9c9c92;
      --accent: #0a0a0a;
      --blue: #2f54eb;
      --blue-light: #e8eeff;
      --blue-dim: rgba(47,84,235,0.08);
      --green: #00875a;
      --green-light: #e3fcef;
      --red: #de350b;
      --amber: #ff8b00;
      --font-serif: 'Instrument Serif', Georgia, serif;
      --font-sans: 'Geist', system-ui, sans-serif;
      --radius: 10px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
      --shadow-md: 0 4px 16px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
      --shadow-lg: 0 20px 60px rgba(0,0,0,0.1), 0 4px 12px rgba(0,0,0,0.05);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* â”€â”€ NAV â”€â”€ */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 1.5rem;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-left { display: flex; align-items: center; gap: 2rem; }

    .nav-logo {
      font-family: var(--font-sans);
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--ink);
      text-decoration: none;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .logo-mark {
      width: 22px; height: 22px;
      background: var(--ink);
      border-radius: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: -0.05em;
    }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 0.25rem;
    }

    .nav-links a {
      color: var(--ink3);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 0.35rem 0.65rem;
      border-radius: 6px;
      transition: background 0.15s, color 0.15s;
    }

    .nav-links a:hover { background: var(--bg2); color: var(--ink); }

    .nav-right { display: flex; align-items: center; gap: 0.5rem; }

    .nav-ghost {
      color: var(--ink2);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 0.4rem 0.75rem;
      border-radius: 6px;
      transition: background 0.15s;
    }

    .nav-ghost:hover { background: var(--bg2); }

    .nav-cta {
      background: var(--ink);
      color: white;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      padding: 0.4rem 0.9rem;
      border-radius: 7px;
      transition: opacity 0.15s;
      white-space: nowrap;
    }

    .nav-cta:hover { opacity: 0.85; }

    /* â”€â”€ HERO â”€â”€ */
    .hero {
      max-width: 860px;
      margin: 0 auto;
      padding: 6rem 2rem 4rem;
      text-align: center;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--blue-light);
      color: var(--blue);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      padding: 0.3rem 0.85rem;
      border-radius: 20px;
      margin-bottom: 1.75rem;
      border: 1px solid rgba(47,84,235,0.15);
    }

    .eyebrow-dot {
      width: 5px; height: 5px;
      background: var(--blue);
      border-radius: 50%;
      animation: pulse 2.5s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(1.5); }
    }

    .hero h1 {
      font-family: var(--font-serif);
      font-size: clamp(2.8rem, 7vw, 4.8rem);
      font-weight: 400;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 1.25rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--ink3);
    }

    .hero-desc {
      font-size: 1.05rem;
      color: var(--ink3);
      max-width: 520px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
      font-weight: 400;
    }

    /* Inline CTA */
    .hero-form {
      display: flex;
      gap: 0.5rem;
      max-width: 440px;
      margin: 0 auto 1rem;
      background: var(--bg);
      border: 1.5px solid var(--border2);
      border-radius: 10px;
      padding: 0.35rem 0.35rem 0.35rem 1rem;
      box-shadow: var(--shadow-md);
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .hero-form:focus-within {
      border-color: var(--ink);
      box-shadow: var(--shadow-lg);
    }

    .hero-input {
      flex: 1;
      border: none;
      outline: none;
      background: transparent;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      color: var(--ink);
    }

    .hero-input::placeholder { color: var(--ink4); }

    .hero-submit {
      background: var(--ink);
      color: white;
      border: none;
      border-radius: 7px;
      padding: 0.6rem 1.2rem;
      font-family: var(--font-sans);
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: opacity 0.15s;
    }

    .hero-submit:hover { opacity: 0.85; }

    .hero-micro {
      font-size: 0.78rem;
      color: var(--ink4);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }

    .hero-micro span {
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    /* â”€â”€ LOGO STRIP â”€â”€ */
    .logo-strip {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--bg2);
      padding: 1.25rem 2rem;
      text-align: center;
    }

    .logo-strip p {
      font-size: 0.75rem;
      color: var(--ink4);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 500;
      margin-bottom: 1rem;
    }

    .ai-platforms {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .ai-platform {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--ink3);
    }

    .platform-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
    }

    /* â”€â”€ SECTIONS â”€â”€ */
    .section {
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .section-tag {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--blue);
      margin-bottom: 0.75rem;
    }

    .section-h {
      font-family: var(--font-serif);
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 400;
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 0.75rem;
    }

    .section-h em { font-style: italic; color: var(--ink3); }

    .section-desc {
      color: var(--ink3);
      font-size: 0.95rem;
      max-width: 500px;
      line-height: 1.7;
      margin-bottom: 3rem;
    }

    /* â”€â”€ PROBLEM SECTION â”€â”€ */
    .problem-section {
      background: var(--bg2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .problem-inner {
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 2rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .problem-stats {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .stat-block { padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .stat-block:last-child { border-bottom: none; padding-bottom: 0; }

    .stat-num {
      font-family: var(--font-serif);
      font-size: 3rem;
      font-weight: 400;
      line-height: 1;
      color: var(--ink);
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.85rem;
      color: var(--ink3);
      line-height: 1.5;
    }

    /* â”€â”€ HOW IT WORKS â”€â”€ */
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .step-cell {
      background: var(--bg);
      padding: 2rem 1.5rem;
      transition: background 0.2s;
    }

    .step-cell:hover { background: var(--bg2); }

    .step-index {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink4);
      margin-bottom: 1rem;
    }

    .step-title {
      font-family: var(--font-serif);
      font-size: 1.3rem;
      font-weight: 400;
      margin-bottom: 0.6rem;
      color: var(--ink);
    }

    .step-desc {
      font-size: 0.85rem;
      color: var(--ink3);
      line-height: 1.6;
    }

    /* â”€â”€ CHECKS â”€â”€ */
    .checks-table {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .check-row {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }

    .check-row:last-child { border-bottom: none; }
    .check-row:hover { background: var(--bg2); }

    .check-icon-wrap {
      width: 28px; height: 28px;
      border-radius: 7px;
      background: var(--bg2);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }

    .check-content { flex: 1; }

    .check-name {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 0.2rem;
    }

    .check-desc-text {
      font-size: 0.8rem;
      color: var(--ink3);
      line-height: 1.5;
    }

    .check-tag {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 0.2rem 0.55rem;
      border-radius: 5px;
      flex-shrink: 0;
      margin-top: 0.15rem;
    }

    .tag-critical { background: #fff0ee; color: var(--red); }
    .tag-high { background: #fff8e6; color: var(--amber); }
    .tag-medium { background: var(--green-light); color: var(--green); }

    /* â”€â”€ PRICING â”€â”€ */
    .pricing-section {
      background: var(--bg2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .pricing-inner {
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--border2);
      border: 1px solid var(--border2);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }

    .price-card {
      background: var(--bg);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .price-card.highlight {
      background: var(--ink);
    }

    .price-card.highlight .price-name { color: rgba(255,255,255,0.5); }
    .price-card.highlight .price-amount { color: white; }
    .price-card.highlight .price-per { color: rgba(255,255,255,0.4); }
    .price-card.highlight .price-tagline { color: rgba(255,255,255,0.6); }
    .price-card.highlight .price-feat { color: rgba(255,255,255,0.7); }
    .price-card.highlight .price-feat::before { color: rgba(255,255,255,0.4); }
    .price-card.highlight .price-btn-out {
      background: white;
      color: var(--ink);
    }

    .popular-tag {
      position: absolute;
      top: -1px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--blue);
      color: white;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.2rem 0.65rem;
      border-radius: 0 0 6px 6px;
    }

    .price-name {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink4);
      margin-bottom: 0.75rem;
    }

    .price-amount {
      font-family: var(--font-serif);
      font-size: 2.2rem;
      font-weight: 400;
      line-height: 1;
      color: var(--ink);
      margin-bottom: 0.2rem;
    }

    .price-amount sup {
      font-size: 1rem;
      vertical-align: super;
      font-family: var(--font-sans);
      font-weight: 500;
    }

    .price-per {
      font-size: 0.75rem;
      color: var(--ink4);
      margin-bottom: 0.75rem;
    }

    .price-tagline {
      font-size: 0.8rem;
      color: var(--ink3);
      margin-bottom: 1.25rem;
      line-height: 1.5;
      flex: 1;
    }

    .price-divider {
      height: 1px;
      background: var(--border);
      margin-bottom: 1.25rem;
    }

    .price-card.highlight .price-divider { background: rgba(255,255,255,0.1); }

    .price-feats { margin-bottom: 1.25rem; }

    .price-feat {
      font-size: 0.78rem;
      color: var(--ink3);
      margin-bottom: 0.35rem;
      padding-left: 1rem;
      position: relative;
      line-height: 1.4;
    }

    .price-feat::before {
      content: 'âœ“';
      position: absolute;
      left: 0;
      color: var(--green);
      font-weight: 700;
      font-size: 0.72rem;
    }

    .price-btn-out {
      display: block;
      text-align: center;
      padding: 0.65rem;
      border-radius: 7px;
      font-size: 0.82rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.15s;
      background: var(--ink);
      color: white;
    }

    .price-btn-out:hover { opacity: 0.85; }

    .price-btn-ghost {
      display: block;
      text-align: center;
      padding: 0.65rem;
      border-radius: 7px;
      font-size: 0.82rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.15s;
      border: 1px solid var(--border2);
      color: var(--ink2);
    }

    .price-btn-ghost:hover { background: var(--bg2); border-color: var(--ink3); }

    /* â”€â”€ TESTIMONIAL â”€â”€ */
    .testimonial-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .testimonial-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .testimonial-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    .t-stars { color: var(--amber); font-size: 0.75rem; margin-bottom: 0.6rem; }

    .t-quote {
      font-size: 0.875rem;
      color: var(--ink2);
      line-height: 1.6;
      margin-bottom: 1rem;
      font-style: italic;
    }

    .t-author {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .t-avatar {
      width: 30px; height: 30px;
      border-radius: 50%;
      background: var(--bg3);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--ink3);
    }

    .t-name {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--ink);
    }

    .t-role { font-size: 0.72rem; color: var(--ink4); }

    /* â”€â”€ FAQ â”€â”€ */
    .faq-section {
      background: var(--bg2);
      border-top: 1px solid var(--border);
    }

    .faq-inner {
      max-width: 680px;
      margin: 0 auto;
      padding: 5rem 2rem;
    }

    .faq-list { margin-top: 2rem; }

    .faq-item {
      border-bottom: 1px solid var(--border);
    }

    .faq-q {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--ink);
      user-select: none;
      transition: color 0.15s;
      gap: 1rem;
    }

    .faq-q:hover { color: var(--ink2); }

    .faq-chevron {
      color: var(--ink4);
      font-size: 0.75rem;
      transition: transform 0.2s;
      flex-shrink: 0;
    }

    .faq-item.open .faq-chevron { transform: rotate(180deg); }

    .faq-a {
      display: none;
      padding-bottom: 1rem;
      font-size: 0.875rem;
      color: var(--ink3);
      line-height: 1.7;
    }

    .faq-item.open .faq-a { display: block; }

    /* â”€â”€ CTA SECTION â”€â”€ */
    .cta-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 2rem 6rem;
      text-align: center;
    }

    .cta-box {
      background: var(--ink);
      border-radius: 16px;
      padding: 4rem 3rem;
      position: relative;
      overflow: hidden;
    }

    .cta-box::before {
      content: '';
      position: absolute;
      top: -60%;
      left: -10%;
      width: 60%;
      height: 120%;
      background: radial-gradient(ellipse, rgba(255,255,255,0.04) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-box::after {
      content: '';
      position: absolute;
      bottom: -60%;
      right: -10%;
      width: 60%;
      height: 120%;
      background: radial-gradient(ellipse, rgba(47,84,235,0.15) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-box h2 {
      font-family: var(--font-serif);
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 400;
      color: white;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 0.75rem;
      position: relative;
      z-index: 1;
    }

    .cta-box h2 em { font-style: italic; color: rgba(255,255,255,0.55); }

    .cta-box p {
      color: rgba(255,255,255,0.55);
      font-size: 0.95rem;
      margin-bottom: 2rem;
      position: relative;
      z-index: 1;
    }

    .cta-form {
      display: flex;
      gap: 0.5rem;
      max-width: 380px;
      margin: 0 auto 0.75rem;
      position: relative;
      z-index: 1;
    }

    .cta-input {
      flex: 1;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px;
      padding: 0.7rem 1rem;
      color: white;
      font-family: var(--font-sans);
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .cta-input::placeholder { color: rgba(255,255,255,0.3); }
    .cta-input:focus { border-color: rgba(255,255,255,0.4); }

    .cta-btn {
      background: white;
      color: var(--ink);
      border: none;
      border-radius: 8px;
      padding: 0.7rem 1.25rem;
      font-family: var(--font-sans);
      font-size: 0.875rem;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: opacity 0.15s;
    }

    .cta-btn:hover { opacity: 0.88; }

    .cta-micro {
      font-size: 0.75rem;
