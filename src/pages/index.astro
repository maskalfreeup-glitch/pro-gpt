.discord-big-card {
  background: var(--bg1);
  border: 1px solid rgba(88,101,242,.25);
  border-radius: var(--r3);
  overflow: hidden;
  display: grid;
  grid-template-columns: 280px 1fr;
  min-height: 200px;
  transition: border-color .18s, box-shadow .18s;
  cursor: pointer;
}
.discord-big-card:hover {
  border-color: rgba(88,101,242,.5);
  box-shadow: 0 8px 48px rgba(88,101,242,.12);
}

.discord-thumb {
  background: linear-gradient(135deg, #3c3f96, #23264a);
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.discord-thumb::before {
  content: "";
  position: absolute; inset: 0;
  background: radial-gradient(circle at 40% 40%, rgba(88,101,242,.4), transparent 70%);
}
.discord-logo-big {
  font-size: 56px; position: relative; z-index: 1;
  filter: drop-shadow(0 4px 20px rgba(88,101,242,.5));
}
.discord-thumb-badge {
  position: absolute; top: 14px; left: 14px; z-index: 2;
  padding: 4px 10px; border-radius: 20px;
  background: rgba(34,197,94,.15); color: #4ade80; border: 1px solid rgba(34,197,94,.2);
  font-size: 10.5px; font-weight: 600;
  display: flex; align-items: center; gap: 5px;
}
.live-dot {
  width: 6px; height: 6px; border-radius: 50%; background: #4ade80;
  animation: livepulse 1.8s ease-in-out infinite;
}
@keyframes livepulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.4)} }

.discord-info {
  padding: 24px 28px; display: flex; flex-direction: column;
}
.discord-platform-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.dc-chip {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 9px; border-radius: 20px;
  background: rgba(88,101,242,.1); border: 1px solid rgba(88,101,242,.2);
  font-size: 11px; color: #7289da; font-family: var(--m);
}
.discord-title {
  font-size: 20px; font-weight: 700; letter-spacing: -.4px;
  color: var(--white); margin-bottom: 8px;
}
.discord-desc {
  font-size: 13.5px; color: var(--gray5); line-height: 1.65; margin-bottom: 16px; flex: 1;
}
.discord-channels {
  display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 18px;
}
.dc-channel-pill {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 4px 10px; border-radius: 20px;
  background: rgba(88,101,242,.08); border: 1px solid rgba(88,101,242,.15);
  font-size: 12px; color: #7289da; font-family: var(--m);
}
.dc-channel-pill::before { content: "#"; opacity: .5; }
.discord-footer {
  display: flex; align-items: center; justify-content: space-between;
}
.dc-member-count {
  display: flex; align-items: center; gap: 8px;
}
.dc-online-pip { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; box-shadow: 0 0 6px #4ade80; }
.dc-count-text { font-size: 13px; color: var(--gray5); }
.dc-count-text strong { color: var(--gray3); font-weight: 600; }
.dc-join-big {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 22px; border-radius: 20px;
  background: var(--discord); color: #fff; border: none;
  font-size: 13.5px; font-weight: 600;
  cursor: pointer; text-decoration: none;
  transition: opacity .15s, transform .15s;
}
.dc-join-big:hover { opacity: .9; transform: scale(1.02); }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   AUDIT DASHBOARD PAGE
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
#page-audit { padding: 40px 0 80px; }
.audit-page-header { margin-bottom: 28px; }
.audit-page-header h1 {
  font-size: 32px; font-weight: 800; letter-spacing: -1.2px;
  color: var(--white); margin-bottom: 6px;
}
.audit-page-header p { font-size: 14px; color: var(--gray5); max-width: 460px; line-height: 1.65; }

/* dashboard shell */
.dash {
  background: var(--bg1); border: 1px solid var(--line);
  border-radius: var(--r4); overflow: hidden;
}
.dash-titlebar {
  background: var(--bg2); border-bottom: 1px solid var(--line);
  padding: 12px 18px;
  display: flex; align-items: center; justify-content: space-between;
}
.dash-win-btns { display: flex; gap: 6px; }
.dwb { width: 11px; height: 11px; border-radius: 50%; }
.dwb-r { background: #ff5f57; }
.dwb-y { background: #febb2c; }
.dwb-g { background: #2bc840; }
.dash-title-text { font-family: var(--m); font-size: 11.5px; color: var(--gray6); letter-spacing: .5px; }
.dash-status { display: flex; align-items: center; gap: 6px; font-family: var(--m); font-size: 11px; color: #4ade80; }
.dash-status::before { content:""; width:6px;height:6px;border-radius:50%;background:#4ade80;box-shadow:0 0 5px #4ade80; animation:livepulse 2s ease-in-out infinite; }

.dash-input-area { padding: 20px; display: flex; gap: 10px; }
.dash-url-row {
  flex: 1; display: flex; align-items: center;
  background: #000; border: 1px solid var(--line2); border-radius: var(--r2);
  transition: border-color .18s; overflow: hidden;
}
.dash-url-row:focus-within { border-color: rgba(255,255,255,.25); }
.dash-prefix {
  padding: 0 12px; font-family: var(--m); font-size: 12.5px; color: var(--gray6);
  border-right: 1px solid var(--line); white-space: nowrap;
  height: 44px; display: flex; align-items: center; flex-shrink: 0;
}
.dash-url-row input {
  flex:1; background:transparent;border:none;outline:none;
  padding:12px; color:var(--white); font-family:var(--m); font-size:13px;
}
.dash-url-row input::placeholder { color: var(--gray6); }
.dash-go-btn {
  padding: 11px 22px; background: var(--white); color: var(--black);
  border: none; border-radius: var(--r2); font-size: 13.5px; font-weight: 600;
  cursor: pointer; white-space: nowrap; transition: background .15s, transform .1s;
  display: flex; align-items: center; gap: 7px;
}
.dash-go-btn:hover { background: var(--gray2); }
.dash-go-btn:active { transform: scale(.97); }
.dash-go-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }

/* dash panels */
.dash-panels {
  border-top: 1px solid var(--line);
  display: grid; grid-template-columns: 260px 1fr;
  gap: 1px; background: var(--line);
}
.dp { background: var(--bg1); padding: 20px; }
.dp-hd {
  font-family: var(--m); font-size: 10px; color: var(--gray6);
  letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;
  display: flex; justify-content: space-between;
}
.dp-hd span { color: var(--gray4); }

/* score */
.score-big-num { font-size: 68px; font-weight: 800; letter-spacing: -5px; line-height: 1; }
.score-denom   { font-family: var(--m); font-size: 18px; color: var(--gray6); }
.score-tag {
  display: inline-flex; align-items: center;
  padding: 4px 10px; border-radius: 20px; margin-top: 10px;
  font-family: var(--m); font-size: 10px; letter-spacing: 1px;
}
.tag-crit { background: rgba(239,68,68,.1); color: #f87171; border:1px solid rgba(239,68,68,.2); }
.tag-low  { background: rgba(234,179,8,.08); color: #fbbf24; border:1px solid rgba(234,179,8,.18); }
.tag-mid  { background: rgba(255,255,255,.06); color: var(--gray3); border:1px solid var(--line2); }
.tag-ok   { background: rgba(34,197,94,.08); color: #4ade80; border:1px solid rgba(34,197,94,.18); }

.score-rows { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
.score-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 10px; background: var(--bg2); border-radius: var(--r);
  border: 1px solid var(--line);
}
.sr-k { font-family: var(--m); font-size: 10px; color: var(--gray6); letter-spacing: .5px; }
.sr-v { font-family: var(--m); font-size: 11px; font-weight: 500; }
.sr-v.bad  { color: #f87171; }
.sr-v.warn { color: #fbbf24; }
.sr-v.ok   { color: #4ade80; }

/* issues */
.issue-items { display: flex; flex-direction: column; gap: 8px; }
.ii {
  display: flex; align-items: flex-start; gap: 9px;
  padding: 10px 12px; background: var(--bg2); border-radius: var(--r);
  border: 1px solid var(--line); animation: issueFade .3s ease both;
}
@keyframes issueFade { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:none} }
.ii-icon { font-family: var(--m); font-size: 12px; flex-shrink:0; margin-top:1px; }
.ii-icon.err  { color:#f87171 }
.ii-icon.warn { color:#fbbf24 }
.ii-icon.ok   { color:#4ade80 }
.ii-text { font-size:12.5px; line-height:1.5; }
.ii-text strong { color:var(--white); display:block; font-size:12px; margin-bottom:2px; }
.ii-text span   { color:var(--gray5); }

/* report */
.dp.report { grid-column: 1/-1; border-top: 1px solid var(--line); }
.report-text {
  font-family: var(--m); font-size: 12px; color: var(--gray5);
  line-height: 1.85; max-height: 240px; overflow-y: auto;
}
.report-text::-webkit-scrollbar { width:3px }
.report-text::-webkit-scrollbar-thumb { background:var(--line2); border-radius:10px }
.rpt-h { color:var(--white); font-weight:500; font-size:11px; letter-spacing:1.5px; margin:14px 0 6px; }
.rpt-h:first-child { margin-top:0 }
.rpt-b { display:flex; gap:8px; padding:2.5px 0; }
.rpt-b::before { content:"â†’"; color:var(--gray6); flex-shrink:0 }
.rpt-b.bad::before  { content:"âœ—"; color:#f87171 }
.rpt-b.warn::before { content:"â–³"; color:#fbbf24 }
.rpt-b.ok::before   { content:"âœ“"; color:#4ade80 }

/* terminal */
.dp.terminal { grid-column:1/-1; background:#000; }
.term-scroll { height:160px; overflow-y:auto; }
.term-scroll::-webkit-scrollbar { width:2px }
.term-scroll::-webkit-scrollbar-thumb { background:var(--line); border-radius:10px }
.t-line { display:flex; gap:10px; padding:2.5px 0; animation:issueFade .2s ease; }
.t-ts  { color:var(--gray6); font-family:var(--m); font-size:11px; flex-shrink:0; }
.t-msg { font-family:var(--m); font-size:11px; }
.t-dim  { color:var(--gray6) }
.t-inf  { color:var(--gray4) }
.t-ok   { color:#4ade80 }
.t-warn { color:#fbbf24 }
.prog-track { height:2px; background:var(--bg3); border-radius:10px; overflow:hidden; margin-top:14px; }
.prog-fill  { height:100%; width:0%; background:var(--white); border-radius:10px; transition:width .12s linear; }
.prog-meta  { display:flex; justify-content:space-between; margin-top:6px; }
.prog-meta span { font-family:var(--m); font-size:10px; color:var(--gray6); }

/* empty + cta */
.dash-empty {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:56px 24px 60px; gap:14px; text-align:center;
  border-top: 1px solid var(--line);
  min-height: 260px;
  background: radial-gradient(ellipse at 50% 60%, rgba(255,255,255,.02) 0%, transparent 70%);
}
.empty-icon {
  width:56px;height:56px;border-radius:14px;
  background:var(--bg3);border:1px solid var(--line3);
  display:flex;align-items:center;justify-content:center;
  position:relative;
  box-shadow: 0 0 0 6px rgba(255,255,255,.03);
}
.empty-icon::after {
  content:"";position:absolute;inset:-6px;border-radius:20px;
  border:1px solid var(--line);
  animation:emptyRing 3s ease-in-out infinite;
  opacity:0;
}
@keyframes emptyRing { 0%{opacity:0;transform:scale(.9)} 50%{opacity:1} 100%{opacity:0;transform:scale(1.05)} }
.empty-ttl { font-size:16px;font-weight:700;color:var(--white); }
.empty-sub { font-size:13px;color:var(--gray5);max-width:300px;line-height:1.6; }

.dash-cta-bar {
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 20px; border-top:1px solid var(--line); background:var(--bg2);
  flex-wrap:wrap; gap:10px;
}
.dash-cta-note { font-family:var(--m);font-size:11.5px;color:var(--gray6); }
.dash-cta-note a { color:var(--gray4);text-decoration:none; }
.dash-cta-note a:hover { color:var(--white); }
.dash-cta-btns { display:flex;gap:8px;align-items:center; }
.dcb {
  padding:7px 16px;border-radius:20px;font-size:13px;font-weight:600;
  cursor:pointer;text-decoration:none;border:1px solid var(--line2);
  color:var(--gray3);background:transparent;transition:all .15s;
}
.dcb:hover { border-color:var(--line3);color:var(--white);background:var(--bg2); }
.dcb.p { background:var(--white);color:var(--black);border-color:var(--white); }
.dcb.p:hover { background:var(--gray2); }
.dcb-reset { background:none;border:none;cursor:pointer;font-family:var(--m);font-size:11px;color:var(--gray6);transition:color .15s; }
.dcb-reset:hover { color:var(--gray3); }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   BLOG PAGE
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
#page-blog { padding:40px 0 80px; }
.blog-hd { margin-bottom:28px; }
.blog-hd h1 { font-size:32px;font-weight:800;letter-spacing:-1.2px;color:var(--white);margin-bottom:6px; }
.blog-hd p  { font-size:14px;color:var(--gray5);max-width:440px;line-height:1.65; }
.blog-controls { display:flex;align-items:center;gap:10px;margin-bottom:24px;flex-wrap:wrap; }
.blog-search-wrap {
  display:flex;align-items:center;gap:8px;
  background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:0 14px;
}
.blog-search-wrap input {
  background:transparent;border:none;outline:none;padding:10px 0;
  font-family:var(--m);font-size:12.5px;color:var(--white);min-width:180px;
}
.blog-search-wrap input::placeholder { color:var(--gray6); }
.blog-search-wrap span { color:var(--gray6); }
.blog-cats { display:flex;gap:6px;flex-wrap:wrap; }
.bcat {
  padding:6px 14px;border-radius:20px;border:1px solid var(--line2);
  font-size:13px;font-weight:500;color:var(--gray5);background:transparent;
  cursor:pointer;transition:all .15s;
}
.bcat:hover { border-color:var(--line3);color:var(--gray2); }
.bcat.active { background:var(--white);color:var(--black);border-color:var(--white); }

.blog-feat { margin-bottom:20px; }
.blog-feat .bpc {
  display:grid;grid-template-columns:380px 1fr;min-height:260px;
}
.blog-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:14px; }
.bpc {
  background:var(--bg1);border:1px solid var(--line);border-radius:var(--r3);
  overflow:hidden;transition:all .2s;cursor:pointer;
}
.bpc:hover { border-color:var(--line3);transform:translateY(-2px); }
.bpc-img {
  display:flex;align-items:center;justify-content:center;
  font-size:36px;position:relative;overflow:hidden;
}
.blog-feat .bpc-img { height:100%;min-height:260px;font-size:48px; }
.bpc:not(.feat-card) .bpc-img { height:160px; }
.bpc-glow { position:absolute;width:100px;height:100px;border-radius:50%;filter:blur(30px);opacity:.25; }
.bpc-body { padding:22px; }
.bpc-cat { font-family:var(--m);font-size:10px;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px; }
.bpc-cat.geo     { color:#818cf8 }
.bpc-cat.tactics { color:#4ade80 }
.bpc-cat.tools   { color:#fbbf24 }
.bpc-cat.case    { color:#f87171 }
.bpc-title { font-size:17px;font-weight:700;letter-spacing:-.4px;color:var(--white);line-height:1.25;margin-bottom:8px; }
.blog-feat .bpc-title { font-size:22px; }
.bpc-excerpt { font-family:var(--m);font-size:12px;color:var(--gray5);line-height:1.7;margin-bottom:14px; }
.bpc-meta { display:flex;align-items:center;gap:8px;font-family:var(--m);font-size:11px;color:var(--gray6); }
.bpc-dot { width:3px;height:3px;border-radius:50%;background:var(--gray6); }
.bpc-tags { display:flex;gap:6px;flex-wrap:wrap;margin-top:10px; }
.bpc-tag { font-family:var(--m);font-size:10px;color:var(--gray6);background:var(--bg2);border:1px solid var(--line);border-radius:4px;padding:2px 7px; }

.pseo-block { margin-top:48px; }
.pseo-hd { font-size:18px;font-weight:700;letter-spacing:-.4px;color:var(--white);margin-bottom:6px; }
.pseo-sub { font-family:var(--m);font-size:12px;color:var(--gray6);margin-bottom:16px; }
.pseo-pills { display:flex;flex-wrap:wrap;gap:8px; }
.pseo-pill {
  padding:7px 14px;border-radius:var(--r2);background:var(--bg1);border:1px solid var(--line);
  font-family:var(--m);font-size:12px;color:var(--gray5);cursor:pointer;transition:all .15s;
}
.pseo-pill:hover { border-color:var(--line3);color:var(--white);background:var(--bg2); }
.pseo-slug { color:var(--gray6);font-size:10px;display:block;margin-bottom:3px; }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   ABOUT PAGE
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
#page-about { padding:40px 0 80px; }
.about-split { display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;margin-bottom:60px; }
.about-left h1 { font-size:clamp(30px,5vw,52px);font-weight:800;letter-spacing:-2px;color:var(--white);line-height:.92;margin-bottom:16px; }
.about-left p  { font-size:14px;color:var(--gray5);line-height:1.7; }
.about-left p+p{ margin-top:12px; }
.about-right {
  background:var(--bg1);border:1px solid var(--line);border-radius:var(--r3);padding:28px;
}
.ar-label { font-family:var(--m);font-size:10px;color:var(--gray6);letter-spacing:2px;text-transform:uppercase;margin-bottom:20px; }
.av-row { display:flex;align-items:center;justify-content:space-between;margin-bottom:14px; }
.av-key { font-family:var(--m);font-size:12px;color:var(--gray5); }
.av-bar-wrap { flex:1;max-width:140px;height:3px;background:var(--bg3);border-radius:10px;overflow:hidden;margin:0 12px; }
.av-bar { height:100%;border-radius:10px; }
.av-val { font-family:var(--m);font-size:11px;color:var(--gray3);width:28px;text-align:right; }
.about-values { display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:48px; }
.aval { background:var(--bg1);border:1px solid var(--line);border-radius:var(--r3);padding:22px; }
.aval-icon { font-size:20px;margin-bottom:12px; }
