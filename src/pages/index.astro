<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ProGPT — AI Visibility Engine</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#050505;
  --card:#0b0f14;
  --border:#1a1f26;
  --accent:#00ff9f;
  --text:#e6edf3;
  --muted:#7d8590;
  --danger:#ff4d4d;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:Inter,sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* GRID BACKGROUND */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size:48px 48px;
  z-index:-1;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:16px 24px;
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(10px);
  position:sticky;
  top:0;
  background:rgba(5,5,5,0.8);
}

.logo{font-weight:900;letter-spacing:-1px}

.nav-cta{
  background:var(--accent);
  color:#000;
  padding:8px 14px;
  border-radius:8px;
  font-weight:700;
  text-decoration:none;
  font-size:13px;
}

/* LAYOUT */
.container{
  max-width:900px;
  margin:auto;
  padding:80px 20px;
}

/* HERO */
h1{
  font-size:clamp(44px,8vw,76px);
  line-height:0.9;
  letter-spacing:-3px;
  margin:0;
}

h1 span{color:var(--accent)}

.sub{
  margin-top:20px;
  color:var(--muted);
  font-size:18px;
  max-width:520px;
}

/* CARD */
.card{
  background:linear-gradient(180deg,#0b0f14,#06080b);
  border:1px solid var(--border);
  border-radius:18px;
  padding:28px;
  margin-top:28px;
  backdrop-filter:blur(8px);
}

/* INPUT */
input{
  width:100%;
  padding:18px;
  border-radius:12px;
  border:1px solid var(--border);
  background:#000;
  color:#fff;
  font-size:16px;
}

/* BUTTON */
.btn{
  width:100%;
  padding:18px;
  margin-top:14px;
  border:none;
  border-radius:12px;
  font-weight:900;
  background:var(--accent);
  color:#000;
  font-size:16px;
  cursor:pointer;
}

.btn-alt{
  display:block;
  margin-top:10px;
  padding:14px;
  border:1px solid var(--border);
  border-radius:12px;
  text-align:center;
  color:var(--muted);
  text-decoration:none;
  font-size:13px;
}

/* SCAN */
#scan,#result{display:none}

.log{
  font-family:monospace;
  color:var(--accent);
  font-size:12px;
}

.bar-bg{
  height:4px;
  background:#111;
  margin-top:14px;
  border-radius:10px;
  overflow:hidden;
}

#bar{
  height:100%;
  width:0%;
  background:var(--accent);
  box-shadow:0 0 10px var(--accent);
}

/* RESULT */
.badge{
  background:rgba(255,0,0,0.1);
  color:var(--danger);
  padding:6px 10px;
  border-radius:6px;
  font-size:11px;
  display:inline-block;
  margin-top:10px;
}

ul{color:var(--accent);font-weight:600}

/* FAQ */
.faq-item{
  border-top:1px solid var(--border);
  padding:14px 0;
  cursor:pointer;
}

.faq-a{
  display:none;
  color:#aaa;
  margin-top:8px;
  font-size:14px;
}

.faq-item.active .faq-a{display:block}

/* BLOG GRID */
.blog{
  display:grid;
  gap:12px;
  margin-top:20px;
}

.blog a{
  display:block;
  padding:16px;
  border:1px solid var(--border);
  border-radius:12px;
  color:#ccc;
  text-decoration:none;
  transition:0.2s;
}

.blog a:hover{
  border-color:var(--accent);
  color:#fff;
}
</style>
</head>

<body>

<nav>
  <div class="logo">PROGPT</div>
  <a href="https://whop.com/progpt" class="nav-cta">GET ACCESS</a>
</nav>

<div class="container">

<h1>AI is already <span>choosing</span> your competitors.</h1>
<p class="sub">
Search is dead. AI answers decide winners now.
If you're not in those answers, you're invisible.
</p>

<!-- INPUT -->
<div class="card" id="inputBox">
  <input id="url" placeholder="yourwebsite.com">
  <button class="btn" onclick="run()">Run free audit →</button>
</div>

<!-- SCAN -->
<div id="scan" class="card">
  <div id="log" class="log">Initializing scan...</div>
  <div class="bar-bg"><div id="bar"></div></div>
</div>

<!-- RESULT -->
<div id="result">

<div class="card">
  <h3>Score: <span id="score"></span>/10</h3>
  <div class="badge">LOW AI TRUST</div>

  <ul id="competitors"></ul>

  <p id="loss" style="color:var(--danger);font-weight:700;margin-top:10px"></p>
</div>

<div class="card">
  <h3>The AI Gap</h3>
  <div id="faq"></div>
</div>

<div class="card">
  <h3>Reclaim your visibility</h3>
  <input placeholder="your@email.com">
  <button class="btn" onclick="window.location.href='https://whop.com/progpt'">
    Fix this → $297
  </button>
  <a href="#" class="btn-alt">Join free Discord</a>
</div>

</div>

<!-- BLOG -->
<div class="card">
  <h3>Learn how AI ranks businesses</h3>
  <div class="blog">
    <a href="#">How ChatGPT Chooses Businesses</a>
    <a href="#">GEO vs SEO Explained</a>
    <a href="#">Why You're Not Showing in AI</a>
  </div>
</div>

</div>

<script>
function run(){
  let url=document.getElementById("url").value;
  if(!url.includes(".")) return alert("enter valid domain");

  inputBox.style.display="none";
  scan.style.display="block";

  let logs=["Scanning...","Analyzing AI signals...","Checking competitors...","Finalizing..."];
  let w=0,i=0;

  let int=setInterval(()=>{
    w+=2;
    bar.style.width=w+"%";

    if(w%25===0 && i<logs.length){
      log.innerText=logs[i++];
    }

    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },40);
}

function show(url){
  scan.style.display="none";
  result.style.display="block";

  score.innerText=(1.5+Math.random()*2).toFixed(1);

  let clean=url.split('.')[0];
  let prefixes=["top-","best-","get-"];

  competitors.innerHTML="";
  prefixes.forEach(p=>{
    let li=document.createElement("li");
    li.innerText=p+clean+".com";
    competitors.appendChild(li);
  });

  let lost=Math.floor(Math.random()*20+12);
  loss.innerText="Estimated loss: "+lost+"–"+(lost+10)+" leads/month";

  renderFAQ();
}

function renderFAQ(){
  let data=[
    ["Why am I invisible?","AI cannot verify your authority signals."],
    ["What does that mean?","Your competitors have stronger structured data."],
    ["Am I losing customers?","Yes, before they even reach Google."],
    ["Fix?","We rebuild your AI visibility layer."]
  ];

  faq.innerHTML="";

  data.forEach(q=>{
    let d=document.createElement("div");
    d.className="faq-item";
    d.innerHTML=`<strong>${q[0]}</strong><div class="faq-a">${q[1]}</div>`;
    d.onclick=()=>d.classList.toggle("active");
    faq.appendChild(d);
  });
}
</script>

</body>
</html>