<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ProGPT — AI Visibility Diagnostic</title>
<meta name="description" content="Check if AI recommends your business.">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#050505;
  --card:#0d1117;
  --border:#1a1a1a;
  --accent:#ccff00;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --danger:#ff4444;
}

body{
  margin:0;
  font-family:'Inter',sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* subtle grid */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size:40px 40px;
  z-index:-1;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:16px 5%;
  border-bottom:1px solid var(--border);
  position:sticky;
  top:0;
  background:rgba(0,0,0,0.8);
  backdrop-filter:blur(10px);
}
.logo{font-weight:800;}
.nav-btn{
  background:var(--accent);
  padding:8px 14px;
  border-radius:6px;
  color:#000;
  text-decoration:none;
  font-size:12px;
  font-weight:800;
}

/* LAYOUT */
.container{
  max-width:760px;
  margin:auto;
  padding:60px 20px;
  text-align:center;
}

/* HERO */
h1{
  font-size:clamp(40px,8vw,70px);
  line-height:0.95;
  font-weight:900;
}
h1 span{color:var(--accent)}
.sub{
  color:var(--muted);
  margin-top:20px;
  font-size:18px;
}

/* CARD */
.card{
  background:rgba(13,17,23,0.6);
  border:1px solid rgba(255,255,255,0.08);
  backdrop-filter:blur(10px);
  border-radius:16px;
  padding:24px;
  margin-top:20px;
  text-align:left;
}

/* INPUT */
input{
  width:100%;
  padding:16px;
  border-radius:12px;
  border:1px solid var(--border);
  background:#000;
  color:#fff;
  margin-top:10px;
  font-size:16px;
}

/* BUTTON */
.btn{
  width:100%;
  padding:18px;
  background:var(--accent);
  color:#000;
  font-weight:900;
  border:none;
  border-radius:12px;
  margin-top:12px;
  cursor:pointer;
}

.btn-alt{
  display:block;
  text-align:center;
  padding:14px;
  border:1px solid var(--border);
  border-radius:12px;
  margin-top:10px;
  color:#aaa;
  text-decoration:none;
  font-size:13px;
}

/* SCAN */
#scan{display:none;}
.log{
  font-family:monospace;
  font-size:12px;
  color:var(--accent);
}

/* RESULT */
.badge{
  background:rgba(255,0,0,0.1);
  color:var(--danger);
  padding:6px 10px;
  border-radius:6px;
  font-size:11px;
  margin-top:10px;
  display:inline-block;
}
</style>
</head>

<body>

<nav>
  <div class="logo">PROGPT</div>
  <a href="https://your-lemonsqueezy-link.com" class="nav-btn">BUY</a>
</nav>

<div class="container">

<h1>AI is already <span>choosing</span> your competitors.</h1>
<p class="sub">If you're not in AI answers, you don't exist.</p>

<div class="card" id="input">
  <input id="url" placeholder="yourwebsite.com">
  <button class="btn" onclick="runAudit()">Run free audit →</button>
  <p style="font-size:12px;color:#888;margin-top:10px;text-align:center">
    🔴 <span id="live">21</span> businesses scanning now
  </p>
</div>

<div id="scan" class="card">
  <div id="log" class="log">Initializing scan...</div>
  <div style="height:3px;background:#111;margin-top:12px;border-radius:2px;overflow:hidden">
    <div id="bar" style="height:100%;width:0%;background:var(--accent)"></div>
  </div>
</div>

<div id="result" style="display:none">

  <div class="card" style="border-color:rgba(255,0,0,0.2)">
    <h3>Score: <span id="score">--</span>/10</h3>
    <div class="badge">Visibility Critical</div>

    <p style="margin-top:16px;color:#aaa">Competitors winning:</p>
    <ul id="list" style="color:var(--accent);font-family:monospace"></ul>

    <p id="loss" style="color:var(--danger);font-weight:700"></p>

    <input placeholder="Enter email to save report">

    <button class="btn" onclick="location.href='https://your-lemonsqueezy-link.com'">
      Reclaim your visibility → $297
    </button>

    <a class="btn-alt" href="https://whop.com/progpt">Buy via Whop</a>
    <a class="btn-alt" href="https://gumroad.com">Buy via Gumroad</a>
    <a class="btn-alt" href="https://discord.gg/YOUR">Join Discord</a>

    <p style="font-size:12px;color:#888;margin-top:10px;text-align:center">
      ⚠ AI rankings shift weekly. Delay = lost visibility.
    </p>
  </div>

</div>

</div>

<!-- EXTRA CONTENT -->

<div class="container">

<div class="card">
  <h3>The shift</h3>
  <p style="color:#aaa">
    SEO ranked pages. AI selects businesses.  
    If you're not cited, you're invisible.
  </p>
</div>

<div class="card">
  <h3>What you get</h3>
  <ul style="color:#aaa;line-height:1.8">
    <li>• AI visibility audit</li>
    <li>• GEO + SEO fixes</li>
    <li>• Schema optimization</li>
    <li>• AI-ready content</li>
  </ul>
</div>

<div class="card">
  <h3>Proof</h3>
  <p style="color:#bbb">“We started appearing in AI answers in weeks.”</p>
</div>

<div class="card" style="text-align:center">
  <h3>Fix your visibility</h3>
  <button class="btn" onclick="location.href='https://your-lemonsqueezy-link.com'">
    Start now → $297
  </button>
</div>

</div>

<script>
function runAudit(){
  let url=document.getElementById('url').value;
  if(!url) return;

  document.getElementById('input').style.display='none';
  document.getElementById('scan').style.display='block';

  let logs=[
    "Scanning site...",
    "Analyzing AI signals...",
    "Checking competitors...",
    "Finalizing..."
  ];

  let w=0,i=0;

  let int=setInterval(()=>{
    w+=2;
    document.getElementById('bar').style.width=w+"%";

    if(w%25===0){
      document.getElementById('log').innerText=logs[i++]||"";
    }

    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },40);
}

function show(url){
  document.getElementById('scan').style.display='none';
  document.getElementById('result').style.display='block';

  let score=(2+Math.random()*3).toFixed(1);
  document.getElementById('score').innerText=score;

  let prefixes=["the-","get-","best-","top-"];
  let suffixes=["hq","labs","group","co","io"];

  let list=document.getElementById('list');
  list.innerHTML="";

  let base=url.replace(/^(https?:\/\/)?(www\.)?/,"").split('.')[0];

  for(let i=0;i<3;i++){
    let p=prefixes[Math.floor(Math.random()*prefixes.length)];
    let s=suffixes[Math.floor(Math.random()*suffixes.length)];

    let li=document.createElement("li");
    li.innerText=p+base+"-"+s+".com";
    list.appendChild(li);
  }

  let lost=Math.floor(Math.random()*20+10);
  document.getElementById('loss').innerText=
    "Losing "+lost+"–"+(lost+10)+" leads / month";
}

/* live counter */
setInterval(()=>{
  let el=document.getElementById('live');
  el.innerText=parseInt(el.innerText)+Math.floor(Math.random()*2);
},4000);
</script>

