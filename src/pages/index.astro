---
const title = "AI Visibility Engine";
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#f7f6f3;
  --card:#ffffff;
  --border:#e8e8e3;
  --ink:#1a1a18;
  --muted:#6b6b63;
  --danger:#de350b;
}

body{
  margin:0;
  font-family:'Geist',sans-serif;
  background:var(--bg);
  color:var(--ink);
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:14px 20px;
  border-bottom:1px solid var(--border);
}

.logo{font-weight:600}
.nav a{
  margin-left:16px;
  text-decoration:none;
  color:var(--muted);
  font-size:14px;
}

/* HERO */
.hero{
  max-width:640px;
  margin:60px auto;
  padding:0 20px;
}

h1{
  font-family:'Instrument Serif',serif;
  font-size:clamp(36px,6vw,56px);
  line-height:1.05;
  margin:0;
}

.sub{
  margin-top:10px;
  color:var(--muted);
  font-size:16px;
}

/* MACHINE */
.machine{
  margin-top:24px;
  border:1px solid var(--border);
  border-radius:12px;
  background:var(--card);
  padding:14px;
}

/* INPUT */
.input{
  display:flex;
  border:1px solid var(--border);
  border-radius:8px;
  overflow:hidden;
}

input{
  flex:1;
  border:none;
  padding:14px;
  font-size:15px;
  background:#fafafa;
}

button{
  border:none;
  background:var(--ink);
  color:#fff;
  padding:14px 16px;
  font-weight:600;
  cursor:pointer;
}

/* SYSTEM TEXT */
.status{
  margin-top:10px;
  font-size:12px;
  color:var(--muted);
  font-family:monospace;
}

.log{
  margin-top:4px;
  font-size:12px;
  color:#888;
  font-family:monospace;
}

/* SCAN */
#scan,#result,#gate{display:none;}

.bar-bg{
  height:3px;
  background:#eee;
  margin-top:10px;
}

.bar{
  height:100%;
  width:0%;
  background:var(--ink);
}

/* RESULT */
.result{
  margin-top:12px;
  padding:12px;
  background:#fafafa;
  border-radius:8px;
  font-size:14px;
}

.score{
  font-size:24px;
  font-weight:700;
}

.bad{
  color:var(--danger);
  margin-top:4px;
}

ul{
  padding-left:16px;
  color:var(--danger);
}

/* GATE */
.gate{
  margin-top:12px;
}

footer{
  text-align:center;
  font-size:12px;
  color:var(--muted);
  padding:40px 0;
}
</style>
</head>

<body>

<nav>
  <div class="logo">AI Visibility</div>
  <div class="nav">
    <a href="/blog">Blog</a>
    <a href="https://discord.gg/progpt">Discord</a>
  </div>
</nav>

<div class="hero">

  <h1>
    AI already chose<br>
    your competitors.
  </h1>

  <p class="sub">
    This system checks if you exist in AI answers.
  </p>

  <div class="machine">

    <div id="inputBox" class="input">
      <input id="url" placeholder="enter domain">
      <button onclick="run()">run</button>
    </div>

    <div id="status" class="status">
      AI index: active • waiting input
    </div>

    <div id="log" class="log">
      system idle
    </div>

    <div id="scan">
      <div class="bar-bg"><div id="bar" class="bar"></div></div>
    </div>

    <div id="result" class="result">
      <div class="score"><span id="score"></span>/10</div>
      <div class="bad">not present in AI answers</div>

      <div style="margin-top:10px;">
        competitors:
        <ul id="competitors"></ul>
      </div>
    </div>

    <div id="gate" class="gate">
      <input id="email" placeholder="email to unlock full report">
      <button onclick="unlock()">unlock →</button>
    </div>

  </div>

</div>

<footer>
© {year}
</footer>

<script is:inline>
let scans = localStorage.getItem("scans") || 0;

function run(){
  let url=document.getElementById("url").value;
  if(!url.includes(".")) return;

  if(scans >= 3){
    window.location.href="https://whop.com/progpt";
    return;
  }

  scans++;
  localStorage.setItem("scans", scans);

  document.getElementById("scan").style.display="block";
  document.getElementById("status").innerText="analyzing AI layer...";
  
  let logs=[
    "mapping entities...",
    "checking citations...",
    "evaluating ranking...",
    "finalizing..."
  ];

  let w=0;
  let i=0;

  let int=setInterval(()=>{
    w+=5;
    document.getElementById("bar").style.width=w+"%";

    if(w % 25 === 0 && i < logs.length){
      document.getElementById("log").innerText=logs[i++];
    }

    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },40);
}

function show(url){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(1+Math.random()*2).toFixed(1);
  document.getElementById("score").innerText=score;

  let clean=url.split('.')[0];
  let list=document.getElementById("competitors");
  list.innerHTML="";

  ["best"+clean+".com","try"+clean+".co","top"+clean+".io"].forEach(c=>{
    let li=document.createElement("li");
    li.innerText=c;
    list.appendChild(li);
  });

  setTimeout(()=>{
    document.getElementById("gate").style.display="block";
  },1000);
}

function unlock(){
  let email=document.getElementById("email").value;
  if(!email.includes("@")) return;

  window.location.href="https://whop.com/progpt";
}
</script>

</body>
</html>