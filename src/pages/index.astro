---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ProGPT — AI Visibility Engine">
  <main class="bg-[#04060a] min-h-screen text-[#dde4ee] font-sans">
    <section class="pt-32 pb-20 px-6 border-b border-[#151c27]">
      <div class="max-w-4xl mx-auto">
        <div class="font-mono text-[11px] text-[#00e5ff] tracking-[0.2em] mb-6 flex items-center gap-2">
          <span class="w-8 h-[1px] bg-[#00e5ff]"></span> LIVE AT PROGPT.STORE
        </div>
        <h1 class="text-7xl md:text-8xl font-black text-white tracking-tighter leading-none mb-6">
          <span class="line-through text-[#2a3444] decoration-[#ff3b3b]">Search</span> is dead.<br/>
          AI picks <span class="text-[#00e5ff] drop-shadow-[0_0_15px_rgba(0,229,255,0.4)]">winners</span> now.
        </h1>
        <p class="text-[#556070] text-xl max-w-lg font-light leading-relaxed mb-10">
          ChatGPT and Perplexity are deciding your brand's fate. Our GEO engine ensures you're the one they recommend.
        </p>
        <a href="#audit" class="inline-block bg-[#00e5ff] text-black px-8 py-4 rounded font-bold hover:bg-white transition-colors">Start Free Audit →</a>
      </div>
    </section>

    <section id="audit" class="py-24 px-6">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-16">
        <div>
          <h2 class="text-4xl font-bold text-white mb-6">The Vending Machine</h2>
          <p class="text-[#556070] mb-8">Input your domain. Our Cloudflare AI node audits your entity clarity across the LLM landscape in real-time.</p>
          <ul class="space-y-4 text-sm font-mono text-[#00ff9f]">
            <li>[✓] AI Trust Score Analysis</li>
            <li>[✓] Competitor Gap Mapping</li>
            <li>[✓] Automated Implementation Roadmap</li>
          </ul>
        </div>

        <div class="bg-[#080c12] border border-[#151c27] p-8 rounded-xl relative" id="vending-box">
          <div id="scan-form">
            <label class="block font-mono text-[10px] text-[#556070] uppercase mb-4 tracking-widest">// TARGET DOMAIN</label>
            <input type="text" id="target-url" placeholder="company.com" class="w-full bg-black border border-[#1e2836] p-4 rounded text-[#00e5ff] font-mono outline-none focus:border-[#00e5ff] mb-4" />
            <button id="run-scan" class="w-full bg-[#00e5ff] text-black py-4 font-bold rounded hover:opacity-90 transition-all">DECODE VISIBILITY</button>
          </div>

          <div id="audit-results" class="hidden">
            <div class="flex items-center justify-between mb-8">
              <span class="font-mono text-xs text-[#556070]">VISIBILITY_SCORE</span>
              <span id="final-score" class="text-5xl font-black text-[#ff3b3b]">--</span>
            </div>
            <div id="vending-cta">
              </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const scanBtn = document.getElementById('run-scan');
    const form = document.getElementById('scan-form');
    const results = document.getElementById('audit-results');
    const scoreDisplay = document.getElementById('final-score');
    const ctaContainer = document.getElementById('vending-cta');

    scanBtn.addEventListener('click', async () => {
      const domain = (document.getElementById('target-url') as HTMLInputElement).value;
      if (!domain) return;

      scanBtn.innerText = "QUERYING CLOUDFLARE AI...";
      
      const response = await fetch('/api/audit', {
        method: 'POST',
        body: JSON.stringify({ domain })
      });
      const data = await response.json();

      form.classList.add('hidden');
      results.classList.remove('hidden');
      scoreDisplay.innerText = data.score.toFixed(1);

      // Automated Vending Machine Logic
      if (data.score < 5) {
        ctaContainer.innerHTML = `
          <a href="https://lemonsqueezy.com/progpt" class="block w-full bg-[#ff3b3b] text-white py-4 text-center font-bold rounded mb-4">Fix Visibility ($297 Growth)</a>
          <p class="text-center font-mono text-[10px] text-[#556070]">Failing signals detected. LemonSqueezy checkout enabled.</p>
        `;
      } else {
        ctaContainer.innerHTML = `
          <a href="https://gumroad.com/progpt" class="block w-full bg-[#00ff9f] text-black py-4 text-center font-bold rounded mb-4">Scale Influence ($47 Starter)</a>
          <p class="text-center font-mono text-[10px] text-[#556070]">Moderate visibility found. Gumroad delivery ready.</p>
        `;
      }
    });
  </script>
</Layout>
