<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>ProGPT — AI Visibility Audit</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet"/>

<style>
:root{
  --bg:#050505;
  --card:#0f0f0f;
  --border:#1a1a1a;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --accent:#00ff88;
}

body{
  font-family:Inter,sans-serif;
  background:var(--bg);
  color:var(--text);
  margin:0;
}

/* CONTAINER */
.container{
  max-width:720px;
  margin:auto;
  padding:24px;
}

/* HERO */
h1{
  font-size:38px;
  line-height:1.1;
}

p{
  color:var(--muted);
  margin-top:8px;
}

/* CARD */
.card{
  background:var(--card);
  border:1px solid var(--border);
  padding:18px;
  border-radius:14px;
  margin-top:16px;
}

/* INPUT */
input{
  width:100%;
  padding:14px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#0b0b0b;
  color:white;
  margin-top:10px;
}

/* BUTTON */
button{
  margin-top:14px;
  width:100%;
  padding:14px;
  border-radius:10px;
  border:none;
  background:var(--accent);
  color:black;
  font-weight:600;
  cursor:pointer;
}

/* DISCORD CTA */
.discord{
  display:block;
  text-align:center;
  margin-top:14px;
  padding:14px;
  border-radius:10px;
  border:1px solid #5865f2;
  color:#8ea1ff;
  text-decoration:none;
}

/* SCAN */
.scan{ display:none; margin-top:20px; }

.loader{
  height:6px;
  background:#111;
  border-radius:6px;
  overflow:hidden;
  margin-top:10px;
}

.loader span{
  display:block;
  height:100%;
  width:0%;
  background:var(--accent);
  animation:scan 2.5s linear forwards;
}

@keyframes scan{
  0%{width:0%}
  100%{width:100%}
}

/* LIVE */
.live{
  font-size:13px;
  color:var(--muted);
  margin-top:10px;
}

.dot{
  width:8px;height:8px;background:var(--accent);
  display:inline-block;border-radius:50%;
  margin-right:6px;
}
</style>
</head>

<body>

<div class="container">

<h1>AI is already ranking your competitors.</h1>
<p>If you're not in AI answers, you're invisible.</p>

<div class="live">
<span class="dot"></span>
<span id="liveCount">17</span> audits running now
</div>

<!-- INPUT -->
<div id="step1" class="card">
<input id="website" placeholder="yourwebsite.com">
<button onclick="startScan()">Run free audit →</button>
</div>

<!-- SCAN -->
<div id="scan" class="scan">
<p id="scanText">Scanning your site…</p>
<div class="loader"><span></span></div>
</div>

<!-- RESULT -->
<div id="result" style="display:none;margin-top:20px">

<div class="card">

<h2 id="scoreText">Score: 3.1 / 10</h2>

<p style="margin-top:10px">
AI is not recommending your business.
</p>

<ul style="margin-top:10px;color:#aaa;font-size:14px">
<li>No structured AI signals</li>
<li>Weak authority footprint</li>
<li>Competitors dominating results</li>
</ul>

<p style="margin-top:10px">
Fix this → get full breakdown + execution plan inside Discord.
</p>

<input id="email" placeholder="Enter email to unlock audit">

<button onclick="saveLead()">Unlock full audit →</button>

<a href="https://whop.com/progpt" class="discord">
Enter Discord System (via Whop) →
</a>

</div>

</div>

<!-- VALUE -->
<div class="card">
<h3>What happens next</h3>
<p>• Full audit breakdown<br>
• GEO + SEO fixes<br>
• AI content strategy<br>
• Done-for-you execution</p>
</div>

</div>

<script>
function startScan(){
  document.getElementById("step1").style.display="none";
  document.getElementById("scan").style.display="block";

  let texts=[
    "Scanning website…",
    "Analyzing AI signals…",
    "Checking competitors…",
    "Evaluating ranking gaps…"
  ];

  let i=0;
  let interval=setInterval(()=>{
    document.getElementById("scanText").innerText=texts[i];
    i++;
    if(i>=texts.length) clearInterval(interval);
  },600);

  setTimeout(showResult,2600);
}

function showResult(){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(Math.random()*3+2).toFixed(1);
  document.getElementById("scoreText").innerText="Score: "+score+" / 10";
}

function saveLead(){
  let email=document.getElementById("email").value;

  let leads=JSON.parse(localStorage.getItem("leads")||"[]");
  leads.push({
    email,
    website:document.getElementById("website").value
  });

  localStorage.setItem("leads",JSON.stringify(leads));
}

/* LIVE COUNTER */
setInterval(()=>{
  let el=document.getElementById("liveCount");
  let num=parseInt(el.innerText);
  el.innerText=num+Math.floor(Math.random()*2);
},4000);
</script>

</body>
</html>