---
// Meta
const title = "AI Visibility Engine";
const description = "Check if AI recommends your business.";
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#f7f6f3;
  --card:#ffffff;
  --border:#e8e8e3;
  --ink:#1a1a18;
  --muted:#6b6b63;
  --accent:#2f54eb;
  --danger:#de350b;
}

*{box-sizing:border-box;}

body{
  margin:0;
  font-family:'Geist',sans-serif;
  background:var(--bg);
  color:var(--ink);
}

/* NAV */
nav{
  position:sticky;
  top:0;
  background:rgba(247,246,243,0.85);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
  padding:12px 20px;
  z-index:100;
}

.logo{font-weight:700;}

.nav-links a{
  margin-left:14px;
  text-decoration:none;
  color:var(--muted);
  font-size:14px;
}

/* HERO */
.hero{
  max-width:720px;
  margin:80px auto 40px;
  text-align:center;
  padding:0 20px;
}

h1{
  font-family:'Instrument Serif',serif;
  font-size:clamp(36px,7vw,60px);
  line-height:1.1;
  margin:0;
  font-weight:400;
}

.sub{
  color:var(--muted);
  margin-top:14px;
  font-size:17px;
}

/* MACHINE */
.machine{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:16px;
  margin-top:24px;
}

.input-wrap{
  display:flex;
  gap:8px;
}

input{
  flex:1;
  padding:14px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#fafafa;
  font-size:16px;
}

button{
  background:var(--ink);
  color:#fff;
  border:none;
  padding:14px 18px;
  border-radius:10px;
  font-weight:600;
  cursor:pointer;
}

/* STATUS */
.status{
  font-size:12px;
  color:var(--muted);
  margin-top:10px;
  font-family:monospace;
}

/* PROGRESS */
#scan,#result{display:none;}

.bar-bg{
  height:3px;
  background:#eee;
  margin-top:10px;
  overflow:hidden;
}

.bar{
  height:100%;
  width:0%;
  background:var(--ink);
}

/* RESULT */
.output{
  margin-top:16px;
  padding:14px;
  border:1px solid var(--border);
  border-radius:10px;
  background:#fafafa;
  text-align:left;
}

.danger{color:var(--danger);font-weight:600;}

/* FAQ */
.faq{
  max-width:720px;
  margin:60px auto;
  padding:0 20px;
}

.faq-item{
  border-top:1px solid var(--border);
  padding:14px 0;
  cursor:pointer;
}

.faq-a{
  display:none;
  color:var(--muted);
  margin-top:8px;
  font-size:14px;
}

.faq-item.open .faq-a{display:block}

/* BLOG */
.blog{
  max-width:720px;
  margin:40px auto;
  padding:0 20px;
}

.blog-card{
  border:1px solid var(--border);
  padding:16px;
  border-radius:10px;
  margin-top:10px;
  background:white;
}

/* CTA */
.cta{
  text-align:center;
  margin:60px auto;
}

.cta a{
  display:inline-block;
  margin:8px;
  padding:12px 18px;
  border-radius:8px;
  text-decoration:none;
  font-size:14px;
}

.primary{background:var(--ink);color:white;}
.secondary{border:1px solid var(--border);color:var(--ink);}

/* FOOTER */
footer{
  text-align:center;
  font-size:12px;
  color:var(--muted);
  padding:40px 0;
}
</style>
</head>

<body>

<nav>
  <div class="logo">AI Visibility</div>
  <div class="nav-links">
    <a href="/blog">Blog</a>
    <a href="https://discord.gg/progpt">Discord</a>
  </div>
</nav>

<div class="hero">
  <h1>Does AI recommend you?</h1>
  <p class="sub">Run a check. See what AI sees.</p>

  <div class="machine">

    <div id="inputBox" class="input-wrap">
      <input id="url" placeholder="yourwebsite.com" />
      <button onclick="run()">Run</button>
    </div>

    <div id="status" class="status">AI index active • awaiting query</div>

    <div id="scan">
      <div class="bar-bg"><div id="bar" class="bar"></div></div>
    </div>

    <div id="result" class="output">
      <div><strong>Score:</strong> <span id="score"></span>/10</div>
      <div class="danger">Not recommended in AI answers</div>
    </div>

  </div>
</div>

<!-- FAQ -->
<div class="faq">
  <div class="faq-item">
    <strong>Why am I not showing in AI?</strong>
    <div class="faq-a">Your business lacks structured entity signals AI can verify.</div>
  </div>

  <div class="faq-item">
    <strong>What improves visibility?</strong>
    <div class="faq-a">Schema, entity authority, and consistent citations.</div>
  </div>

  <div class="faq-item">
    <strong>How fast does it change?</strong>
    <div class="faq-a">Usually within 2–4 weeks after optimization.</div>
  </div>
</div>

<!-- BLOG -->
<div class="blog">
  <h3>Research</h3>

  <div class="blog-card">
    <a href="/blog/how-ai-decides">How AI decides which business to recommend →</a>
  </div>

  <div class="blog-card">
    <a href="/blog/geo-vs-seo">GEO vs SEO — what changed →</a>
  </div>
</div>

<!-- CTA -->
<div class="cta">
  <a href="https://discord.gg/progpt" class="secondary">Join Discord</a>
  <a href="https://whop.com/progpt" class="primary">Get Access</a>
</div>

<footer>
© {year}
</footer>

<script is:inline>
let scans = localStorage.getItem("scans") || 0;

function run(){
  let url=document.getElementById("url").value;

  if(!url || !url.includes(".")){
    setStatus("Invalid domain");
    return;
  }

  if(scans >= 3){
    setStatus("Free limit reached");
    setTimeout(()=>window.location.href="https://whop.com/progpt",1200);
    return;
  }

  scans++;
  localStorage.setItem("scans", scans);

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";

  let logs=[
    "Parsing domain...",
    "Mapping entity graph...",
    "Querying AI layer...",
    "Calculating score..."
  ];

  let w=0,i=0;

  let int=setInterval(()=>{
    w+=3;
    document.getElementById("bar").style.width=w+"%";

    if(w%25===0 && i<logs.length){
      setStatus(logs[i++]);
    }

    if(w>=100){
      clearInterval(int);
      show();
    }
  },40);
}

function show(){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(1.5 + Math.random()*2.5).toFixed(1);
  document.getElementById("score").innerText=score;

  setStatus("Analysis complete");
}

function setStatus(text){
  document.getElementById("status").innerText=text;
}

document.querySelectorAll(".faq-item").forEach(el=>{
  el.onclick=()=>el.classList.toggle("open");
});
</script>

</body>
</html>