<script is:inline>
function runAudit(){
  let url = document.getElementById('url').value;
  if(!url || url.length < 3) return;

  document.getElementById('input-container').style.display='none';
  document.getElementById('scan').style.display='block';

  let logs = [
    "Crawling site structure...",
    "Querying LLM citation indices...",
    "Mapping competitor visibility...",
    "Finalizing AI recommendation score..."
  ];

  let w = 0, i = 0;

  let interval = setInterval(() => {
    w += 1.5;
    document.getElementById('bar').style.width = w + "%";

    if(w % 25 < 2 && i < logs.length){
      document.getElementById('log').innerText = logs[i++];
    }

    if(w >= 100){
      clearInterval(interval);
      finalize(url);
    }
  }, 35);
}

function finalize(url){
  document.getElementById('scan').style.display='none';
  document.getElementById('result').style.display='block';

  let score = (2.2 + (url.length % 2.5) + Math.random()).toFixed(1);
  document.getElementById('score').innerText = score;

  // More realistic competitor names
  let suffixes = ["solutions", "services", "group", "hq", "co"];
  let list = document.getElementById('competitors');
  list.innerHTML = "";

  let clean = url.replace(/^(https?:\/\/)?(www\.)?/, '').split('.')[0];

  for(let i=0;i<3;i++){
    let suffix = suffixes[Math.floor(Math.random()*suffixes.length)];
    let li = document.createElement("li");
    li.innerText = clean + suffix + ".com";
    list.appendChild(li);
  }

  // Loss framing
  let lost = Math.floor(Math.random()*25 + 15);
  document.getElementById('lossText').innerText =
    "Estimated loss: " + lost + "–" + (lost+20) + " inbound leads/month";

  // Scroll into view (important UX)
  document.getElementById('result').scrollIntoView({
    behavior: "smooth",
    block: "start"
  });
}

/* EMAIL CAPTURE FEEDBACK */
document.getElementById("lead-email")?.addEventListener("change", function(){
  let email = this.value;

  try{
    let leads = JSON.parse(localStorage.getItem("progpt_leads") || "[]");
    leads.push({ email, ts: new Date().toISOString() });
    localStorage.setItem("progpt_leads", JSON.stringify(leads));
  }catch(e){}

  this.style.borderColor = "var(--accent)";
  this.value = "✓ saved — check your inbox";
});

/* LIVE COUNTER */
setInterval(()=>{
  let el = document.getElementById("liveCount");
  let n = parseInt(el.innerText);
  el.innerText = n + Math.floor(Math.random()*2);
},4000);
</script>