---
// Astro logic
const title = "ProGPT — Rank Inside AI Answers";
const description = "Check if AI recommends your business. Run a free visibility audit.";
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

<style>
:root{
  --bg:#f7f6f3;
  --border:#e8e8e3;
  --ink:#1a1a18;
  --muted:#6b6b63;
  --accent:#2f54eb;
  --danger:#de350b;
}

body{
  margin:0;
  font-family:'Geist',sans-serif;
  background:var(--bg);
  color:var(--ink);
}

/* NAV */
nav{
  position:sticky;
  top:0;
  background:rgba(247,246,243,0.8);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
  padding:12px 20px;
}

.logo{font-weight:700;}

/* HERO */
.hero{
  max-width:720px;
  margin:80px auto 40px;
  text-align:center;
  padding:0 20px;
}

h1{
  font-family:'Instrument Serif',serif;
  font-size:clamp(36px,8vw,64px);
  line-height:1.1;
  margin:0;
}

.sub{
  color:var(--muted);
  margin-top:16px;
  font-size:18px;
}

/* SYSTEM LINE */
.system{
  font-size:12px;
  color:var(--muted);
  margin-top:14px;
}

/* FORM */
.form{
  background:white;
  border:1px solid var(--border);
  border-radius:12px;
  padding:6px;
  display:flex;
  max-width:460px;
  margin:24px auto;
}

input{
  flex:1;
  border:none;
  padding:12px;
  font-size:16px;
  outline:none;
}

button{
  background:var(--ink);
  color:white;
  border:none;
  padding:12px 20px;
  border-radius:8px;
  font-weight:600;
  cursor:pointer;
}

/* SCAN */
#scan,#result{display:none;}

.bar-bg{
  height:3px;
  background:#eee;
  margin-top:10px;
}
.bar{
  height:100%;
  width:0%;
  background:var(--ink);
}

/* RESULT */
.result-box{
  max-width:460px;
  margin:20px auto;
  text-align:left;
  border:1px solid var(--border);
  background:white;
  padding:16px;
  border-radius:10px;
}

.danger{
  color:var(--danger);
  font-size:13px;
  margin-top:6px;
}

/* SECTION */
.section{
  max-width:800px;
  margin:60px auto;
  padding:0 20px;
}

/* PRICING */
.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:1px;
  background:var(--border);
  border:1px solid var(--border);
  border-radius:10px;
  overflow:hidden;
}

.card{
  background:var(--bg);
  padding:20px;
}

.card.white{background:white;}

.tag{
  font-size:11px;
  font-weight:700;
  color:var(--accent);
}

@media(max-width:600px){
  .form{flex-direction:column;}
  .grid{grid-template-columns:1fr;}
}
</style>
</head>

<body>

<nav>
  <div class="logo">ProGPT</div>
  <div>
    <a href="#pricing" style="margin-right:10px; text-decoration:none; color:var(--muted);">Pricing</a>
    <a href="https://whop.com/progpt" style="background:var(--ink);color:white;padding:6px 12px;border-radius:6px;text-decoration:none;">Start</a>
  </div>
</nav>

<div class="hero">

<h1>Your business inside every AI answer</h1>

<p class="sub">
Check if AI actually recommends you — or your competitors.
</p>

<div class="system">
● AI index active • Monitoring citations • Audit ready
</div>

<!-- INPUT -->
<div id="inputBox" class="form">
  <input id="url" placeholder="yourwebsite.com">
  <button onclick="run()">Check if AI recommends you →</button>
</div>

<!-- SCAN -->
<div id="scan" style="max-width:460px;margin:20px auto;">
  <div style="font-size:12px;color:var(--accent)">Scanning AI signals...</div>
  <div class="bar-bg"><div class="bar" id="bar"></div></div>
</div>

<!-- RESULT -->
<div id="result" class="result-box">
  <strong>Visibility Score: <span id="score"></span>/10</strong>
  <div class="danger">AI is not recommending your business</div>
</div>

</div>

<!-- PRICING -->
<div class="section" id="pricing">

<p style="color:var(--muted);">
Once you see your score, you’ll understand what needs fixing.
</p>

<div class="grid">

<div class="card">
  <div class="tag">FREE</div>
  <h3>AI Audit</h3>
  <p style="color:var(--muted)">Basic visibility score</p>
</div>

<div class="card white">
  <div class="tag">PRO</div>
  <h3>GEO Optimization</h3>
  <p style="color:var(--muted)">Schema + AI ranking fixes</p>
  <div style="font-weight:700;margin:10px 0;">$97</div>
  <a href="https://whop.com/progpt" style="display:block;background:var(--ink);color:white;padding:10px;border-radius:6px;text-align:center;text-decoration:none;">
    Fix visibility →
  </a>
</div>

</div>

</div>

<footer style="text-align:center;color:var(--muted);font-size:13px;padding:40px 0;">
© {currentYear} ProGPT
</footer>

<script is:inline>
function run(){
  let url=document.getElementById("url").value;
  if(!url) return;

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";

  let w=0;
  let int=setInterval(()=>{
    w+=3;
    document.getElementById("bar").style.width=w+"%";

    if(w>=100){
      clearInterval(int);
      show();
    }
  },40);
}

function show(){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(2+Math.random()*2).toFixed(1);
  document.getElementById("score").innerText=score;
}
</script>

</body>
</html>