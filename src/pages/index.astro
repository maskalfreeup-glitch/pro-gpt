---
import Layout from '../layouts/Layout.astro';

const links = {
	fiverr: '#',
	audit: '#',
	discord: 'https://discord.gg/vyvD7QWtcP',
	github: 'https://github.com/maskalfreeup-glitch',
	email: 'mailto:hello@progpt.store',
	medium: 'https://medium.com/@YOUR_HANDLE/article-slug',
	whop: 'https://whop.com/progpt',
};

const services = [
	{
		title: 'AI Visibility / GEO Audit',
		body: 'See how your offer shows up in AI answers and search, then get clear fixes for pages, prompts, and buyer questions.',
		items: ['AI answer checks', 'Offer clarity review', 'Content fixes to prioritize'],
	},
	{
		title: 'Discord + Whop Paid Community Setup',
		body: 'Launch a cleaner paid community with the right channels, roles, access rules, and onboarding flow from day one.',
		items: ['Channel and role setup', 'Whop access rules', 'Member onboarding flow'],
	},
	{
		title: 'AI Automation Workflows',
		body: 'Save founder time with simple automations for intake, lead follow-up, reporting, and content tasks.',
		items: ['Intake and follow-up flow', 'Tool connection plan', 'Founder review steps'],
	},
	{
		title: 'GEO SEO Landing Pages',
		body: 'Ship fast landing pages that explain your offer clearly, support conversions, and give AI/search engines better context.',
		items: ['Offer positioning', 'FAQ-ready page structure', 'Fast Astro delivery'],
	},
];

const systemExamples = [
	{
		title: 'AI Visibility Audit Dashboard',
		body: 'Demo view for checking prompt coverage, offer clarity, citation gaps, and page fixes.',
		type: 'dashboard',
	},
	{
		title: 'Discord / Whop Launch Setup',
		body: 'Demo setup for paid access, roles, onboarding, support channels, and upgrade paths.',
		type: 'community',
	},
	{
		title: 'AI Intake Automation',
		body: 'Demo workflow for lead capture, qualification, draft follow-up, and founder review.',
		type: 'workflow',
	},
];

const founderLabPerks = [
	'AI visibility breakdowns',
	'Landing page teardown discussions',
	'Discord + Whop setup ideas',
	'Automation workflow notes',
	'Founder stack resources',
	'Early access to templates',
];

const mediumCards = [
	{
		title: 'What an AI Visibility Audit Actually Checks',
		body: 'A plain-English look at prompts, entity clarity, answer gaps, citations, and page fixes that help your offer show up better.',
		url: links.medium,
	},
	{
		title: 'How to Structure a Paid Discord Before Launch',
		body: 'The practical channel, role, onboarding, access, and support decisions to make before inviting paying members.',
		url: links.medium,
	},
	{
		title: 'Simple Automations That Save Founder Time',
		body: 'Useful intake, follow-up, reporting, and content workflows that reduce manual work without adding tool bloat.',
		url: links.medium,
	},
	{
		title: 'The Lightweight Founder Stack for AI-Era Growth',
		body: 'A lean stack for clearer offers, AI-visible pages, community operations, and repeatable founder workflows.',
		url: links.medium,
	},
];
---

<Layout>
	<main class="site-shell">
		<nav class="nav" aria-label="Primary">
			<a class="brand" href="/" aria-label="ProGPT home">
				<span class="brand-mark">PG</span>
				<span>ProGPT Systems</span>
			</a>
			<div class="nav-links">
				<a href="#services">Services</a>
				<a href="#examples">Examples</a>
				<a href="#lab">Free Lab</a>
				<a href="#operator">Operator</a>
				<a href="#contact">Contact</a>
			</div>
		</nav>

		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Founder systems for the AI era</p>
				<h1>Founder Systems for the AI Era</h1>
				<p class="hero-lede">
					AI visibility audits, paid Discord + Whop communities, GEO-ready landing pages, and
					automation workflows for founders who want clearer offers, faster launches, and less
					manual work.
				</p>
				<div class="hero-actions" aria-label="Primary calls to action">
					<a class="button primary" href={links.fiverr}>Hire on Fiverr</a>
					<a class="button ghost" href={links.discord} target="_blank" rel="noopener noreferrer"
						>Join Founder Lab</a
					>
					<a class="button whop" href={links.whop} target="_blank" rel="noopener noreferrer"
						>Browse on Whop</a
					>
				</div>
			</div>

			<div class="hero-graphic" aria-label="Founder systems intelligence dashboard preview">
				<div class="intel-map" aria-hidden="true">
					<span class="map-line visibility"></span>
					<span class="map-line landing"></span>
					<span class="map-line community"></span>
					<span class="map-line automation"></span>
					<div class="map-node core">Founder Offer</div>
					<div class="map-node node-ai">AI Visibility</div>
					<div class="map-node node-page">Landing Page</div>
					<div class="map-node node-community">Discord + Whop</div>
					<div class="map-node node-automation">Automation</div>
				</div>
				<div class="terminal-panel status-terminal">
					<div class="terminal-bar">
						<span></span>
						<span></span>
						<span></span>
						<strong>system.status</strong>
					</div>
					<div class="terminal-lines">
						<p><span>$</span> review founder offer</p>
						<p><span>></span> AI visibility: checked</p>
						<p><span>></span> launch tasks: listed</p>
						<p><span>></span> next fixes: ready</p>
					</div>
				</div>
				<div class="mini-dashboard signal-panel">
					<div>
						<span>AI visibility</span>
						<i style="--score: 78%"></i>
					</div>
					<div>
						<span>Launch setup</span>
						<i style="--score: 72%"></i>
					</div>
					<div>
						<span>Automation gaps</span>
						<i style="--score: 66%"></i>
					</div>
				</div>
			</div>
		</section>

		<section class="section" id="services">
			<div class="section-heading">
				<p class="eyebrow">Services</p>
				<h2>Practical builds that help founders launch, improve visibility, and save time.</h2>
			</div>
			<div class="service-grid">
				{
					services.map((service) => (
						<article class="service-card">
							<div class="card-glow"></div>
							<h3>{service.title}</h3>
							<p>{service.body}</p>
							<ul>
								{service.items.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</article>
					))
				}
			</div>
		</section>

		<section class="operator-section" id="operator">
			<div class="operator-copy">
				<p class="eyebrow">Why founder-led</p>
				<h2>Direct work, faster decisions, and fewer unnecessary meetings.</h2>
				<p>
					You work directly with the person building the page, community setup, audit, or
					automation. The goal is simple: understand the problem, move quickly, keep the process
					light, and leave you with something you can actually use.
				</p>
			</div>
			<div class="operator-grid">
				<div>
					<strong>Direct communication</strong>
					<p>Simple project threads, clear scope, and quick decisions without extra layers.</p>
				</div>
				<div>
					<strong>Fast iteration</strong>
					<p>Short feedback loops so copy, setup, and automations can improve quickly.</p>
				</div>
				<div>
					<strong>Lightweight systems</strong>
					<p>Useful pages and automations without extra process or tools you do not need.</p>
				</div>
				<div>
					<strong>Clean handoff</strong>
					<p>Clear notes, next steps, and delivery context so you can keep moving after launch.</p>
				</div>
			</div>
		</section>

		<section class="section" id="examples">
			<div class="section-heading">
				<p class="eyebrow">Example Systems</p>
				<h2>Demo projects that show the kind of work you can request.</h2>
			</div>
			<div class="example-grid">
				{
					systemExamples.map((example) => (
						<article class={`example-card ${example.type}`}>
							<div class="example-visual" aria-hidden="true">
								{example.type === 'dashboard' && (
									<div class="geo-signal-map">
										<span class="geo-core">Offer</span>
										<span class="geo-node geo-a">Prompts</span>
										<span class="geo-node geo-b">Entities</span>
										<span class="geo-node geo-c">Pages</span>
										<span class="geo-node geo-d">Gaps</span>
										<div class="score-bars compact-bars">
											<span style="--score: 82%"></span>
											<span style="--score: 58%"></span>
											<span style="--score: 74%"></span>
										</div>
									</div>
								)}
								{example.type === 'community' && (
									<div class="community-map">
										<span class="access-core">Whop</span>
										<span>Paid Role</span>
										<span>Welcome</span>
										<span>Support</span>
										<span>Upgrade</span>
									</div>
								)}
								{example.type === 'workflow' && (
									<div class="workflow-map">
										<span>Form</span>
										<span>Qualify</span>
										<span>Draft Response</span>
										<span>Founder Review</span>
									</div>
								)}
							</div>
							<h3>{example.title}</h3>
							<p>{example.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="section founder-lab" id="lab">
			<div class="section-heading">
				<p class="eyebrow">Free Discord</p>
				<h2>Join the free Founder Lab</h2>
				<p>
					A free Discord for founders building AI-visible offers, cleaner landing pages, paid
					communities, and lightweight automations.
				</p>
			</div>
			<div class="perk-grid">
				{
					founderLabPerks.map((perk) => (
						<article class="perk-card">
							<span></span>
							<h3>{perk}</h3>
						</article>
					))
				}
			</div>
			<a class="button secondary lab-cta" href={links.discord} target="_blank" rel="noopener noreferrer"
				>Join Founder Lab</a
			>
		</section>

		<section class="split-section" id="process">
			<div>
				<p class="eyebrow">Delivery</p>
				<h2>Start with the problem, ship the useful fix, and leave with clear next steps.</h2>
			</div>
			<div class="process-list">
				<div>
					<strong>Audit</strong>
					<p>Review your offer, AI visibility, landing page, community setup, or workflow gaps.</p>
				</div>
				<div>
					<strong>Build</strong>
					<p>Create the page, setup, audit, or automation needed to solve the immediate problem.</p>
				</div>
				<div>
					<strong>Handoff</strong>
					<p>Share clear notes and next steps so you can keep using it after delivery.</p>
				</div>
			</div>
		</section>

		<section class="section compact" id="insights">
			<div class="section-heading">
				<p class="eyebrow">Field Notes on Medium</p>
				<h2>Practical notes on AI visibility, founder systems, automation, and community operations.</h2>
			</div>
			<div class="blog-grid">
				{
					mediumCards.map((card) => (
						<article class="blog-card">
							<h3>{card.title}</h3>
							<p>{card.body}</p>
							<a
								href={card.url}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={`Read on Medium: ${card.title}`}
							>
								Read on Medium →
							</a>
						</article>
					))
				}
			</div>
		</section>

		<section class="cta-band" id="contact">
			<div>
				<p class="eyebrow">Free audit</p>
				<h2>Need help improving your AI visibility or founder workflow?</h2>
				<p>
					Get help with an AI visibility audit, a cleaner founder workflow, a paid Discord setup,
					or a landing page that explains your offer more clearly.
				</p>
			</div>
			<div class="cta-stack">
				<a class="button primary" href={links.fiverr}>Hire on Fiverr</a>
				<a class="button secondary" href={links.audit}>Get free audit</a>
				<a class="button ghost" href={links.discord} target="_blank" rel="noopener noreferrer"
					>Join Founder Lab</a
				>
			</div>
		</section>

		<footer class="footer">
			<div class="footer-brand">
				<a class="brand" href="/" aria-label="ProGPT home">
					<span class="brand-mark">PG</span>
					<span>ProGPT Systems</span>
				</a>
				<p class="footer-tagline">Founder systems for the AI era.</p>
				<p class="footer-meta">Built and maintained by Maskal / ProGPT Systems.</p>
			</div>
			<div class="footer-actions">
				<nav class="footer-links" aria-label="Footer links">
					<a href={links.fiverr}>Hire on Fiverr</a>
					<a href={links.audit}>Get Free Audit</a>
					<a href={links.discord} target="_blank" rel="noopener noreferrer">Join Founder Lab</a>
					<a href={links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
					<a href={links.medium} target="_blank" rel="noopener noreferrer">Medium</a>
				</nav>
				<a class="footer-email" href={links.email}>hello@progpt.store</a>
			</div>
		</footer>
	</main>
</Layout>

<style>
	:global(body) {
		overflow-x: hidden;
		color: #f6f7fb;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	:global(body)::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		content: '';
		background:
			radial-gradient(circle at 16% 10%, rgba(126, 226, 189, 0.16), transparent 28%),
			radial-gradient(circle at 82% 22%, rgba(122, 167, 255, 0.13), transparent 30%),
			linear-gradient(180deg, #070910 0%, #0a0f18 52%, #06080f 100%);
	}

	:global(a) {
		color: inherit;
	}

	.site-shell {
		width: min(1180px, calc(100% - 40px));
		margin: 0 auto;
		padding: 24px 0 40px;
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 12px 0;
	}

	.brand,
	.nav-links {
		display: flex;
		align-items: center;
	}

	.brand {
		gap: 10px;
		text-decoration: none;
		font-weight: 750;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		flex: 0 0 auto;
		width: 38px;
		height: 38px;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 8px;
		background: linear-gradient(135deg, #fbf3bd, #51d6a8 48%, #7aa7ff);
		color: #061017;
		font-size: 13px;
		font-weight: 850;
	}

	.nav-links {
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 18px;
		color: #b8bfcc;
		font-size: 14px;
	}

	.nav-links a,
	.footer a {
		text-decoration: none;
	}

	.nav-links a:hover,
	.footer a:hover {
		color: #ffffff;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(390px, 0.95fr);
		gap: 44px;
		align-items: center;
		min-height: 650px;
		padding: 92px 0 72px;
	}

	.hero-copy {
		min-width: 0;
	}

	.eyebrow {
		margin: 0 0 14px;
		color: #7ee2bd;
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		max-width: 860px;
		margin-bottom: 24px;
		font-size: clamp(46px, 7vw, 88px);
		line-height: 0.96;
		letter-spacing: 0;
	}

	.hero-lede {
		max-width: 700px;
		margin-bottom: 36px;
		color: #c9ced8;
		font-size: 20px;
		line-height: 1.6;
	}

	.hero-actions,
	.cta-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 13px 18px;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 8px;
		font-weight: 800;
		text-align: center;
		text-decoration: none;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background 160ms ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button.primary {
		border-color: transparent;
		background: #ffffff;
		color: #05070d;
	}

	.button.secondary {
		border-color: transparent;
		background: #24c48e;
		color: #04120d;
	}

	.button.ghost {
		background: rgba(255, 255, 255, 0.06);
		color: #f6f7fb;
	}

	.button.whop {
		border-color: rgba(122, 167, 255, 0.36);
		background:
			linear-gradient(135deg, rgba(122, 167, 255, 0.22), rgba(126, 226, 189, 0.1)),
			rgba(255, 255, 255, 0.055);
		color: #f6f9ff;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
	}

	.button.whop:hover {
		border-color: rgba(122, 167, 255, 0.62);
		background:
			linear-gradient(135deg, rgba(122, 167, 255, 0.28), rgba(126, 226, 189, 0.14)),
			rgba(255, 255, 255, 0.075);
	}

	.hero-graphic,
	.service-card,
	.operator-section,
	.example-card,
	.founder-lab,
	.perk-card,
	.blog-card,
	.cta-band,
	.footer {
		border: 1px solid rgba(255, 255, 255, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.035)),
			#0b1019;
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
	}

	.hero-graphic {
		position: relative;
		min-height: 540px;
		overflow: hidden;
		padding: 24px;
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(126, 226, 189, 0.12), transparent 36%),
			linear-gradient(315deg, rgba(122, 167, 255, 0.15), transparent 38%),
			#0b1019;
	}

	.hero-graphic::before {
		position: absolute;
		inset: 24px;
		content: '';
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 8px;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
		background-size: 34px 34px;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.75), transparent);
	}

	.hero-graphic::after {
		position: absolute;
		inset: auto -80px -120px auto;
		width: 300px;
		height: 300px;
		content: '';
		border-radius: 999px;
		background: rgba(126, 226, 189, 0.14);
		filter: blur(56px);
	}

	.intel-map {
		position: relative;
		z-index: 2;
		height: 312px;
		margin: 10px 0 24px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		background:
			radial-gradient(circle at center, rgba(126, 226, 189, 0.13), transparent 36%),
			rgba(5, 8, 14, 0.42);
	}

	.map-node {
		position: absolute;
		z-index: 2;
		display: grid;
		place-items: center;
		width: 128px;
		min-height: 48px;
		padding: 10px 12px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 8px;
		background: rgba(5, 8, 14, 0.9);
		box-shadow: 0 14px 34px rgba(0, 0, 0, 0.32);
		color: #e8eef7;
		font-size: 12px;
		font-weight: 800;
		text-align: center;
	}

	.map-node::before {
		position: absolute;
		top: 50%;
		left: -5px;
		width: 9px;
		height: 9px;
		content: '';
		border-radius: 999px;
		background: #7ee2bd;
		box-shadow: 0 0 18px rgba(126, 226, 189, 0.7);
		transform: translateY(-50%);
	}

	.map-node.core {
		top: 50%;
		left: 50%;
		width: 150px;
		min-height: 62px;
		border-color: rgba(126, 226, 189, 0.42);
		background: linear-gradient(145deg, rgba(126, 226, 189, 0.16), rgba(122, 167, 255, 0.1)), #071017;
		color: #ffffff;
		transform: translate(-50%, -50%);
	}

	.map-node.core::before {
		display: none;
	}

	.node-ai {
		top: 28px;
		left: 28px;
	}

	.node-page {
		top: 28px;
		right: 28px;
	}

	.node-community {
		bottom: 30px;
		left: 30px;
	}

	.node-automation {
		right: 30px;
		bottom: 30px;
	}

	.map-line {
		position: absolute;
		z-index: 1;
		top: 50%;
		left: 50%;
		width: 34%;
		height: 1px;
		background: linear-gradient(90deg, rgba(126, 226, 189, 0), rgba(126, 226, 189, 0.62));
		transform-origin: left center;
	}

	.map-line.visibility {
		transform: rotate(214deg);
	}

	.map-line.landing {
		transform: rotate(326deg);
	}

	.map-line.community {
		transform: rotate(146deg);
	}

	.map-line.automation {
		transform: rotate(34deg);
	}

	.terminal-panel,
	.mini-dashboard {
		position: relative;
		z-index: 2;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 8px;
		background: rgba(5, 8, 14, 0.82);
		backdrop-filter: blur(16px);
	}

	.terminal-panel {
		width: min(100%, 360px);
		margin: 0 0 0 auto;
	}

	.status-terminal {
		position: absolute;
		right: 24px;
		bottom: 24px;
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 12px 14px;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		color: #aeb6c5;
		font-size: 12px;
	}

	.terminal-bar span {
		width: 9px;
		height: 9px;
