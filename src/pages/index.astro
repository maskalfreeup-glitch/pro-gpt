<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ProGPT — AI Visibility</title>
<meta name="description" content="Check if AI recommends your business.">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#050505;
  --card:rgba(13,17,23,0.6);
  --border:rgba(255,255,255,0.08);
  --accent:#ccff00;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --danger:#ff4444;
}

body{
  margin:0;
  font-family:Inter,sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* GRID BG */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size:40px 40px;
  z-index:-1;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:16px 5%;
  border-bottom:1px solid var(--border);
  position:sticky;
  top:0;
  backdrop-filter:blur(10px);
}
.logo{font-weight:800}
.nav-links{
  display:flex;
  gap:16px;
  align-items:center;
}
.nav-links a{
  color:#aaa;
  text-decoration:none;
  font-size:14px;
}
.nav-btn{
  background:var(--accent);
  padding:8px 14px;
  border-radius:6px;
  color:#000;
  font-weight:800;
  text-decoration:none;
}

/* LAYOUT */
.container{
  max-width:900px;
  margin:auto;
  padding:60px 20px;
}

/* HERO */
.hero{
  text-align:center;
}
h1{
  font-size:clamp(42px,8vw,72px);
  line-height:0.95;
  font-weight:900;
}
h1 span{color:var(--accent)}
.sub{
  color:var(--muted);
  margin-top:20px;
  font-size:18px;
}

/* CARD */
.card{
  background:var(--card);
  border:1px solid var(--border);
  backdrop-filter:blur(10px);
  border-radius:16px;
  padding:24px;
  margin-top:24px;
}

/* INPUT */
input{
  width:100%;
  padding:16px;
  border-radius:12px;
  border:1px solid var(--border);
  background:#000;
  color:#fff;
  font-size:16px;
}

/* BUTTON */
.btn{
  width:100%;
  padding:18px;
  background:var(--accent);
  color:#000;
  font-weight:900;
  border:none;
  border-radius:12px;
  margin-top:12px;
  cursor:pointer;
}

/* BLOG GRID */
.blog-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:16px;
}
.blog-card{
  border:1px solid var(--border);
  padding:20px;
  border-radius:12px;
}
.blog-card a{
  color:var(--accent);
  text-decoration:none;
  font-weight:600;
}

/* RESULT */
#scan{display:none;}
#result{display:none;}

.badge{
  background:rgba(255,0,0,0.1);
  color:var(--danger);
  padding:6px 10px;
  border-radius:6px;
  font-size:11px;
}
</style>
</head>

<body>

<nav>
  <div class="logo">PROGPT</div>

  <div class="nav-links">
    <a href="/blog">Blog</a>
    <a href="https://your-lemonsqueezy-link.com" class="nav-btn">Buy</a>
  </div>
</nav>

<div class="container">

<!-- HERO -->
<div class="hero">
  <h1>AI is already <span>choosing</span> your competitors.</h1>
  <p class="sub">If you're not in AI answers, you don't exist.</p>
</div>

<!-- AUDIT -->
<div class="card" id="input">
  <input id="url" placeholder="yourwebsite.com">
  <button class="btn" onclick="runAudit()">Run free audit →</button>
  <p style="font-size:12px;color:#888;margin-top:10px;text-align:center">
    🔴 <span id="live">21</span> businesses scanning now
  </p>
</div>

<div id="scan" class="card">
  <div id="log">Scanning...</div>
  <div style="height:3px;background:#111;margin-top:10px">
    <div id="bar" style="height:100%;width:0%;background:var(--accent)"></div>
  </div>
</div>

<div id="result" class="card">
  <h3>Score: <span id="score"></span>/10</h3>
  <div class="badge">Visibility Critical</div>

  <ul id="list"></ul>

  <p id="loss"></p>

  <button class="btn" onclick="location.href='https://your-lemonsqueezy-link.com'">
    Reclaim visibility → $297
  </button>
</div>

<!-- BLOG STRATEGIC SECTION -->
<div class="card">
  <h3>Learn how AI picks businesses</h3>

  <div class="blog-grid">

    <div class="blog-card">
      <a href="/blog/ai-seo-for-dentists">
        AI SEO for Dentists →
      </a>
      <p style="color:#888">Why dental clinics disappear from AI answers</p>
    </div>

    <div class="blog-card">
      <a href="/blog/why-youre-not-in-chatgpt">
        Why you're not in ChatGPT →
      </a>
      <p style="color:#888">The real ranking system behind AI</p>
    </div>

    <div class="blog-card">
      <a href="/blog/ai-visibility-checklist">
        AI Visibility Checklist →
      </a>
      <p style="color:#888">Signals AI uses to pick businesses</p>
    </div>

  </div>
</div>

<!-- VALUE -->
<div class="card">
  <h3>What you get</h3>
  <ul style="color:#aaa;line-height:1.8">
    <li>• AI visibility audit</li>
    <li>• GEO + SEO fixes</li>
    <li>• Schema optimization</li>
    <li>• AI-ready content</li>
  </ul>
</div>

<!-- FINAL CTA -->
<div class="card" style="text-align:center">
  <h3>Fix your visibility</h3>
  <button class="btn" onclick="location.href='https://your-lemonsqueezy-link.com'">
    Start now → $297
  </button>
</div>

</div>

<script>
function runAudit(){
  let url=document.getElementById('url').value;
  if(!url) return;

  document.getElementById('input').style.display='none';
  document.getElementById('scan').style.display='block';

  let w=0;

  let int=setInterval(()=>{
    w+=2;
    document.getElementById('bar').style.width=w+"%";

    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },40);
}

function show(url){
  document.getElementById('scan').style.display='none';
  document.getElementById('result').style.display='block';

  document.getElementById('score').innerText=(2+Math.random()*3).toFixed(1);

  let list=document.getElementById('list');
  list.innerHTML="";

  let base=url.split('.')[0];

  for(let i=0;i<3;i++){
    let li=document.createElement("li");
    li.innerText="top-"+base+".com";
    list.appendChild(li);
  }

  document.getElementById('loss').innerText=
    "Losing "+Math.floor(Math.random()*20+10)+" leads / month";
}

/* live counter */
setInterval(()=>{
  let el=document.getElementById('live');
  el.innerText=parseInt(el.innerText)+1;
},5000);
</script>

<!-- LLM SCHEMA -->
<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"Service",
  "name":"AI Visibility Optimization",
  "offers":{"@type":"Offer","price":"297","priceCurrency":"USD"}
}
</script>

</body>
</html>