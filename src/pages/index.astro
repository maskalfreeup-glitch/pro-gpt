<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Visibility Engine</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#050505;
  --card:#0d1117;
  --border:#1a1a1a;
  --accent:#00ff9f;
  --text:#eaeaea;
  --muted:#8a8a8a;
  --danger:#ff4444;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:Inter,sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* GRID BACKGROUND */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background:
    linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);
  background-size:50px 50px;
  z-index:-1;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:16px 20px;
  border-bottom:1px solid var(--border);
}

.logo{
  font-weight:800;
  letter-spacing:-1px;
}

.nav-links a{
  color:var(--muted);
  margin-left:16px;
  text-decoration:none;
  font-size:14px;
}

.nav-links a:hover{color:#fff}

/* LAYOUT */
.container{
  max-width:820px;
  margin:auto;
  padding:80px 20px;
}

/* HERO */
h1{
  font-size:clamp(42px,8vw,72px);
  line-height:.9;
  margin:0;
}

h1 span{color:var(--accent)}

.sub{
  margin-top:16px;
  color:var(--muted);
  font-size:18px;
  max-width:520px;
}

/* CARD */
.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
  margin-top:24px;
}

/* INPUT */
input{
  width:100%;
  padding:16px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#000;
  color:#fff;
  font-size:16px;
}

/* BUTTON */
.btn{
  width:100%;
  padding:16px;
  margin-top:12px;
  border:none;
  border-radius:10px;
  font-weight:800;
  background:var(--accent);
  color:#000;
  cursor:pointer;
}

/* SCAN */
#scan,#result{display:none}

.bar-bg{
  height:4px;
  background:#111;
  margin-top:12px;
  border-radius:10px;
}

#bar{
  height:100%;
  width:0%;
  background:var(--accent);
}

/* RESULT */
.badge{
  background:rgba(255,0,0,0.1);
  color:var(--danger);
  padding:6px 10px;
  border-radius:6px;
  font-size:12px;
}

ul{color:var(--accent)}

.loss{
  color:var(--danger);
  font-weight:700;
  margin-top:16px;
}

/* FAQ */
.faq-item{
  border-top:1px solid var(--border);
  padding:12px 0;
  cursor:pointer;
}

.faq-a{display:none;color:#aaa;margin-top:6px}
.faq-item.active .faq-a{display:block}

/* FOOTER CTA (soft) */
.footer{
  text-align:center;
  margin-top:60px;
  color:var(--muted);
}

.footer a{
  color:var(--accent);
  text-decoration:none;
  margin:0 8px;
}
</style>
</head>

<body>

<nav>
  <div class="logo">AI VISIBILITY</div>
  <div class="nav-links">
    <a href="/blog">Blog</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
  </div>
</nav>

<div class="container">

<h1>AI is already <span>choosing</span> your competitors.</h1>
<p class="sub">This engine shows whether your business exists inside AI answers.</p>

<!-- INPUT -->
<div class="card" id="inputBox">
  <input id="url" placeholder="yourwebsite.com">
  <button class="btn" onclick="run()">Run audit</button>
</div>

<!-- SCAN -->
<div id="scan" class="card">
  <div id="log">Scanning site…</div>
  <div class="bar-bg"><div id="bar"></div></div>
</div>

<!-- RESULT -->
<div id="result">

<div class="card">
  <h3>Score: <span id="score"></span>/10</h3>
  <div class="badge">Low AI Visibility</div>

  <ul id="competitors"></ul>

  <p id="loss" class="loss"></p>
</div>

<div class="card">
  <h3>Why this happens</h3>
  <div id="faq"></div>
</div>

<div class="card">
  <h3>Next step</h3>
  <p style="color:var(--muted)">
    Full system access, deeper analysis, and fixes are available inside the private environment.
  </p>
</div>

</div>

<!-- FOOTER -->
<div class="footer">
  <p>
    <a href="#">Join Discord</a> · 
    <a href="#">Request Access</a>
  </p>
</div>

</div>

<script>
function run(){
  let url=document.getElementById("url").value;
  if(!url.includes(".")) return alert("enter valid domain");

  inputBox.style.display="none";
  scan.style.display="block";

  let w=0;
  let int=setInterval(()=>{
    w+=2;
    bar.style.width=w+"%";
    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },40);
}

function show(url){
  scan.style.display="none";
  result.style.display="block";

  score.innerText=(2+Math.random()*2).toFixed(1);

  let clean=url.split('.')[0];
  let prefixes=["top-","best-","get-"];

  competitors.innerHTML="";
  prefixes.forEach(p=>{
    let li=document.createElement("li");
    li.innerText=p+clean+".com";
    competitors.appendChild(li);
  });

  let lost=Math.floor(Math.random()*20+10);
  loss.innerText="Estimated loss: "+lost+"–"+(lost+10)+" leads/month";

  renderFAQ();
}

function renderFAQ(){
  let data=[
    ["Why invisible?","AI cannot verify your authority."],
    ["What’s missing?","Structured data and entity signals."],
    ["Impact?","Customers choose competitors automatically."],
    ["Fix?","Rebuild your AI visibility layer."]
  ];

  faq.innerHTML="";
  data.forEach(q=>{
    let d=document.createElement("div");
    d.className="faq-item";
    d.innerHTML=`<strong>${q[0]}</strong><div class="faq-a">${q[1]}</div>`;
    d.onclick=()=>d.classList.toggle("active");
    faq.appendChild(d);
  });
}
</script>

</body>
</html>