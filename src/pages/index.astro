---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ProGPT — Rank inside AI search</title>

    <style>
      :root {
        --bg: #0a0a0a;
        --text: #ffffff;
        --muted: #a0a0a0;
        --accent: #7c5cff;
        --card: #141414;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      }

      body {
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem;
      }

      h1 {
        font-size: 3rem;
        line-height: 1.2;
      }

      h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
      }

      p {
        color: var(--muted);
        margin: 1rem 0;
      }

      .hero {
        text-align: center;
        padding: 6rem 2rem;
      }

      .cta-button {
        display: inline-block;
        margin-top: 1.5rem;
        padding: 0.9rem 1.5rem;
        background: var(--accent);
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
      }

      .section {
        padding: 4rem 0;
        text-align: center;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
      }

      .card {
        background: var(--card);
        padding: 1.5rem;
        border-radius: 12px;
      }

      form {
        margin-top: 2rem;
      }

      input {
        padding: 0.8rem;
        width: 250px;
        border-radius: 6px;
        border: none;
        margin-right: 0.5rem;
      }

      button {
        padding: 0.8rem 1.2rem;
        background: var(--accent);
        border: none;
        color: white;
        border-radius: 6px;
        cursor: pointer;
      }

      footer {
        text-align: center;
        padding: 3rem 0;
        font-size: 0.9rem;
        color: var(--muted);
      }
    </style>
  </head>

  <body>
    <div class="container">

      <!-- HERO -->
      <section class="hero">
        <h1>Rank inside ChatGPT & AI search</h1>
        <p>
          We help brands appear inside AI-generated answers using AEO/GEO systems.
        </p>

        <a href="#cta" class="cta-button">
          Get your brand ranked
        </a>
      </section>

      <!-- HOW IT WORKS -->
      <section class="section">
        <h2>How it works</h2>

        <div class="grid">
          <div class="card">
            <h3>Analyze</h3>
            <p>We identify where your brand is missing in AI responses.</p>
          </div>

          <div class="card">
            <h3>Optimize</h3>
            <p>We structure your content for AI visibility (AEO/GEO).</p>
          </div>

          <div class="card">
            <h3>Rank</h3>
            <p>Your brand starts appearing in ChatGPT-style answers.</p>
          </div>
        </div>
      </section>

      <!-- WHY THIS MATTERS -->
      <section class="section">
        <h2>Search is changing</h2>
        <p>
          People are no longer clicking links. They’re asking AI.
          If your brand isn’t inside those answers, you don’t exist.
        </p>
      </section>

      <!-- FINAL CTA -->
      <section class="section" id="cta">
        <h2>Get your brand ranked inside AI</h2>
        <p>Request early access or an audit.</p>

        <form onsubmit="handleSubmit(event)">
          <input type="email" placeholder="Enter your email" required />
          <button type="submit">Get access</button>
        </form>
      </section>

      <!-- FOOTER -->
      <footer>
        <p>ProGPT — AI Search Optimization</p>
        <p>© 2026</p>
      </footer>

    </div>

    <script>
      function handleSubmit(e) {
        e.preventDefault();
        const email = e.target.querySelector("input").value;
        console.log("Captured email:", email);
        alert("Thanks! We’ll reach out soon.");
      }
    </script>
  </body>
</html>
