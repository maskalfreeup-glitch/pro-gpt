---
const title = "ProGPT - AI Visibility Audit";
const description = "Check if AI recommends your business.";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />

<style>
:root{
  --bg:#060608;
  --surface:#0d0d12;
  --border:rgba(255,255,255,0.07);
  --orange:#ff6b1a;
  --red:#ff4444;
  --text:#f0ede8;
  --muted:#8a8294;
}

*{margin:0;padding:0;box-sizing:border-box}
body{
  background:var(--bg);
  color:var(--text);
  font-family:system-ui, sans-serif;
}

/* LAYOUT */
.wrap{
  max-width:680px;
  margin:auto;
  padding:24px;
}

/* HERO */
h1{
  font-size:2.6rem;
  line-height:1.2;
  margin-bottom:12px;
}

.hero-sub{
  color:var(--muted);
  margin-bottom:24px;
}

/* INPUT */
.audit-box{
  display:flex;
  border:1px solid var(--border);
  border-radius:12px;
  overflow:hidden;
}

.audit-box input{
  flex:1;
  padding:14px;
  background:transparent;
  border:none;
  color:white;
}

.audit-box button{
  background:var(--orange);
  border:none;
  padding:14px 20px;
  color:white;
  cursor:pointer;
}

/* RESULT */
.result{
  display:none;
  margin-top:24px;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:12px;
}

.score{
  font-size:2.4rem;
  padding:20px;
  color:var(--red);
}

.verdict{
  padding:0 20px;
  font-weight:600;
  color:var(--red);
}

.result p{
  padding:10px 20px;
  color:var(--muted);
}

/* GATE */
.gate{
  padding:20px;
}

.gate input{
  width:100%;
  margin-bottom:10px;
  padding:12px;
  border:1px solid var(--border);
  background:#000;
  color:white;
  border-radius:8px;
}

.gate button{
  width:100%;
  padding:14px;
  background:var(--orange);
  border:none;
  color:white;
  border-radius:8px;
}

/* CTA */
.cta{
  display:block;
  text-align:center;
  margin-top:12px;
  padding:14px;
  background:var(--orange);
  border-radius:10px;
  color:white;
  text-decoration:none;
}

/* SECTIONS */
.section{
  margin-top:50px;
}

.section h2{
  margin-bottom:10px;
}

.section p{
  color:var(--muted);
}

/* BUY */
.buy-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:20px;
}

.buy-card{
  padding:16px;
  border:1px solid var(--border);
  border-radius:10px;
  background:var(--surface);
  text-decoration:none;
  color:white;
}

.buy-card.main{
  grid-column:span 2;
  border-color:var(--orange);
}

/* NAV */
.tiles{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:20px;
}

.tile{
  padding:16px;
  border:1px solid var(--border);
  border-radius:10px;
  text-decoration:none;
  color:white;
  background:var(--surface);
}
</style>
</head>

<body>
<div class="wrap">

<h1>Check if AI recommends your business</h1>
<p class="hero-sub">If you're not in AI answers, you don't exist.</p>

<div class="audit-box">
  <input id="siteInput" placeholder="yourwebsite.com" />
  <button onclick="startAudit()">Check</button>
</div>

<!-- RESULT -->
<div id="result" class="result">

  <div class="score">3.2 / 10</div>

  <div class="verdict">You are invisible in AI search</div>

  <p>
    If someone asks AI for your service, your competitors are shown — not you.
  </p>

  <!-- GATE -->
  <div id="gate" class="gate">

    <input placeholder="Your name" />
    <input id="email" placeholder="Your email" />

    <button onclick="unlock()">Get full report</button>

    <!-- CTA AFTER -->
    <div id="ctaBlock" style="display:none">

      <p style="margin-top:10px;">
        Most businesses with your score are never shown in AI results.
      </p>

      <a href="https://your-lemonsqueezy-link.com" class="cta">
        Fix my AI visibility →
      </a>

      <p style="font-size:0.7rem; color:#888; text-align:center;">
        Secure checkout • Also on Gumroad & Whop
      </p>

    </div>

  </div>

</div>

<!-- STORY -->
<div class="section">
<h2>The shift</h2>
<p>
AI selects businesses, not pages.  
Most businesses are invisible.
</p>
</div>

<!-- BUY -->
<div class="section">
<h2>Start fixing your visibility</h2>

<div class="buy-grid">
  <a href="https://your-lemonsqueezy-link.com" class="buy-card main">
    Direct (Recommended)
  </a>
  <a href="https://gumroad.com/your-link" class="buy-card">Gumroad</a>
  <a href="https://whop.com/your-link" class="buy-card">Whop</a>
</div>

</div>

<!-- NAV -->
<div class="section">
<h2>Explore</h2>

<div class="tiles">
  <a href="/blog" class="tile">Blog</a>
  <a href="/about" class="tile">About</a>
  <a href="/dashboard" class="tile">Dashboard</a>
  <a href="/audit" class="tile">Run Audit</a>
</div>

</div>

<script>
function startAudit(){
  document.getElementById("result").style.display="block";
}

function unlock(){
  document.getElementById("ctaBlock").style.display="block";
}
</script>

</div>
</body>
</html>