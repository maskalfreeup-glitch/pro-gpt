<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>ProGPT — AI Visibility Audit</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet"/>

<style>
:root{
  --bg:#040507;
  --card:#0e1016;
  --border:#1c1f2a;
  --text:#f1f3f8;
  --muted:#8b90a8;
  --accent:#00ff88;
}

/* BASE */
*{box-sizing:border-box;margin:0;padding:0}

body{
  font-family:Inter,sans-serif;
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
}

/* ANIMATED GRID */
body::before{
  content:"";
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
  background-size:40px 40px;
  animation:moveGrid 20s linear infinite;
}

@keyframes moveGrid{
  from{background-position:0 0}
  to{background-position:40px 40px}
}

/* GLOW ORB */
.glow{
  position:fixed;
  width:500px;
  height:500px;
  background:radial-gradient(circle, rgba(0,255,136,0.18), transparent 70%);
  top:20%;
  left:50%;
  transform:translateX(-50%);
  filter:blur(80px);
  animation:float 6s ease-in-out infinite;
}

@keyframes float{
  0%,100%{transform:translate(-50%,0)}
  50%{transform:translate(-50%,20px)}
}

/* CONTAINER */
.container{
  max-width:720px;
  margin:auto;
  padding:24px;
  position:relative;
}

/* HERO */
h1{
  font-size:40px;
  line-height:1.1;
  opacity:0;
  animation:fadeUp 0.8s forwards;
}

p{
  color:var(--muted);
  margin-top:10px;
  opacity:0;
  animation:fadeUp 1s forwards;
}

/* LIVE */
.live{
  margin-top:12px;
  font-size:13px;
  color:var(--muted);
  opacity:0;
  animation:fadeUp 1.2s forwards;
}

.dot{
  width:8px;height:8px;
  background:var(--accent);
  display:inline-block;
  border-radius:50%;
  margin-right:6px;
  animation:pulse 1.2s infinite;
}

@keyframes pulse{
  0%,100%{opacity:1}
  50%{opacity:0.3}
}

/* CARD */
.card{
  background:var(--card);
  border:1px solid var(--border);
  padding:20px;
  border-radius:14px;
  margin-top:20px;
  backdrop-filter:blur(6px);
  box-shadow:0 0 30px rgba(0,255,136,0.05);
  opacity:0;
  animation:fadeUp 1.4s forwards;
}

/* INPUT */
input{
  width:100%;
  padding:14px;
  border-radius:10px;
  border:1px solid var(--border);
  background:#0b0c12;
  color:white;
  margin-top:10px;
  transition:0.2s;
}

input:focus{
  border-color:var(--accent);
  box-shadow:0 0 10px rgba(0,255,136,0.3);
  outline:none;
}

/* BUTTON */
button{
  margin-top:14px;
  width:100%;
  padding:14px;
  border-radius:10px;
  border:none;
  background:linear-gradient(90deg,#00ff88,#00e0ff);
  color:black;
  font-weight:600;
  cursor:pointer;
  transition:0.2s;
}

button:hover{
  transform:translateY(-2px);
  box-shadow:0 10px 25px rgba(0,255,136,0.3);
}

/* DISCORD */
.discord{
  display:block;
  text-align:center;
  margin-top:12px;
  padding:14px;
  border-radius:10px;
  border:1px solid #5865f2;
  color:#8ea1ff;
  text-decoration:none;
  transition:0.2s;
}

.discord:hover{
  background:rgba(88,101,242,0.1);
}

/* SCAN */
.scan{
  display:none;
  margin-top:20px;
  text-align:center;
}

.loader{
  height:6px;
  background:#111;
  border-radius:6px;
  overflow:hidden;
  margin-top:10px;
}

.loader span{
  display:block;
  height:100%;
  width:0%;
  background:linear-gradient(90deg,#00ff88,#00e0ff);
  animation:scan 2.5s linear forwards;
}

@keyframes scan{
  0%{width:0%}
  100%{width:100%}
}

/* ANIMATION */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px)}
  to{opacity:1;transform:translateY(0)}
}
</style>
</head>

<body>

<div class="glow"></div>

<div class="container">

<h1>AI already chose your competitors.</h1>
<p>If you're not in AI answers, you don’t exist.</p>

<div class="live">
<span class="dot"></span>
<span id="liveCount">21</span> audits running now
</div>

<!-- INPUT -->
<div id="step1" class="card">
<input id="website" placeholder="yourwebsite.com">
<button onclick="startScan()">Run free audit →</button>
</div>

<!-- SCAN -->
<div id="scan" class="scan">
<p id="scanText">Scanning your site…</p>
<div class="loader"><span></span></div>
</div>

<!-- RESULT -->
<div id="result" style="display:none;margin-top:20px">

<div class="card">

<h2 id="scoreText">Score: 3.4 / 10</h2>

<p>AI is not recommending your business.</p>

<input id="email" placeholder="Enter email to unlock audit">

<button onclick="saveLead()">Unlock full audit →</button>

<a href="https://whop.com/progpt" class="discord">
Enter Discord System →
</a>

</div>

</div>

</div>

<script>
function startScan(){
  document.getElementById("step1").style.display="none";
  document.getElementById("scan").style.display="block";

  let texts=[
    "Scanning website…",
    "Analyzing AI signals…",
    "Checking competitors…",
    "Evaluating ranking gaps…"
  ];

  let i=0;
  let interval=setInterval(()=>{
    document.getElementById("scanText").innerText=texts[i];
    i++;
    if(i>=texts.length) clearInterval(interval);
  },600);

  setTimeout(showResult,2600);
}

function showResult(){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(Math.random()*3+2).toFixed(1);
  document.getElementById("scoreText").innerText="Score: "+score+" / 10";
}

function saveLead(){
  localStorage.setItem("email",document.getElementById("email").value);
}

/* LIVE COUNTER */
setInterval(()=>{
  let el=document.getElementById("liveCount");
  el.innerText=parseInt(el.innerText)+Math.floor(Math.random()*2);
},4000);
</script>

</body>
</html>