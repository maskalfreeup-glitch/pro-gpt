---
const title = "ProGPT — Get Recommended in ChatGPT & AI Search";
const description = "Check if ChatGPT recommends your business. Free AI visibility audit for local businesses.";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <style>
    body {
      margin: 0;
      background: #000;
      color: #fff;
      font-family: -apple-system, sans-serif;
    }

    .container {
      max-width: 680px;
      margin: 0 auto;
      padding: 60px 20px;
      text-align: center;
    }

    h1 {
      font-size: 2.4rem;
      line-height: 1.3;
      margin-bottom: 12px;
    }

    .sub {
      color: #aaa;
      margin-bottom: 28px;
    }

    .audit-box {
      display: flex;
      background: #111;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid #222;
    }

    .audit-box input {
      flex: 1;
      padding: 14px;
      border: none;
      background: transparent;
      color: #fff;
      outline: none;
    }

    .audit-box button {
      background: #7C3AED;
      border: none;
      padding: 14px 18px;
      color: white;
      font-weight: 600;
      cursor: pointer;
    }

    .trust {
      font-size: 0.8rem;
      color: #666;
      margin-top: 10px;
    }

    .result {
      display: none;
      margin-top: 24px;
      background: #111;
      padding: 18px;
      border-radius: 10px;
      text-align: left;
      border: 1px solid #222;
    }

    .cta {
      display: block;
      margin-top: 14px;
      background: #7C3AED;
      padding: 12px;
      text-align: center;
      color: white;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
    }

    .section {
      margin-top: 60px;
      text-align: left;
    }

    .section h2 {
      font-size: 1.4rem;
      margin-bottom: 10px;
    }

    .section p {
      color: #aaa;
      margin-bottom: 16px;
      line-height: 1.6;
    }

    .list div {
      margin-bottom: 8px;
      color: #ccc;
    }

    footer {
      margin-top: 60px;
      font-size: 0.8rem;
      color: #555;
      text-align: center;
    }
  </style>
</head>

<body>

<div class="container">

  <!-- HERO -->
  <h1>Check if ChatGPT recommends your business</h1>
  <p class="sub">If AI doesn’t mention you, your customers never see you.</p>

  <div class="audit-box">
    <input id="siteInput" placeholder="Enter your website..." />
    <button onclick="runAudit()">Check</button>
  </div>

  <div class="trust">
    Used for ChatGPT, Gemini & AI search visibility
  </div>

  <!-- RESULT -->
  <div id="result" class="result">
    <b>AI Visibility Score: 3.2 / 10</b><br><br>

    ❌ Not recommended in ChatGPT answers<br>
    ⚠️ Weak authority & unclear positioning<br><br>

    Your competitors are more likely to appear instead of you.

    <a href="https://whop.com/progpt" class="cta">
      Fix this for me →
    </a>
  </div>

  <!-- WHY IT MATTERS -->
  <div class="section">
    <h2>Why this matters</h2>
    <p>
      People are no longer searching and clicking links.  
      They ask AI directly and choose from its answers.
    </p>
    <div class="list">
      <div>✔ AI recommends only a few businesses</div>
      <div>✔ Most local businesses are invisible</div>
      <div>✔ Visibility = calls, leads, revenue</div>
    </div>
  </div>

  <!-- WHAT WE DO -->
  <div class="section">
    <h2>What we fix</h2>
    <p>
      We optimize your website so AI understands, trusts, and recommends your business.
    </p>
    <div class="list">
      <div>✔ Schema & structured data</div>
      <div>✔ Content clarity & positioning</div>
      <div>✔ Local signals & authority</div>
      <div>✔ FAQ content for AI answers</div>
    </div>
  </div>

  <!-- FINAL CTA -->
  <div class="section">
    <h2>Get your audit</h2>
    <p>
      See exactly why AI is not recommending you — and how to fix it.
    </p>

    <a href="https://whop.com/progpt" class="cta">
      Get full audit →
    </a>
  </div>

  <footer>
    progpt.store — AI Search Optimization
  </footer>

</div>

<script>
function runAudit() {
  const input = document.getElementById("siteInput").value;
  if (!input) return;

  document.getElementById("result").style.display = "block";
}
</script>

</body>
</html>