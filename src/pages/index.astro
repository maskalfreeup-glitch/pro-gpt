---
const title = "AI Visibility Engine";
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#f7f6f3;
  --card:#ffffff;
  --border:#e8e8e3;
  --ink:#1a1a18;
  --muted:#6b6b63;
  --danger:#de350b;
}

body{
  margin:0;
  font-family:'Geist',sans-serif;
  background:var(--bg);
  color:var(--ink);
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:14px 20px;
  border-bottom:1px solid var(--border);
}

.logo{font-weight:700}
.nav a{margin-left:16px;text-decoration:none;color:var(--muted);font-size:14px}

/* HERO */
.hero{
  max-width:680px;
  margin:70px auto 20px;
  text-align:center;
  padding:0 20px;
}

h1{
  font-family:'Instrument Serif',serif;
  font-size:clamp(38px,7vw,64px);
  line-height:1.05;
  margin:0;
}

.sub{
  color:var(--muted);
  margin-top:14px;
  font-size:18px;
}

/* TENSION */
.tension{
  font-size:13px;
  color:#8a8a82;
  margin-top:10px;
}

/* MACHINE */
.machine{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:18px;
  padding:20px;
  margin-top:28px;
  box-shadow:0 8px 30px rgba(0,0,0,0.04);
}

.input-wrap{
  display:flex;
  gap:8px;
}

input{
  flex:1;
  padding:16px;
  border-radius:12px;
  border:1px solid var(--border);
  font-size:16px;
  background:#fafafa;
}

button{
  min-width:130px;
  background:var(--ink);
  color:white;
  border:none;
  padding:16px;
  border-radius:12px;
  font-weight:700;
  cursor:pointer;
}

.status{
  font-size:12px;
  color:var(--muted);
  margin-top:10px;
  font-family:monospace;
}

.micro{
  font-size:12px;
  color:#9a9a92;
  margin-top:6px;
}

/* STATES */
#scan,#result,#emailGate,#paywall{display:none;}

.bar-bg{
  height:4px;
  background:#eee;
  margin-top:12px;
  border-radius:10px;
  overflow:hidden;
}

.bar{
  height:100%;
  width:0%;
  background:var(--ink);
}

/* RESULT */
.output{
  margin-top:18px;
  padding:16px;
  background:#fafafa;
  border-radius:12px;
  border:1px solid var(--border);
  text-align:left;
}

.score{
  font-size:28px;
  font-weight:700;
}

.danger{
  color:var(--danger);
  font-weight:600;
  margin-top:4px;
}

ul{
  padding-left:18px;
  color:var(--danger);
  margin-top:10px;
}

/* CTA */
.cta{
  text-align:center;
  margin-top:16px;
}

.cta a{
  display:inline-block;
  margin:6px;
  padding:12px 18px;
  border-radius:8px;
  text-decoration:none;
  font-size:14px;
}

.primary{background:var(--ink);color:white;}
.secondary{border:1px solid var(--border);color:var(--ink);}

footer{
  text-align:center;
  font-size:12px;
  color:var(--muted);
  padding:40px 0;
}
</style>
</head>

<body>

<nav>
  <div class="logo">AI Visibility</div>
  <div class="nav">
    <a href="/blog">Blog</a>
    <a href="https://discord.gg/progpt">Discord</a>
  </div>
</nav>

<div class="hero">
  <h1>AI is already choosing your competitors.</h1>
  <p class="sub">Reveal whether your business exists inside AI answers.</p>

  <div class="tension">
    Most businesses score below 3/10
  </div>

  <div class="machine">

    <div id="inputBox" class="input-wrap">
      <input id="url" placeholder="yourwebsite.com">
      <button onclick="run()">Reveal →</button>
    </div>

    <div id="status" class="status">
      AI index active • waiting query
    </div>

    <div class="micro">
      competitors already being selected
    </div>

    <div id="scan">
      <div class="bar-bg"><div id="bar" class="bar"></div></div>
    </div>

    <div id="result" class="output">
      <div class="score"><span id="score"></span>/10</div>
      <div class="danger">Not recommended in AI answers</div>

      <div style="margin-top:10px;">
        AI prefers:
        <ul id="competitors"></ul>
      </div>
    </div>

    <div id="emailGate" class="output">
      <strong>You're missing critical ranking signals</strong>
      <p style="font-size:13px;color:var(--muted);">
        Get the exact signals AI requires to recommend you
      </p>

      <input id="email" placeholder="your@email.com">
      <button onclick="unlock()">Unlock report →</button>
    </div>

    <div id="paywall" class="output">
      <strong>Scan limit reached</strong>
      <p style="font-size:13px;color:var(--muted);">
        Monitor competitors + fix your AI visibility system
      </p>

      <div class="cta">
        <a href="https://whop.com/progpt" class="primary">Upgrade Access</a>
        <a href="https://discord.gg/progpt" class="secondary">Join Research</a>
      </div>
    </div>

  </div>
</div>

<footer>
© {year} ProGPT
</footer>

<script is:inline>
let scans = localStorage.getItem("scans") || 0;

function run(){
  let url=document.getElementById("url").value;
  if(!url || !url.includes(".")) return;

  if(scans >= 3){
    document.getElementById("inputBox").style.display="none";
    document.getElementById("paywall").style.display="block";
    return;
  }

  scans++;
  localStorage.setItem("scans", scans);

  document.getElementById("inputBox").style.display="none";
  document.getElementById("scan").style.display="block";
  document.getElementById("status").innerText="Analyzing AI ranking layer...";

  let w=0;
  let int=setInterval(()=>{
    w+=4;
    document.getElementById("bar").style.width=w+"%";

    if(w>=100){
      clearInterval(int);
      show(url);
    }
  },35);
}

function show(url){
  document.getElementById("scan").style.display="none";
  document.getElementById("result").style.display="block";

  let score=(1 + Math.random()*2).toFixed(1);
  document.getElementById("score").innerText=score;

  let clean=url.split('.')[0];
  let list=document.getElementById("competitors");
  list.innerHTML="";

  [""+clean+"pro.com","try"+clean+".com","best"+clean+".co"].forEach(c=>{
    let li=document.createElement("li");
    li.innerText=c;
    list.appendChild(li);
  });

  setTimeout(()=>{
    document.getElementById("emailGate").style.display="block";
  },1200);
}

function unlock(){
  let email=document.getElementById("email").value;
  if(!email.includes("@")) return;
  window.location.href="https://whop.com/progpt";
}
</script>

</body>
</html>