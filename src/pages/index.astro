---
// ProGPT Store â€” Main Page
// Fonts loaded via <link> below; JS is inline (is:inline) to preserve
// global function scope needed by inline onclick handlers
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link
  href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@300;400;500&display=swap"
  rel="stylesheet"
/>

<style is:global>

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   WHOP DESIGN SYSTEM â€” TOKENS
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
:root {
  --black:   #000000;
  --bg:      #0a0a0a;
  --bg1:     #111111;
  --bg2:     #161616;
  --bg3:     #1c1c1c;
  --line:    #222222;
  --line2:   #2a2a2a;
  --line3:   #333333;
  --white:   #ffffff;
  --gray1:   #fafafa;
  --gray2:   #ebebeb;
  --gray3:   #c4c4c4;
  --gray4:   #a0a0a0;
  --gray5:   #6b6b6b;
  --gray6:   #444444;
  --accent:  #ffffff;
  --blue:    #3b82f6;
  --green:   #22c55e;
  --purple:  #a855f7;
  --discord: #5865F2;
  --g:       'Geist', sans-serif;
  --m:       'Geist Mono', monospace;
  --r:       6px;
  --r2:      12px;
  --r3:      16px;
  --r4:      20px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
:focus-visible { outline: 2px solid rgba(255,255,255,.35); outline-offset: 2px; border-radius: 4px; }
button:active, a:active { opacity: .82; }

body {
  font-family: var(--g);
  background: var(--black);
  color: var(--gray2);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   NAV â€” Whop-style sticky nav
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.nav {
  position: sticky; top: 0; z-index: 500;
  height: 52px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 20px;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--line);
}

.nav-left { display: flex; align-items: center; gap: 0; }

.nav-logo {
  display: flex; align-items: center; gap: 8px;
  font-size: 15px; font-weight: 700; letter-spacing: -.3px;
  color: var(--white); text-decoration: none; cursor: pointer;
  padding: 6px 12px; margin-left: -12px;
  border-radius: var(--r2);
  transition: background .15s;
}
.nav-logo:hover { background: var(--bg2); }
.nav-logo-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--white);
  box-shadow: 0 0 0 2px rgba(255,255,255,.15);
}

.nav-sep { width: 1px; height: 18px; background: var(--line2); margin: 0 4px; }

.nav-tabs { display: flex; align-items: center; gap: 2px; }
.nav-tab {
  padding: 6px 12px; border-radius: var(--r2);
  font-size: 13.5px; font-weight: 500; color: var(--gray5);
  cursor: pointer; text-decoration: none; border: none; background: none;
  transition: color .15s, background .15s; white-space: nowrap;
}
.nav-tab:hover { color: var(--gray2); background: var(--bg2); }
.nav-tab.active { color: var(--white); background: var(--bg2); }

.nav-right { display: flex; align-items: center; gap: 8px; }
.nav-pill {
  display: flex; align-items: center; gap: 6px;
  padding: 6px 12px; border-radius: 20px;
  font-size: 13px; font-weight: 500;
  cursor: pointer; text-decoration: none; border: none;
  transition: all .15s; white-space: nowrap;
}
.nav-pill.ghost { background: var(--bg2); color: var(--gray3); border: 1px solid var(--line2); }
.nav-pill.ghost:hover { background: var(--bg3); color: var(--white); border-color: var(--line3); }
.nav-pill.solid { background: var(--white); color: var(--black); }
.nav-pill.solid:hover { background: var(--gray2); }
.nav-console-short { display: none; }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   PAGE SYSTEM
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.page { display: none; scroll-margin-top: 52px; }
.page.active { display: block; }
.wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   STORE PAGE â€” Hero section
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.store-banner {
  background: var(--bg1);
  border-bottom: 1px solid var(--line);
  padding: 48px 0 0;
}

.store-identity {
  display: flex; align-items: flex-end; gap: 24px;
  margin-bottom: 28px;
}

.store-logo {
  width: 88px; height: 88px; border-radius: 22px;
  background: var(--white);
  display: flex; align-items: center; justify-content: center;
  font-size: 38px; flex-shrink: 0;
  box-shadow: 0 0 0 1px var(--line2), 0 8px 24px rgba(0,0,0,.4);
}

.store-meta {}
.store-name {
  font-size: 28px; font-weight: 800; letter-spacing: -.8px;
  color: var(--white); margin-bottom: 6px;
  display: flex; align-items: center; gap: 10px;
}
.verified-badge {
  display: inline-flex; align-items: center; justify-content: center;
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--blue); flex-shrink: 0;
}
.verified-badge svg { width: 12px; height: 12px; }

.store-tagline { font-size: 14px; color: var(--gray5); line-height: 1.5; max-width: 520px; }

.store-stats-row {
  display: flex; align-items: center; gap: 24px; margin-top: 12px; flex-wrap: wrap;
}
.store-stat {
  display: flex; align-items: center; gap: 6px;
  font-size: 13px; color: var(--gray5);
}
.store-stat svg { color: var(--gray6); }
.store-stat strong { color: var(--gray3); font-weight: 600; }

.store-actions {
  display: flex; gap: 8px; margin-top: 20px; align-items: center;
}
.store-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 9px 18px; border-radius: 20px;
  font-size: 13.5px; font-weight: 600;
  cursor: pointer; text-decoration: none; border: none;
  transition: all .15s;
}
.store-btn:active { transform: scale(.96); }
.store-btn.primary { background: var(--white); color: var(--black); }
.store-btn.primary:hover { background: var(--gray2); }
.store-btn.secondary { background: var(--bg3); color: var(--gray2); border: 1px solid var(--line2); }
.store-btn.secondary:hover { background: var(--bg2); border-color: var(--line3); color: var(--white); }
.store-btn.discord-btn { background: rgba(88,101,242,.15); color: #7289da; border: 1px solid rgba(88,101,242,.25); }
.store-btn.discord-btn:hover { background: rgba(88,101,242,.25); border-color: rgba(88,101,242,.4); }

/* Store nav tabs */
.store-nav {
  display: flex; gap: 0;
  border-top: 1px solid var(--line);
  margin-top: 28px;
}
.store-nav-tab {
  padding: 12px 18px;
  font-size: 13.5px; font-weight: 500; color: var(--gray5);
  cursor: pointer; border-bottom: 2px solid transparent;
  transition: color .15s, border-color .15s;
  white-space: nowrap;
}
.store-nav-tab:hover { color: var(--gray2); }
.store-nav-tab.active { color: var(--white); border-bottom-color: var(--white); }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   STORE LAYOUT â€” sidebar + products
â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.store-body {
  padding: 32px 0 80px;
}

.store-layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 28px;
  align-items: start;
}

/* SIDEBAR */
.store-sidebar {}

.sidebar-section {
  background: var(--bg1);
  border: 1px solid var(--line);
  border-radius: var(--r3);
  padding: 16px;
  margin-bottom: 12px;
}

.sidebar-label {
  font-size: 11px; font-weight: 600; color: var(--gray6);
  letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 10px;
}

.sidebar-filter {
  display: flex; flex-direction: column; gap: 2px;
}

.sf-btn {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 10px; border-radius: var(--r);
  font-size: 13.5px; font-weight: 500; color: var(--gray4);
  cursor: pointer; border: none; background: none;
  transition: all .12s; text-align: left;
}
.sf-btn:hover { background: var(--bg2); color: var(--gray2); }
.sf-btn.active { background: var(--bg3); color: var(--white); }
.sf-count {
  font-size: 11px; color: var(--gray6); font-family: var(--m);
  background: var(--bg3); padding: 2px 7px; border-radius: 20px;
}
.sf-btn.active .sf-count { background: var(--line2); color: var(--gray4); }

/* Discord community widget in sidebar */
.dc-sidebar-widget {
  background: linear-gradient(135deg, rgba(88,101,242,.12), rgba(88,101,242,.04));
  border: 1px solid rgba(88,101,242,.2);
  border-radius: var(--r3);
  padding: 18px;
  cursor: pointer;
  transition: border-color .18s;
}
.dc-sidebar-widget:hover { border-color: rgba(88,101,242,.4); }
.dc-widget-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.dc-widget-icon {
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--discord);
  display: flex; align-items: center; justify-content: center;
}
.dc-widget-name { font-size: 14px; font-weight: 700; color: var(--white); }
.dc-widget-sub  { font-size: 11.5px; color: #7289da; font-family: var(--m); }
.dc-widget-stats { display: flex; gap: 14px; margin-bottom: 14px; }
.dc-ws { font-size: 12px; color: var(--gray5); }
.dc-ws strong { display: block; font-size: 17px; font-weight: 700; color: var(--white); letter-spacing: -.5px; }
.dc-join-btn-sm {
  width: 100%; padding: 9px; border-radius: var(--r2);
  background: var(--discord); color: #fff; border: none;
  font-size: 13px; font-weight: 600; cursor: pointer;
  transition: opacity .15s; text-decoration: none; display: block; text-align: center;
}
.dc-join-btn-sm:hover { opacity: .88; }

/* PRODUCT GRID */
.store-products {}

.products-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px;
}
.products-count { font-size: 13px; color: var(--gray5); font-family: var(--m); }
.products-sort {
  display: flex; align-items: center; gap: 6px;
  background: var(--bg1); border: 1px solid var(--line2); border-radius: var(--r2);
  padding: 7px 12px; font-size: 13px; color: var(--gray4); cursor: pointer;
}
.products-sort svg { color: var(--gray6); }

/* PRODUCT CARDS */
.product-grid { display: flex; flex-direction: column; gap: 12px; }

.product-card {
  background: var(--bg1);
  border: 1px solid var(--line);
  border-radius: var(--r3);
  overflow: hidden;
  transition: border-color .18s, transform .18s, box-shadow .18s;
  cursor: pointer;
  display: grid;
  grid-template-columns: 280px 1fr;
  min-height: 200px;
}
.product-card:hover {
  border-color: var(--line3);
  transform: translateY(-1px);
  box-shadow: 0 8px 32px rgba(0,0,0,.35);
}
.product-card.featured {
  border-color: rgba(255,255,255,.12);
  background: linear-gradient(to right, var(--bg2), var(--bg1));
}

.product-thumb {
  position: relative; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.product-thumb-bg {
  position: absolute; inset: 0;
}
.product-thumb-emoji {
  font-size: 52px; position: relative; z-index: 1;
  filter: drop-shadow(0 4px 16px rgba(0,0,0,.4));
}
.product-badge {
  position: absolute; top: 14px; left: 14px; z-index: 2;
  padding: 4px 10px; border-radius: 20px;
  font-size: 10.5px; font-weight: 600; letter-spacing: .3px;
  backdrop-filter: blur(8px);
}
.badge-featured { background: rgba(255,255,255,.15); color: var(--white); border: 1px solid rgba(255,255,255,.2); }
.badge-new      { background: rgba(34,197,94,.15); color: #4ade80; border: 1px solid rgba(34,197,94,.2); }
.badge-free     { background: rgba(99,102,241,.15); color: #a5b4fc; border: 1px solid rgba(99,102,241,.2); }
.badge-hot      { background: rgba(251,146,60,.12); color: #fb923c; border: 1px solid rgba(251,146,60,.2); }

.product-info {
  padding: 24px 28px;
  display: flex; flex-direction: column;
}

.product-platform-row {
  display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
}
.platform-chip {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 9px; border-radius: 20px; border: 1px solid var(--line2);
  font-size: 11px; font-weight: 500; color: var(--gray5);
  font-family: var(--m); letter-spacing: .3px;
}
.platform-chip-dot { width: 5px; height: 5px; border-radius: 50%; }

.product-title {
  font-size: 20px; font-weight: 700; letter-spacing: -.4px;
  color: var(--white); margin-bottom: 8px; line-height: 1.2;
}
.product-desc {
  font-size: 13.5px; color: var(--gray5); line-height: 1.65;
  margin-bottom: 16px; flex: 1;
}

.product-includes {
  display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 18px;
}
.include-pill {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 20px;
  background: var(--bg3); border: 1px solid var(--line2);
  font-size: 12px; color: var(--gray4);
}
.include-pill::before { content: "Â·"; color: var(--gray6); }

.product-footer {
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
}
.product-price-block {}
.product-price {
  font-size: 28px; font-weight: 800; letter-spacing: -1.5px;
  color: var(--white); line-height: 1;
}
.product-price.free { color: #4ade80; }
.product-period { font-size: 12px; color: var(--gray6); font-family: var(--m); margin-top: 2px; }

.product-members {
  display: flex; align-items: center; gap: 6px;
  font-size: 12.5px; color: var(--gray5);
}
.members-dots { display: flex; }
.member-dot {
  width: 22px; height: 22px; border-radius: 50%;
  border: 2px solid var(--bg1); margin-left: -7px;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px; font-weight: 700; color: #fff;
}
.member-dot:first-child { margin-left: 0; }

.product-buy-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 22px; border-radius: 20px;
  font-size: 13.5px; font-weight: 600;
  cursor: pointer; text-decoration: none; border: none;
  transition: all .15s; white-space: nowrap;
}
.pbb-white  { background: var(--white); color: var(--black); }
.pbb-white:hover { background: var(--gray2); }
.pbb-outline { background: transparent; color: var(--gray2); border: 1px solid var(--line2); }
.pbb-outline:hover { border-color: var(--line3); background: var(--bg2); color: var(--white); }

/* Whop-branded button */
.pbb-whop {
  background: #7440e0;
  color: #fff;
  border: 1px solid rgba(255,255,255,.12);
}
.pbb-whop:hover { background: #6533cc; }

/* Whop platform chip */
.platform-chip.whop-chip {
  background: rgba(116,64,224,.15);
  border-color: rgba(116,64,224,.35);
  color: #c4a8ff;
  gap: 5px;
}

/* â”€â”€â”€ WHOP TRUST BAR â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.whop-trust-bar {
  margin-top: 28px;
  padding: 16px 20px;
  background: var(--bg1);
  border: 1px solid var(--line);
  border-radius: var(--r3);
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 14px;
}
.wtb-left {
  display: flex; align-items: center; gap: 10px;
}
.wtb-whop-logo {
  display: flex; align-items: center; gap: 7px;
  padding: 5px 12px; border-radius: 8px;
  background: rgba(116,64,224,.1); border: 1px solid rgba(116,64,224,.25);
  font-size: 12px; font-weight: 700; color: #c4a8ff; letter-spacing: -.2px;
}
.wtb-whop-logo svg { flex-shrink: 0; }
.wtb-tagline { font-family: var(--m); font-size: 11px; color: var(--gray6); }
.wtb-trust-items {
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
}
.wtb-item {
  display: flex; align-items: center; gap: 5px;
  font-family: var(--m); font-size: 10.5px; color: var(--gray5);
}
.wtb-item svg { color: var(--gray6); flex-shrink: 0; }
.wtb-item.green { color: #4ade80; }
.wtb-item.green svg { color: #4ade80; }

/* Payment method logos row */
.wtb-payments {
  display: flex; align-items: center; gap: 8px;
}
.pay-badge {
  height: 20px; padding: 3px 8px; border-radius: 4px;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 9.5px; font-weight: 700; letter-spacing: .5px;
  border: 1px solid var(--line2); color: var(--gray5);
  background: var(--bg2); white-space: nowrap;
}
.pay-badge.visa    { color: #1a1f71; background: #fff; border-color: #e0e0e0; }
.pay-badge.mc      { color: #fff; background: #252525; border-color: var(--line2); }
.pay-badge.paypal  { color: #003087; background: #fff; border-color: #e0e0e0; }
.pay-badge.stripe  { color: #6772e5; background: #fff; border-color: #e0e0e0; }

/* â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
   DISCORD BIG BLOCK
