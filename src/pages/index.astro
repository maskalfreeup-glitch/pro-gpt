---
const title = "ProGPT — AI Visibility Audit";
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>

<style>
body {
  margin: 0;
  background: #000;
  color: #fff;
  font-family: -apple-system, sans-serif;
}

/* GRID */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(124,58,237,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(124,58,237,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

/* LAYOUT */
.container {
  max-width: 720px;
  margin: auto;
  padding: 80px 20px;
  text-align: center;
}

/* HERO */
h1 {
  font-size: 2.6rem;
  font-weight: 800;
  line-height: 1.2;
}

.sub {
  color: #777;
  margin: 12px 0 30px;
}

/* INPUT */
.audit-box {
  display: flex;
  border: 1px solid #1a1a1a;
  border-radius: 12px;
  overflow: hidden;
  background: #0a0a0a;
}

.audit-box input {
  flex: 1;
  padding: 16px;
  border: none;
  background: transparent;
  color: #fff;
  outline: none;
}

.audit-box button {
  background: linear-gradient(135deg,#7C3AED,#9333EA);
  border: none;
  padding: 16px 22px;
  color: white;
  font-weight: 600;
  cursor: pointer;
}

/* STATUS */
.status {
  margin-top: 20px;
  color: #aaa;
  font-size: 0.9rem;
}

/* RESULT */
.result {
  display: none;
  margin-top: 25px;
  text-align: left;
  background: #0b0b0b;
  padding: 20px;
  border-radius: 12px;
  border: 1px solid #1a1a1a;
}

.score {
  font-size: 1.4rem;
  font-weight: 700;
}

.bad { color: #ff4d4d; }
.warn { color: #ffaa00; }

/* FORM */
.lead-form {
  display: none;
  margin-top: 20px;
}

.lead-form input {
  width: 100%;
  padding: 12px;
  margin-bottom: 10px;
  background: #111;
  border: 1px solid #222;
  border-radius: 8px;
  color: white;
}

.lead-form button {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg,#7C3AED,#9333EA);
  border: none;
  border-radius: 8px;
  color: white;
  font-weight: bold;
  cursor: pointer;
}

/* CTA */
.cta {
  display: block;
  margin-top: 14px;
  padding: 14px;
  background: linear-gradient(135deg,#7C3AED,#9333EA);
  text-align: center;
  border-radius: 10px;
  color: white;
  text-decoration: none;
  font-weight: bold;
}

/* SECTION */
.section {
  margin-top: 70px;
  text-align: left;
}

.section h2 {
  font-size: 1.4rem;
  margin-bottom: 10px;
}

.section p {
  color: #888;
  line-height: 1.6;
}

footer {
  margin-top: 60px;
  color: #444;
  font-size: 0.8rem;
}
</style>
</head>

<body>

<div class="container">

<h1>Check if AI recommends your business</h1>

<p class="sub">
If you're not in AI answers, you don't exist.
</p>

<div class="audit-box">
  <input id="siteInput" placeholder="Enter your website..." />
  <button onclick="startAudit()">Check</button>
</div>

<div id="status" class="status"></div>

<!-- RESULT -->
<div id="result" class="result">
  <div class="score">AI Visibility Score: 3.2 / 10</div>
  <div class="bad">❌ Not recommended</div>
  <div class="warn">⚠ Weak authority signals</div>

  <p style="color:#777; margin-top:10px;">
  AI cannot confidently select your business.
  </p>

  <!-- LEAD FORM -->
  <div id="leadForm" class="lead-form">
    <input id="name" placeholder="Your name" />
    <input id="email" placeholder="Your email" />
    <button onclick="submitLead()">Get full report</button>
  </div>

  <!-- PAID CTA -->
  <a id="paidCTA" href="https://your-lemonsqueezy-link.com" class="cta" style="display:none;">
    Fix this for me →
  </a>
</div>

<!-- STORY -->
<div class="section">
<h2>The shift</h2>
<p>
Search is no longer pages.  
AI picks a few businesses and ignores the rest.  
Most are invisible.
</p>
</div>

<footer>
progpt.store — AI Search Optimization
</footer>

</div>

<script>

function startAudit() {
  const site = document.getElementById("siteInput").value;
  if (!site) return;

  const status = document.getElementById("status");

  status.innerText = "Scanning website...";
  
  setTimeout(() => {
    status.innerText = "Analyzing AI signals...";
  }, 800);

  setTimeout(() => {
    status.innerText = "Generating report...";
  }, 1600);

  setTimeout(() => {
    status.innerText = "";
    document.getElementById("result").style.display = "block";
    document.getElementById("leadForm").style.display = "block";
  }, 2400);
}

function submitLead() {
  const email = document.getElementById("email").value;

  if (!email) return;

  // store locally (replace later with API)
  let leads = JSON.parse(localStorage.getItem("leads") || "[]");
  leads.push({ email, ts: new Date().toISOString() });
  localStorage.setItem("leads", JSON.stringify(leads));

  document.getElementById("leadForm").style.display = "none";
  document.getElementById("paidCTA").style.display = "block";
}

</script>

</body>
</html>